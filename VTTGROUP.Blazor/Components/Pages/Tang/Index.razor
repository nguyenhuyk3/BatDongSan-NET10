@page "/tang"
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model.Tang
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Blazor.Components.CompChilds
@inject TangService TangService
@inject BlockService BlockService
@inject IBaseService BaseService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IWebHostEnvironment _env

<h1 class="legend-title">Tầng</h1>
<div class="rounded-xl bg-white p-4 space-y-3 wraper-content-page">
    <div class="relative z-50">
        <div class="flex flex-wrap items-end gap-3">
            <UiSelect Icon="mdi mdi-office-building-outline"
                      Placeholder="Chọn dự án"
                      Items="ListDA.Select(x => new UiSelect.SelectItem(x.MaDuAn!, x.TenDuAn!))"
                      @bind-Value="selectedMaDuAn"
                      OnChange="OnDuAnChanged" />

            <UiSelect Icon="mdi mdi-view-grid-outline"
                      Placeholder="Chọn block"
                      Disabled="@(string.IsNullOrEmpty(selectedMaDuAn))"
                      Items="(ListBlock ?? new()).Select(x => new UiSelect.SelectItem(x.MaBlock!, x.TenBlock!))"
                      @bind-Value="selectedBlock"
                      OnChange="OnBlockChanged" />
            <div class="ml-auto flex items-center gap-2">
                <AddButton Text="Tầng" OnClick="Insert" />
                <button style="
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #EDAD0F;
        padding: 0 12px;
        border-radius: 8px;
        height: 40px;
        background-color: #FDF7E7;
        color: #EDAD0F;
        font-weight: 600;
        font-size: 16px;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
    "
                        title="Import"
                        @onclick="Import">
                    <i class="mdi mdi-cloud-upload"
                       style="
           color: #EDAD0F;
           font-size: 16px;
       ">
                    </i>
                    <span style="
           color: #EDAD0F;
           font-weight: 600;
           font-size: 16px;
           font-family: 'Inter', sans-serif;
       ">
                        Import
                    </span>
                </button>
            </div>
        </div>
    </div>
    <div class="flex items-center gap-3 my-3">
        <div class="w-[360px] md:w-[480px]">
            <InputSearch @bind-Value="search" OnSearch="Search" />
        </div>
    </div>
    <SelectedDeleteList Count="@SelectedCount" OnRemoveList="RemoveSelectedAsync" OnDeleteList="@DeleteSelectedAsync" />
    <div class="container-table-detail">
        <div class="container-table-fixed has-paging">
            <table class="tbl table-form table-detail treeTable" id="table-data">
                <thead>
                    <tr class="cls_custome_back">
                        <th style="width: 40px" class="text-center">
                            <input type="checkbox" class="form-check-input" checked="@IsSelectAll"
                                   @onchange="(e) => OnCheckboxAllChanged(e)" />
                        </th>
                        <th style="width: 40px" class="text-center">
                            STT
                        </th>
                        <th style="width: 120px" class="text-center">Mã tầng</th>
                        <th style="width: 150px" class="text-center">Tên tầng</th>
                        <th style="width: 150px" class="text-center">Tên block</th>
                        <th style="width: 120px; text-align:right" class="text-center">Hệ số</th>
                        <th style="width: 120px; text-align:right" class="text-center">STT</th>
                        <th style="width: 90px">&nbsp;</th>
                    </tr>
                </thead>

                <tbody class="content-table">
                    @if (ChiTietTang != null && ChiTietTang.Any())
                    {
                        int i = 1;
                        foreach (var item in ChiTietTang)
                        {
                            <tr class="initialized">
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input"
                                           checked="@item.IsSelected"
                                           @onchange="(e) => OnCheckboxChanged(item, e)" />

                                </td>
                                <td style="text-align:center">
                                    <span>@i</span>
                                </td>
                                <td>
                                    <span>
                                        @item.MaTang
                                    </span>
                                </td>
                                <td>
                                    <span>@item.TenTang</span>
                                </td>
                                <td>
                                    <span>@item.TenBlock</span>
                                </td>
                                <td style="text-align:right">
                                    @string.Format("{0:#,#0.##}", item.HeSo)
                                </td>
                                <td style="text-align:right">
                                    @string.Format("{0:#,#0}", item.STTTang)
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center">
                                        <div class="icon-button" data-title="Cập nhật" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => OnEditRecord(item.MaTang!)">
                                                <span><i class="mdi mdi-pencil"></i></span>
                                            </a>
                                        </div>
                                        <div class="icon-button" data-title="Xóa" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => ShowConfirmDelete(item.MaTang!)">
                                                <span><i class="mdi mdi-delete"></i></span>
                                            </a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>

            @if (ChiTietTang == null || !ChiTietTang.Any())
            {
                <div class="p-2">Không có dữ liệu</div>
            }
        </div>
    </div>
    <ConfirmDeleteModal ModalId="confirmDeleteModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa tầng <strong>@selectedMaCongViec</strong> không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDelete">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>

    <ConfirmDeleteModal ModalId="confirmDeleteListModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa danh sách Tầng này không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDeleteList">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>

    <ImportFileModal @ref="importFileModalRef" OnUploaded="HandleFileUpload" />
</div>

@code {
    private List<TangModel> ChiTietTang = new();
    private string? selectedMaCongViec;
    private string? selectedMaDuAn;
    private string? selectedBlock;
    private bool isLoading = false;
    private List<DaDanhMucDuAn> ListDA = new();
    private List<DaDanhMucBlock> ListBlock = new();
    string? search;
    // Chặn re-init JS
    private bool _jsInited;
    private ImportFileModal? importFileModalRef;
    int SelectedCount => ChiTietTang?.Count(x => x.IsSelected) ?? 0;
    private bool IsSelectAll = false;
    protected override async Task OnInitializedAsync()
    {
        await BaseService.CheckPermissionAsync("LoTang", VuViec.Xem.GetDescription());
        ListDA = await BlockService.GetByDuAnAsync();
        await LoadTangData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_jsInited)
        {
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaDuAn", "Chọn dự án", true);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaBlock", "Chọn block", true);
            _jsInited = true;
        }
    }

    private async Task ShowConfirmDelete(string maBlock)
    {
        var coQuyen = await BaseService.KiemTraQuyenVuViec("LoTang", VuViec.Xoa.GetDescription());
        if (coQuyen == false)
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Bạn không có quyền xóa. Xin vui lòng liên hệ quản trị", false);
            return;
        }
        else
        {
            selectedMaCongViec = maBlock;
            await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteModal");
        }
    }

    private async Task ConfirmDelete()
    {
        if (selectedMaCongViec == null || string.IsNullOrEmpty(selectedMaCongViec))
        {
            return;
        }
        var result = await TangService.DeleteTangAsync(selectedMaCongViec, _env.WebRootPath);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteModal");
        ChiTietTang = await TangService.GetTangAsync(string.Empty, string.Empty);
        await LoadTangData();
        selectedMaCongViec = string.Empty;
        StateHasChanged();
    }

    private async Task ConfirmDeleteList()
    {
        var selected = ChiTietTang.Where(d => d.IsSelected).ToList();
        if (selected.Count == 0) return;
        var result = await TangService.DeleteListAsync(selected, _env.WebRootPath);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteListModal");
        await LoadTangData();
        StateHasChanged();
    }

    private async Task OnEditRecord(string maTang)
    {
        Nav.NavigateTo($"/tang/edit/{maTang}");
    }
    private void Insert()
    {
        Nav.NavigateTo("/tang/create");
        return;
    }

    private async Task OnDuAnChanged(string? maDuAn)
    {
        if (isLoading) return;

        selectedMaDuAn = string.IsNullOrWhiteSpace(maDuAn) ? null : maDuAn;

        // Lấy Block theo dự án + reset block giống Trục
        ListBlock = await TangService.GetByBlockAsync(selectedMaDuAn ?? string.Empty);
        selectedBlock = null;

        await InvokeAsync(StateHasChanged);
        await LoadTangData();
    }

    private async Task OnBlockChanged(string? maBlock)
    {
        if (isLoading) return;

        selectedBlock = string.IsNullOrWhiteSpace(maBlock) ? null : maBlock;
        await LoadTangData();
    }


    private async Task LoadTangData()
    {
        isLoading = true;
        try
        {
            ChiTietTang = await TangService.GetTangAsync(selectedMaDuAn ?? string.Empty, selectedBlock ?? string.Empty, search);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Search(string? keyword)
    {
        search = keyword;
        await LoadTangData();
    }

    private async Task HandleFileUpload()
    {
        await LoadTangData();
    }

    private async Task Import()
    {
        if (string.IsNullOrEmpty(selectedMaDuAn))
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Bạn vui lòng chọn dự án để Import", false);
        }
        else
        {
            await importFileModalRef?.ShowFileModal(selectedMaDuAn);
        }
    }

    private async Task OnCheckboxAllChanged(ChangeEventArgs e)
    {
        IsSelectAll = (bool)e.Value;
        foreach (var item in ChiTietTang)
        {
            item.IsSelected = IsSelectAll;
        }
    }

    private async Task OnCheckboxChanged(TangModel item, ChangeEventArgs e)
    {
        item.IsSelected = (bool)e.Value;
        IsSelectAll = ChiTietTang.All(x => x.IsSelected);
    }

    private async Task RemoveSelectedAsync()
    {
        IsSelectAll = false;
        foreach (var item in ChiTietTang)
        {
            item.IsSelected = IsSelectAll;
        }
    }

    private async Task DeleteSelectedAsync()
    {
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteListModal");
    }
}
