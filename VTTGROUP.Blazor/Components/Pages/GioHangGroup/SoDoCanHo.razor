																<span>@canHo.TenSanPham</span>
																<div class="label-dongia" style="color:@(canHo.MaMauChu)!important; font-weight:@(canHo.FontWeghtMaCanHo)!important">@(canHo.IsMoBan == true ? string.Format("{0:#,##0}", canHo.GiaBan) : "")</div>
																@if (canHo.ThoiGianHieuLuc != null)
																{
																	<div class="count-down-ch">
																		<div class="item-count-down">
																			<i class="mdi mdi-timer me-1"></i>
																			<span class="badge-countdown" data-canho="@canHo.MaSanPham"></span>
																		</div>
																	</div>
																}
																@if (canHo.IsGoc == true)
																{
