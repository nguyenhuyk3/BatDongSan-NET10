							</thead>

							<tbody>
								@foreach (var tang in tangHienThi)
								{
									var isLastBlock = i == blocks.Count - 1;

									<tr>
										<td class="floor-label @blockFirst-tang-@tang">@tang</td>
										@foreach (var mat in MatCanHo)
										{
											var trucList = GetTrucs(blockFirst, mat.MaView);
											foreach (var truc in trucList)
											{
												var canHo = GetCanHo(blockFirst, tang, truc.MaTruc, mat.MaView);
												<td class="border text-center">
													@if (canHo != null)
													{
														if (!string.IsNullOrEmpty(nguoiLap) && nguoiLap == "NV")
														{
