						<ul>
							@foreach (var d in ListHienTrang)
							{
								<li><span style="background-color:@d.MaMau; border-color:@d.MaMau"></span>@d.TenTrangThai @(d.MaTrangThai != "ConTrong" ? $"({string.Format("{0:#,#0}", d.SoLuong)})" : "")</li>
							}
						</ul>
					}
				</div>
