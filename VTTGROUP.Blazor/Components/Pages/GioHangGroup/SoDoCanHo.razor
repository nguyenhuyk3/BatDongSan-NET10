																<span>@canHo.TenSanPham</span>
																<div class="label-dongia" style="color:@(canHo.MaMauChu)!important; font-weight:@(canHo.FontWeghtMaCanHo)!important">@(canHo.IsMoBan == true ? string.Format("{0:#,##0}", canHo.GiaBan) : "")</div>
																@if (canHo.ThoiGianHieuLuc != null)
																{
																	<div class="count-down-ch">
																		<div class="item-count-down">
																			<i class="mdi mdi-timer me-1"></i>
																			<span class="badge-countdown" data-canho="@canHo.MaSanPham"></span>
																		</div>
																	</div>
																}
																@if (canHo.IsGoc == true)
																{
																	<span class="rg-goc"></span>
																}
															</div>
														}
														else
														{
															if (!string.IsNullOrEmpty(canHo.TinhTrangSanPham) && canHo.TinhTrangSanPham != "ConTrong")
															{
																<div class="apartment default @(canHo.IsMoBan == true ? "is-moban" : "") @(canHo.IsGoc == true ? "canho-goc" : "")" @onclick="() => OnViewCH(canHo)" id-block="@canHo.TenBlock" id-truc="truc-@(canHo.MaTruc)" id-tang="tang-@(canHo.TenTang)" style="background-color:@(canHo.MaMauTinhTrang)!important; color:@(canHo.MaMauChu)!important; font-weight:@(canHo.FontWeghtMaCanHo)!important">
																	<span>@canHo.TenSanPham</span>
																	<div class="label-dongia" style="color:@(canHo.MaMauChu)!important; font-weight:@(canHo.FontWeghtMaCanHo)!important">@(canHo.IsMoBan == true ? string.Format("{0:#,##0}", canHo.GiaBan) : "")</div>
																	@if (canHo.ThoiGianHieuLuc != null)
																	{
																		<div class="count-down-ch">
																			<div class="item-count-down">
																				<i class="mdi mdi-timer me-1"></i>
																				<span class="badge-countdown" data-canho="@canHo.MaSanPham"></span>
																			</div>
																		</div>
																	}
																	@if (canHo.IsGoc == true)
																	{
																		<span class="rg-goc"></span>
																	}
																</div>
															}
															else
															{
																<div class="no-default">&nbsp;</div>
															}
														}
													}
													else
													{
														<div class="no-default">&nbsp;</div>
													}
												</td>
											}
										}
									</tr>
								}
							</tbody>

							<!-- 4. Footer: TRỤC LẦN NỮA -->
							<tfoot>
								<tr>
									<td class="floor-label-footer" style="padding:0">
										@if (!ExpandedBlocks.Contains(blockFirst) && TangList.Count > offset)
										{
											<button class="title-label tn-show-all-floor" @onclick="() => ShowAllTangForBlock(blockFirst)" data-title="Xem tất cả" data-position="right">
												<span class="triple-arrow">
													<i class="bi bi-chevron-double-down"></i>
													<i class="bi bi-chevron-double-down"></i>
												</span>
											</button>
										}
										@if (ExpandedBlocks.Contains(blockFirst))
										{
											<button class="title-label tn-show-all-floor" @onclick="() => HideAllTangForBlock(blockFirst)" data-title="Thu gọn" data-position="right">
												<span class="triple-arrow-up">
													<i class="bi bi-chevron-double-up"></i>
													<i class="bi bi-chevron-double-up"></i>
