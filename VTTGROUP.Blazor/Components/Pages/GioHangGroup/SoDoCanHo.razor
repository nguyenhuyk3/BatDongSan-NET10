<h1 class="legend-title">Giỏ hàng</h1>
<div class="rounded-xl bg-white wraper-content-page page-giohang" style="overflow: hidden;">
	<div class="relative z-50">
		<div class="flex flex-wrap align-items-center gap-3 px-4 py-3 wrapper-infor-top">
			@if (string.IsNullOrEmpty(CongTrinhSan?.MaCongTrinh))
			{
				<UiSelect Icon="mdi mdi-file-document"
						  Placeholder="Chọn dự án"
						  Items="ListDA.Select(x => new UiSelect.SelectItem(x.MaDuAn!, x.TenDuAn!))"
						  @bind-Value="selectedMaDuAn"
						  OnChange="OnDuAnChanged" />
			}
			<div class="col-search wapper-congtrinh container-form droplist-index">
				<div class="result-label-icon">
					<i class="mdi mdi-file-document"></i>
					<select id="MaBlock" class="form-control" multiple @ref="selectBlockRef">
						@foreach (var item in ListBlock)
						{
							<option value="@(item.MaBlock)">@item.TenBlock</option>
						}
					</select>
				</div>
			</div>
			@* <div class="ml-auto">
				<div class="container-filter-home">
					<div class="flex items-center gap-2">
						<ZoomSlider Min="10" Max="200" ZoomValue="@zoom" OnZoomChanged="HandleZoomChange" />
						<div class="icon-button" data-title="Toàn màn hình" data-position="left" @onclick="() => EnableFullScreen()">
							<i class="mdi mdi-arrow-expand"></i>
						</div>
					</div>
				</div>
			</div> *@
		</div>
		<div class="wrapper-status px-4 py-3">
			<div class="ml-auto">
				<div id="scrollWrapper" class="wraper-list-dot trangthai-canho trangthai-giohang">
