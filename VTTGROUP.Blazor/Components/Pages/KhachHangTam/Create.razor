    private async Task ApplyDoiTuongUI()
    {
        // Giới tính (required khi show)
        await JS.InvokeVoidAsync("UiHelper.toggle",
            "anHienDIVGioiTinh", Record.IsCheckGioiTinh,
            new[] { "GioiTinh" }, true);

        // Ngày cấp + Nơi cấp (required khi show – tùy bạn)
        await JS.InvokeVoidAsync("UiHelper.toggle",
            "anHienDIVNgayCap", Record.IsCheckNgayCapNoiCapIdCard,
            new[] { "NgayCap" }, true);
        await JS.InvokeVoidAsync("UiHelper.toggle",
            "anHienDIVNoiCap", Record.IsCheckNgayCapNoiCapIdCard,
            new[] { "NoiCap" }, true);

        // Người đại diện (DN mới show, thường không required)
        await JS.InvokeVoidAsync("UiHelper.toggle",
            "anHienDIVNguoiDaiDien", Record.IsHienThiNguoiDaiDien,
            new[] { "NguoiDaiDien", "SoDienThoaiNguoiDaiDien" }, false);

        // Ngày sinh
        await JS.InvokeVoidAsync("UiHelper.toggle",
            "anHienDIVNgaySinh", Record.IsHienThiNgaySinh,
            new[] { "NgaySinh" }, true);

        // Quốc tịch
        await JS.InvokeVoidAsync("UiHelper.toggle",
            "anHienDIVQuocTich", Record.IsHienThiQuocTich,
            new[] { "QuocTich" }, true);

        // Địa chỉ thường trú
        await JS.InvokeVoidAsync("UiHelper.toggle",
            "anHienDIVDiaChiThuongTru", Record.IsHienThiDiaChiThuongTru,
            new[] { "DiaChiThuongTru" }, false);
    }
