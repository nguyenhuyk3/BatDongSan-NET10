        // model.FileAnhs = Record.FileAnhs;
        var result = await KhachHangTamService.SaveKhachHangTamAsync(Record);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        if (result.Status)
        {
            Nav.NavigateTo($"/khachhangtam/edit/{result.Id}");
        }
    }

    public string GetSafeString(Dictionary<string, JsonElement> data, string key)
    {
        if (data.TryGetValue(key, out var element) && element.ValueKind != JsonValueKind.Null)
            return element.GetString() ?? string.Empty;
        return string.Empty;
    }

    public async Task MatTruocHandleFiles(List<UploadedFileModel> file)
    {
        Record.FileAnhs = file;
    }

    public async Task OnQuetThongTinAsync()
    {
        var file = Record.FileAnhs;
        if (file.Any())
        {
            IsQuetAnh = true;
            if (TypeIdCard == "CCCD")
            {
                try
                {
                    var result = await KhachHangTamService.DocThongTinCCCDAsync(_env.WebRootPath, file);
                    if (result.Status)
                    {
                        var thongTinAnh = (KhachHangTamModel)result.Data;
                        if (thongTinAnh != null)
                        {
                            Record.IdCard = thongTinAnh.IdCard;
                            Record.TenKhachHang = thongTinAnh.TenKhachHang;
                            Record.NgaySinh = thongTinAnh.NgaySinh;
                            Record.NgayCapIdCard = thongTinAnh.NgayCapIdCard;
                            Record.GioiTinh = thongTinAnh.GioiTinh;
                            Record.DiaChiThuongTru = thongTinAnh.DiaChiThuongTru;
                            if (thongTinAnh.GioiTinh != null)
                            {
                                await JS.InvokeVoidAsync("select2Helper.setValue", "GioiTinh", thongTinAnh.GioiTinh.ToString());
                            }
                            await JS.InvokeVoidAsync("select2Helper.setValue", "QuocTich", "VN");
                            await JS.InvokeVoidAsync("select2Helper.setValue", "MaLoaiIdCard", "CCCD");
                            await JS.InvokeVoidAsync("showToast", "Thông báo", "Quét thông tin thành công", true);
                            StateHasChanged();
                        }
                    }
                    else
                    {
                        await JS.InvokeVoidAsync("showToast", "Thông báo", "Không phát hiện mã QR hợp lệ", false);
                    }
                }
                finally
                {
                    IsQuetAnh = false;
                }

            }
            else
            {
                IsQuetAnh = false;
            }
        }
    }

