@page "/giohang"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.KeHoachBanHang
@using VTTGROUP.Blazor.Components.Pages.Paging
@using VTTGROUP.Domain.Model
@using VTTGROUP.Domain.Model.GioHang
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Helpers
@inject LoadingService Loading
@inject IBaseService BaseService
@inject CanHoService CanHoService
@inject GioHangService GioHangService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IWebHostEnvironment _env

<h1 class="legend-title">Danh sách giỏ hàng</h1>
<div class="rounded-xl bg-white p-4 space-y-3 wraper-content-page">
    <div class="relative z-50">
        <div class="flex flex-wrap items-end gap-3">
            <div class="flex items-center">
                <div class="result-label-icon">
                    <i class="mdi mdi-calendar-today"></i>
                    <DateRangePicker OnDateRangeChanged="OnDateRangeChanged" @ref="dateRangeRef" />
                </div>
            </div>
            <UiSelect Icon="mdi mdi-file-document"
                      Placeholder="Chọn dự án"
                      Items="ListDA.Select(x => new UiSelect.SelectItem(x.MaDuAn!, x.TenDuAn!))"
                      @bind-Value="selectedMaDuAn"
                      OnChange="OnDTKHChanged" />
            <div class="ml-auto flex items-center gap-2">
                <MoreFilterPopup OnTrangThaiChanged="OnTTDChanged"
                                 OnReset="ResetAllParam" @ref="morePopupRef" />
                <AddButton Text="Giỏ hàng" OnClick="Insert" />
            </div>
        </div>
    </div>
    <div class="flex items-center gap-3 my-3">
        <div class="w-[360px] md:w-[480px]">
            <InputSearch @bind-Value="search" OnSearch="Search" />
        </div>
        <div class="ml-auto h-11 flex items-center">
            <Pagination Page="@_page"
                        TotalPages="@totalPage"
                        OnPageChanged="HandlePageChanged"
                        OnPageSizeChanged="HandlePageSizeChanged" />
        </div>
    </div>
    <SelectedDeleteList Count="@SelectedCount" OnRemoveList="RemoveSelectedAsync" OnDeleteList="@DeleteSelectedAsync" />
    <div class="container-table-detail">
        <div class="container-table-fixed has-paging">
            <table class="tbl table-form table-detail treeTable" id="table-data">
                <thead>
                    <tr class="cls_custome_back">
                        <th style="width: 40px" class="text-center" rowspan="2">
                            <input type="checkbox" class="form-check-input" checked="@IsSelectAll"
                                   @onchange="(e) => OnCheckboxAllChanged(e)" />
                        </th>
                        <th style="width: 40px" class="text-center">
                            STT
                        </th>
                        <th style="width: 130px" class="text-center">
                            Hệ thống
                        </th>
                        <th style="width: 130px" class="text-center">
                            Mã số giỏ hàng
                        </th>
                        <th style="width: 220px" class="text-center">
                            Dự án
                        </th>
                        <th style="width: 150px" class="text-center">
                            Sàn giao dịch
                        </th>
                        <th style="width: 150px" class="text-center">
                            Đợt mở bán
                        </th>
                        <th style="width: 250px" class="text-center">
                            Nội dung
                        </th>
                        <th style="width: 150px" class="text-center">
                            Số lượng căn mở bán
                        </th>
                        <th style="width: 100px" class="text-center">
                            Loại giỏ hàng
                        </th>
                        <th style="width: 90px" class="text-center">
                            Trạng thái
                        </th>
                        <th style="width: 50px">
                            &nbsp;
                        </th>
                    </tr>
                </thead>
                <tbody class="content-table">
                    @if (sanPhams != null && sanPhams.Count > 0)
                    {
                        @foreach (var item in sanPhams)
                        {
                            <tr class="initialized">
                                <td class="text-center">
                                    @if (item.TrangThaiDuyet < 1 && item.NguoiLap == maNhanVienHT)
                                    {
                                        <input type="checkbox" class="form-check-input"
                                               checked="@item.IsSelected"
                                               @onchange="(e) => OnCheckboxChanged(item, e)" />
                                    }
                                </td>
                                <td style="text-align:center">
                                    <span>@item.STT</span>
                                </td>
                                <td>
                                    <div class="item-phieu" @onclick="() => OnEditRecord(item.MaPhieu.ToString())">@item.MaPhieu</div>
                                    <span class="created-label">@item.HoVaTen</span>
                                    <div class="created-date-label">@string.Format("{0:dd/MM/yyyy}", item.NgayLap)</div>
                                </td>
                                <td>
                                    <span> @item.MaSoGioHang</span>
                                </td>
                                <td>
                                    <span>@item.TenDuAn</span>
                                </td>
                                <td>
                                    <span>@item.TenSanGiaoDich</span>
                                </td>
                                <td>
                                    <div class="item-phieu"><span class="input-value" @onclick="() => OnViewPDG(item.MaPhieuDuyetGia)">@item.TenDotMoBan</span></div>
                                </td>
                                <td>
                                    <span>@item.NoiDung</span>
                                </td>
                                <td style="text-align:right">
                                    @string.Format("{0:N0}", item.TongSoCanTrongGio)
                                </td>
                                <td class="text-center">
                                    <div class="form-group d-flex align-items-center gap-2 justify-content-center">
                                        <label class="switch-toggle m-0">
                                            <input type="checkbox"
                                                   checked="@item.LoaiGioHang"
                                                   @onclick:preventDefault
                                                   @onclick="(e => ShowConfirmCapNhatLoaiGioHang(item, !(item.LoaiGioHang ?? false)))" />
                                            <span class="slider"></span>
                                        </label>
                                        <span style="font-weight: 600;" @onclick="() => ViewHistory(item.MaPhieu, 1)">
                                            @((item.LoaiGioHang ?? false) ? "Chung" : "Riêng")
                                        </span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="status-label" style="color: @(item.Mau)" @onclick="() => LichSuDuyetPhieu(maCongViec, item.MaPhieu)">
                                        @item.TenTrangThai
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (!item.IsDong)
                                    {
                                        if (item.TrangThaiDuyet < 1 && item.NguoiLap == maNhanVienHT)
                                        {
                                            <div class="d-flex justify-content-center align-items-center flex-column">
                                                <div class="icon-button" data-title="Cập nhật" data-position="left">
                                                    <a href="javascript:void()" @onclick="() => OnEditRecord(item.MaPhieu!)">
                                                        <span>
                                                            <i class="mdi mdi-pencil">
                                                            </i>
                                                        </span>
                                                    </a>
                                                </div>
                                                <div class="icon-button" data-title="Xóa" data-position="left">
                                                    <a href="javascript:void(0)" @onclick="() => ShowConfirmDelete(item.MaPhieu!)"><span><i class="mdi mdi-delete "></i></span></a>
                                                </div>
                                                <div class="icon-button" data-title="Cập nhật sàn" data-position="left">
                                                    <a href="javascript:void(0);" @onclick="() => CapNhatSan(item)">
                                                        <i class="bi bi-arrow-left-right text-success fs-5"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex justify-content-center align-items-center flex-column">
                                                <div class="icon-button" data-title="Cập nhật sàn" data-position="left">
                                                    <a href="javascript:void(0);" @onclick="() => CapNhatSan(item)">
                                                        <i class="bi bi-arrow-left-right text-success fs-5"></i>
                                                    </a>
                                                </div>
                                                <div class="icon-button" data-title="Lịch sử đổi sàn" data-position="left">
                                                    <a href="javascript:void(0);" @onclick="() => ViewHistory(item.MaPhieu, 2)">
                                                        <i class="mdi mdi-history text-primary fs-5"></i>
                                                    </a>
                                                </div>
                                            </div>
                                            @*   <div class="d-flex flex-column align-items-center justify-content-center gap-2">
                                                <div class="icon-button" data-title="Cập nhật sàn" data-position="left">
                                                    <a href="javascript:void(0);" @onclick="() => CapNhatSan(item)">
                                                        <i class="bi bi-arrow-left-right text-success fs-5"></i>
                                                    </a>
                                                </div>

                                                <div class="icon-button" data-title="Lịch sử đổi sàn" data-position="left">
                                                    <a href="javascript:void(0);" @onclick="() => ViewHistory(item.MaPhieu, 2)">
                                                        <i class="bi bi-clock-history text-primary fs-5"></i>
                                                    </a>
                                                </div>
                                            </div> *@
                                        }
                                    }
                                    else
                                    {
                                        @*   <span class="label-dadong" title="Giỏ hàng đã đóng">Đã đóng</span> *@
                                        <span class="status-label" style="color: #842D2D">
                                            Đã đóng
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            @if (sanPhams == null || !sanPhams.Any())
            {
                <div class="p-2">Không có dữ liệu</div>
            }
        </div>
    </div>
    <ConfirmDeleteModal ModalId="confirmDeleteModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa giỏ hàng này <strong>@selectedMaCongViec</strong> không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDelete">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>
    <ConfirmDeleteModal ModalId="confirmDeleteListModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa giỏ hàng này không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDeleteList">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>

    <ConfirmDeleteModal ModalId="confirmCapNhatLoaiGioHangModal"
                        Title="Xác nhận cập nhật loại giỏ hàng">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn cập nhật loại giỏ hàng này sang
                <strong>@(giaTriMoi ? "Giỏ hàng CHUNG" : "Giỏ hàng RIÊNG")</strong> không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="button button-primary" @onclick="ConfirmCapNhatLoaiGioHang">
                Cập nhật
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>
</div>
