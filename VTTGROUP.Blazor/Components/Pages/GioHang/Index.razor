<PopupLichSuDuyetPhieu @ref="guiDuyetModalRef" />
<PopupSanGiaoDich @ref="sanGGModalRef" OnSelected="OnSanGiaoDichSelected" />
<PopupLichSu @ref="lichSuModalRef" />
@code {
    private DotNetObjectReference<Index>? _dotNetRef;
    private List<DaDanhMucDuAn> ListDA = new();
    private List<HtTrangThaiDuyet> LisTTD = new();
    private string? selectedMaDuAn;
    private string? selectedMaCongViec;
    private bool isLoading = false;
    int _page = 1;
    int _pageSize = 10;
    int totalPage = 1;
    int totalCount;
    string? search;
    List<GioHangPagingDto> sanPhams = new();
    private CancellationTokenSource _cts = new();
    private string? tuNgay { get; set; } = DateTime.Now.AddMonths(-1).ToString("dd/MM/yyyy");
    private string? denNgay { get; set; } = DateTime.Now.ToString("dd/MM/yyyy");
    private string maCongViec = "GioHang";
    private PopupLichSuDuyetPhieu? guiDuyetModalRef;
    private PopupSanGiaoDich? sanGGModalRef;
    private string? selectedTrangThaiDuyet;
    private string? maNhanVienHT;
    private GioHangPagingDto? itemDangCapNhat;
    private bool giaTriMoi;
    private GioHangPagingDto? currentRowDangChonSGD;
    MoreFilterPopup morePopupRef;
    DateRangePicker dateRangeRef;
    int SelectedCount => sanPhams?.Count(x => x.IsSelected) ?? 0;
    private bool IsSelectAll = false;
    private PopupLichSu? lichSuModalRef;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync(maCongViec, VuViec.Xem.GetDescription());
            _dotNetRef = DotNetObjectReference.Create(this);
            ListDA = await CanHoService.GetByDuAnAsync();
            LisTTD = await BaseService.GetListTrangThaiDuyetAsync();
            maNhanVienHT = await BaseService.MaNhanVienHienTai();
            await LoadData();
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaDuAn", "Chọn dự án", true);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "TrangThaiDuyet", "Chọn trạng thái", true);
            StateHasChanged();
        }
    }

    private async Task ShowConfirmDelete(string maKeHoach)
    {
        var coQuyen = await BaseService.KiemTraQuyenVuViec(maCongViec, VuViec.Xoa.GetDescription());
        if (coQuyen == false)
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Bạn không có quyền xóa. Xin vui lòng liên hệ quản trị", false);
            return;
        }

        selectedMaCongViec = maKeHoach;
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteModal");
    }

    private async Task ConfirmDelete()
    {
        Loading.Show();
        try
        {
            if (selectedMaCongViec == null || string.IsNullOrEmpty(selectedMaCongViec))
            {
                return;
            }
            var result = await GioHangService.DeleteRecordAsync(selectedMaCongViec);
            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
            await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteModal");
            await LoadData();
            selectedMaCongViec = string.Empty;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", ex.Message, false);
        }
        finally
        {
            Loading.Hide();
        }
    }

    private async Task ConfirmDeleteList()
    {

        Loading.Show();
        try
        {
            var selected = sanPhams.Where(d => d.IsSelected).ToList();
            if (selected.Count == 0) return;
            var result = await GioHangService.DeleteListAsync(selected);
            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
            await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteListModal");
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", ex.Message, false);
        }
        finally
        {
            Loading.Hide();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;

        try
        {
            var (data, total) = await GioHangService.GetPagingAsync(selectedMaDuAn, _page, _pageSize, search, tuNgay, denNgay, selectedTrangThaiDuyet);
            sanPhams = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandlePageChanged(int newPage)
    {
        _page = newPage;
        await LoadData();
    }

    private async Task HandlePageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        _page = 1;
        await LoadData(); // Gọi lại API với PageSize mới
    }

    private async Task OnEditRecord(string maPhieuKH)
    {
        Nav.NavigateTo($"/giohang/edit/{maPhieuKH}");
    }
    private void Insert()
    {
        Nav.NavigateTo("/giohang/create");
        return;
    }

    async Task Search()
    {
        _page = 1;
        await LoadData();
    }

    private async Task OnDTKHChanged(string? duAn)
    {
        if (isLoading) return;
        selectedMaDuAn = string.IsNullOrWhiteSpace(duAn) ? null : duAn;
        _page = 1;
        await LoadData();
    }

    private async Task OnTTDChanged(string trangThai)
    {
        var newTTD = trangThai;
        if (newTTD == selectedTrangThaiDuyet || isLoading)
        {
            return;
        }
        selectedTrangThaiDuyet = newTTD;
        _page = 1;
        await LoadData();
    }

    private async Task OnDateRangeChanged((string? Start, string? End) range)
    {
        tuNgay = range.Start;
        denNgay = range.End;
        await LoadData();
    }

    private async Task LichSuDuyetPhieu(string MaCongViec, string MaPhieu)
    {
        await guiDuyetModalRef?.ShowLSDP(MaCongViec, MaPhieu);
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    private async Task OnViewPDG(string maPhieuDuyetGia)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/phieuduyetgia/edit/" + maPhieuDuyetGia);
    }

    private async Task ShowConfirmCapNhatLoaiGioHang(GioHangPagingDto item, bool newValue)
    {
        itemDangCapNhat = item;
        giaTriMoi = newValue;
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmCapNhatLoaiGioHangModal");
    }

    private async Task ConfirmCapNhatLoaiGioHang()
    {
        if (itemDangCapNhat == null)
            return;
        var response = await GioHangService.UpdateLoaiGioHangAsync(itemDangCapNhat.MaPhieu, giaTriMoi, maNhanVienHT);
        if (response == "TC")
        {
            itemDangCapNhat.LoaiGioHang = giaTriMoi;
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Cập nhật loại giỏ hàng thành công", true);
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Cập nhật loại giỏ hàng thất bại", false);
        }
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmCapNhatLoaiGioHangModal");
        itemDangCapNhat = null;
        StateHasChanged(); // ✅ Cập nhật lại UI
    }

    private async Task CapNhatSan(GioHangPagingDto item)
    {
        currentRowDangChonSGD = item;
        await sanGGModalRef?.ShowSGG(item);
    }

    private async Task OnSanGiaoDichSelected(DmSanGiaoDich item)
    {
        if (currentRowDangChonSGD != null)
        {
            currentRowDangChonSGD.MaSanGiaoDich = item.MaSanGiaoDich;
            currentRowDangChonSGD.TenSanGiaoDich = item.TenSanGiaoDich;
            var response = await GioHangService.UpdateSanGiaoDichAsync(currentRowDangChonSGD.MaPhieu, item.MaSanGiaoDich, maNhanVienHT);
            if (response == "TC")
            {
                await JS.InvokeVoidAsync("showToast", "Thông báo", "Cập nhật sàn giao dịch thành công", true);
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", "Thông báo", "Cập nhật sàn giao dịch thất bại", false);
            }
        }
        currentRowDangChonSGD = null;
        StateHasChanged();
        //await popupSGD.Hide(); // đóng modal nếu có
    }

    private async Task ResetAllParam()
    {
        _page = 1;
        _pageSize = 10;
        search = null;
        selectedTrangThaiDuyet = null;
        selectedMaDuAn = null;
        tuNgay = null;
        denNgay = null;
        await LoadData();
        await dateRangeRef.ResetAsync();
        await morePopupRef.RestAllMore();
        await JS.InvokeVoidAsync("select2Helper.resetMultipleSelects", new[] { "MaDuAn", "TrangThaiDuyet" });
        StateHasChanged();
    }

    private async Task ResetMore()
    {
        _page = 1;
        _pageSize = 10;
        await LoadData();
    }

    private async Task RemoveSelectedAsync()
    {
        IsSelectAll = false;
        foreach (var item in sanPhams)
        {
            item.IsSelected = IsSelectAll;
        }
    }

    private async Task DeleteSelectedAsync()
    {
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteListModal");
    }

    private async Task OnCheckboxAllChanged(ChangeEventArgs e)
    {
        IsSelectAll = (bool)e.Value;
        foreach (var item in sanPhams)
        {
            if (item.TrangThaiDuyet < 1 && item.NguoiLap == maNhanVienHT)
            {
                item.IsSelected = IsSelectAll;
            }
        }
    }

    private async Task OnCheckboxChanged(GioHangPagingDto item, ChangeEventArgs e)
    {
        item.IsSelected = (bool)e.Value;
        IsSelectAll = sanPhams.All(x => x.IsSelected);
    }

    async Task ViewHistory(string maPhieu, int loaiLS)
    {
        await lichSuModalRef?.Show(maPhieu, loaiLS);
    }
}
