@page "/truc"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.Paging
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model.ViewTruc
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@inject ViewTrucService ViewTrucService
@inject IBaseService BaseService
@inject LoadingService Loading
@inject CanHoService CanHoService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IWebHostEnvironment _env

<h1 class="legend-title">DANH SÁCH TRỤC</h1>
<div class="rounded-xl bg-white p-4 space-y-3 wraper-content-page">
    <div class="relative z-50">
        <div class="flex flex-wrap items-end gap-3">
            <UiSelect Icon="mdi mdi-office-building-outline"
                      Placeholder="Chọn dự án"
                      Items="ListDA.Select(x => new UiSelect.SelectItem(x.MaDuAn!, x.TenDuAn!))"
                      @bind-Value="selectedMaDuAn"
                      OnChange="OnDuAnChanged" />

            <UiSelect Icon="mdi mdi-view-grid-outline"
                      Placeholder="Chọn block"
                      Disabled="@(string.IsNullOrEmpty(selectedMaDuAn))"
                      Items="(ListBlock ?? new()).Select(x => new UiSelect.SelectItem(x.MaBlock!, x.TenBlock!))"
                      @bind-Value="selectedBlock"
                      OnChange="OnBlockChanged" />
            <div class="ml-auto flex items-center gap-2">
                <AddButton Text="Thêm trục" OnClick="Insert" />
                <button style="
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #EDAD0F;
        padding: 0 12px;
        border-radius: 8px;
        height: 40px;
        background-color: #FDF7E7;
        color: #EDAD0F;
        font-weight: 600;
        font-size: 16px;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
    "
                        title="Import"
                        @onclick="Import">
                    <i class="mdi mdi-cloud-upload"
                       style="
           color: #EDAD0F;
           font-size: 16px;
       ">
                    </i>
                    <span style="
           color: #EDAD0F;
           font-weight: 600;
           font-size: 16px;
           font-family: 'Inter', sans-serif;
       ">
                        Import
                    </span>
                </button>
            </div>
        </div>
    </div>
    <div class="flex items-center gap-3">
        <div class="w-[360px] md:w-[480px]">
            <InputSearch @bind-Value="search" OnSearch="Search" />
        </div>
        <div class="ml-auto h-11 flex items-center">
            <Pagination Page="@_page"
                        TotalPages="@totalPage"
                        TotalItems="@totalCount"
                        OnPageChanged="HandlePageChanged"
                        OnPageSizeChanged="HandlePageSizeChanged" />
        </div>
    </div>
    <SelectedDeleteList Count="@SelectedCount" OnRemoveList="RemoveSelectedAsync" OnDeleteList="@DeleteSelectedAsync" />
    <div class="container-table-detail">
        <div class="container-table-fixed has-paging">
            <table class="tbl table-form table-detail treeTable" id="table-data">
                <thead>
                    <tr class="cls_custome_back">
                        <th style="width: 40px" class="text-center" rowspan="2">
                            <input type="checkbox" class="form-check-input" checked="@IsSelectAll"
                                   @onchange="(e) => OnCheckboxAllChanged(e)" />
                        </th>
                        <th style="width: 40px" class="text-center">
                            STT
                        </th>
                        <th style="width: 120px" class="text-center">Mã trục</th>
                        <th style="width: 150px" class="text-center">Tên trục</th>
                        <th style="width: 180px" class="text-center">Tên dự án</th>
                        <th style="width: 150px" class="text-center">Tên block</th>
                        <th style="width: 120px" class="text-center">Mặt khối</th>
                        <th style="width: 120px" class="text-center">View</th>
                        <th style="width: 120px" class="text-center">Góc</th>
                        <th style="width: 120px" class="text-center">Vị trí</th>
                        <th style="width: 140px; text-align:center">Thứ tự hiển thị</th>
                        <th style="width: 120px;" class="text-center">Hệ số</th>
                        <th style="width: 90px">&nbsp;</th>
                    </tr>
                </thead>

                <tbody class="content-table">
                    @if (ChiTietView != null && ChiTietView.Any())
                    {
                        foreach (var item in ChiTietView)
                        {
                            <tr class="initialized">
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input"
                                           checked="@item.IsSelected"
                                           @onchange="(e) => OnCheckboxChanged(item, e)" />
                                </td>
                                <td style="text-align:center">
                                    <span>@item.STT</span>
                                </td>
                                <td>
                                    <span>
                                        @item.MaTruc
                                    </span>
                                </td>
                                <td>
                                    <span>@item.TenTruc</span>
                                </td>
                                <td>
                                    <span>@item.TenDuAn</span>
                                </td>
                                <td>
                                    <span>@item.TenBlock</span>
                                </td>
                                <td>
                                    <span>@item.TenMatKhoi</span>
                                </td>
                                <td>
                                    <span>@item.TenView</span>
                                </td>
                                <td>
                                    <span>@item.TenLoaiGoc</span>
                                </td>
                                <td>
                                    <span>@item.TenViTri</span>
                                </td>
                                <td style="text-align:center">
                                    <span>@item.ThuTuHienThi</span>
                                </td>
                                <td style="text-align:right">
                                    @string.Format("{0:#,#0.####}", item.HeSoTruc)
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center flex-column">
                                        <div class="icon-button" data-title="Cập nhật" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => OnEditRecord(item.MaTruc!)">
                                                <span><i class="mdi mdi-pencil"></i></span>
                                            </a>
                                        </div>
                                        <div class="icon-button" data-title="Xóa" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => ShowConfirmDelete(item.MaTruc!)">
                                                <span><i class="mdi mdi-delete"></i></span>
                                            </a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            @if (ChiTietView == null || !ChiTietView.Any())
            {
                <div class="p-2">Không có dữ liệu</div>
            }
        </div>
    </div>
    <ConfirmDeleteModal ModalId="confirmDeleteModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa trục <strong>@selectedMaCongViec</strong> không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDelete">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>
    <ConfirmDeleteModal ModalId="confirmDeleteListModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa danh sách trục này không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDeleteList">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>
    <ImportFileModalVT DuAnOptions="@ListDA" @ref="importFileModalRef" OnUploaded="HandleFileUpload" />
</div>

@code {
    private DotNetObjectReference<Index>? _dotNetRef;
    private List<ViewTrucPagingDto> ChiTietView = new();
    private string? selectedMaCongViec;
    private List<DaDanhMucDuAn> ListDA = new();
    private List<DaDanhMucBlock> ListBlock = new();
    private string? selectedMaDuAn;
    private string? selectedBlock;
    private bool isLoading = false;
    string? search;
    int _page = 1;
    int _pageSize = 10;
    int totalPage = 1;
    int totalCount;
    int SelectedCount => ChiTietView?.Count(x => x.IsSelected) ?? 0;
    private ImportFileModalVT? importFileModalRef;
    private bool IsSelectAll = false;

    // Chặn re-init JS
    private bool _jsInited;

    /* --------- 1) LOAD DỮ LIỆU Ở ĐÂY --------- */
    protected override async Task OnInitializedAsync()
    {
        await BaseService.CheckPermissionAsync("TraCanHoVeKho", VuViec.Xem.GetDescription());
        ListDA = await CanHoService.GetByDuAnAsync();
        await LoadViewTrucData();

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_jsInited)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaDuAn", "Chọn dự án", true);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaBlock", "Chọn block", true);
            _jsInited = true;
        }
    }

    private async Task ShowConfirmDelete(string maDuAn)
    {
        selectedMaCongViec = maDuAn;
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteModal");
    }

    private async Task ConfirmDelete()
    {
        if (selectedMaCongViec == null || string.IsNullOrEmpty(selectedMaCongViec))
        {
            return;
        }
        var result = await ViewTrucService.DeleteViewAsync(selectedMaCongViec);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteModal");
        await LoadViewTrucData();
        selectedMaCongViec = string.Empty;
        StateHasChanged();
    }

    private async Task ConfirmDeleteList()
    {
        Loading.Show();
        try
        {
            var selected = ChiTietView.Where(d => d.IsSelected).ToList();
            if (selected.Count == 0) return;

            var result = await ViewTrucService.DeleteListAsync(selected);
            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
            await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteListModal");
            await LoadViewTrucData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", ex.Message, false);
        }
        finally
        {
            Loading.Hide();
        }
    }

    private async Task OnEditRecord(string maTruc)
    {
        Nav.NavigateTo($"/truc/edit/{maTruc}");
    }

    private void Insert()
    {
        Nav.NavigateTo("/truc/create");
        return;
    }

    private async Task OnDuAnChanged(string? maDuAn)
    {
        if (isLoading) return;

        selectedMaDuAn = string.IsNullOrWhiteSpace(maDuAn) ? null : maDuAn;

        ListBlock = await ViewTrucService.GetByBlockTheoDuAnAsync(selectedMaDuAn);
        selectedBlock = null;
        await InvokeAsync(StateHasChanged); // đảm bảo UI cập nhật danh sách block

        _page = 1;
        await LoadViewTrucData();
    }

    private async Task OnBlockChanged(string? maBlock)
    {
        if (isLoading) return;

        selectedBlock = string.IsNullOrWhiteSpace(maBlock) ? null : maBlock;

        _page = 1;
        await LoadViewTrucData();
    }


    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    private async Task Search(string? keyword)
    {
        search = keyword;
        _page = 1;
        await LoadViewTrucData();
    }

    private async Task LoadViewTrucData()
    {
        isLoading = true;
        try
        {
            var (data, total) = await ViewTrucService.GetPagingAsync(selectedMaDuAn, selectedBlock, _page, _pageSize, search);
            ChiTietView = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandlePageChanged(int newPage)
    {
        _page = newPage;
        await LoadViewTrucData();
    }

    private async Task HandlePageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        _page = 1;
        await LoadViewTrucData();
    }

    private async Task RemoveSelectedAsync()
    {
        IsSelectAll = false;
        foreach (var item in ChiTietView)
            item.IsSelected = false;
    }

    private async Task DeleteSelectedAsync()
    {
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteListModal");
    }

    private async Task OnCheckboxAllChanged(ChangeEventArgs e)
    {
        IsSelectAll = (bool)e.Value;
        foreach (var item in ChiTietView)
        {
            item.IsSelected = IsSelectAll;
        }
    }

    private async Task OnCheckboxChanged(ViewTrucPagingDto item, ChangeEventArgs e)
    {
        item.IsSelected = (bool)e.Value;
        IsSelectAll = ChiTietView.All(x => x.IsSelected);
    }

    private async Task HandleFileUpload()
    {
        await LoadViewTrucData();
    }

    private async Task Import()
    {
        await importFileModalRef?.ShowFileModal(selectedMaDuAn);
    }
}
