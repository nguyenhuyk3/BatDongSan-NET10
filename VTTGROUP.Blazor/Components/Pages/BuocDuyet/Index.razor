@page "/buocduyet"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.Paging
@using VTTGROUP.Domain.Model
@using VTTGROUP.Domain.Model.QuyTrinhDuyet
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Helpers
@inject IBaseService BaseService
@inject BuocDuyetService BuocDuyetService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IWebHostEnvironment _env
<h1 class="legend-title">Bước duyệt</h1>
<div class="rounded-xl bg-white p-4 space-y-3 wraper-content-page">
    <div class="relative z-50">
        <div class="flex flex-wrap items-end gap-3">
            <div class="ml-auto flex items-center gap-2">
                <AddButton Text="Bước duyệt" OnClick="Insert" />
            </div>
        </div>
    </div>
    <div class="flex items-center gap-3 my-3">
        <div class="w-[360px] md:w-[480px]">
            <InputSearch @bind-Value="search" OnSearch="Search" />
        </div>
        <div class="ml-auto h-11 flex items-center">
            <Pagination Page="@_page"
                        TotalPages="@totalPage"
                        TotalItems="@totalCount"
                        OnPageChanged="HandlePageChanged"
                        OnPageSizeChanged="HandlePageSizeChanged" />
        </div>
    </div>
    <div class="container-table-detail">
        <div class="container-table-fixed has-paging">
            <table class="tbl table-form table-detail treeTable" id="table-data">
                <thead>
                    <tr class="cls_custome_back">
                        <th style="width: 50px" class="text-center">
                            STT
                        </th>
                        <th style="width: 130px" class="text-center">
                            Mã bước duyệt
                        </th>
                        <th style="width: 130px" class="text-center">
                            Tên bước duyệt
                        </th>
                        <th style="width: 130px" class="text-center">
                            Tên hiển thị
                        </th>
                        <th style="width: 90px">
                            &nbsp;
                        </th>
                    </tr>
                </thead>
                <tbody class="content-table">
                    @if (listKH != null && listKH.Count > 0)
                    {
                        @foreach (var item in listKH)
                        {
                            <tr class="initialized">
                                <td style="text-align:center">
                                    <span>@item.STT</span>
                                </td>
                                <td>@item.MaBuocDuyet</td>
                                <td>
                                    <span>@item.TenBuocDuyet</span>
                                </td>
                                <td>
                                    <span>@item.TenHienThi</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center">
                                        <div class="icon-button" data-title="Cập nhật" data-position="left">
                                            <a href="javascript:void()" @onclick="() => OnEditRecord(item!)">
                                                <span>
                                                    <i class="mdi mdi-pencil">
                                                    </i>
                                                </span>
                                            </a>
                                        </div>
                                        <div class="icon-button" data-title="Xóa" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => ShowConfirmDelete(item)"><span><i class="mdi mdi-delete "></i></span></a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            @if (listKH == null || !listKH.Any())
            {
                <div class="p-2">Không có dữ liệu</div>
            }
        </div>
    </div>
    <ConfirmDeleteModal ModalId="confirmDeleteModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa bước duyệt này <strong>@selectedBuocDuyet</strong> không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDelete">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>
</div>
<PopupBuocDuyet @ref="buocDuyetModalRef" OnSaved="@OnSaved" />
@code {
    [Parameter]
    public EventCallback<BuocDuyetPagingDto?> OnSelected { get; set; }
    private PopupBuocDuyet? buocDuyetModalRef;
    private string? selectedMaDuyet;
    private string? selectedBuocDuyet;
    private bool isLoading = false;
    int _page = 1;
    int _pageSize = 10;
    int totalPage = 1;
    int totalCount;
    string? search;
    List<BuocDuyetPagingDto> listKH = new();
    BuocDuyetModel? buocDuyet = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync("BuocDuyet", VuViec.Xem.GetDescription());
            await JS.InvokeVoidAsync("modalHelper.makeAllDraggable");
        }
    }
    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var (data, total) = await BuocDuyetService.GetPagingBuocDuyetAsync(_page, _pageSize, search);
            listKH = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }
    private async Task HandlePageChanged(int newPage)
    {
        _page = newPage;
        await LoadData();
    }

    private async Task HandlePageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        _page = 1;
        await LoadData(); // Gọi lại API với PageSize mới
    }

    private async Task Search(string? keyword)
    {
        search = keyword;
        _page = 1;
        await LoadData();
    }
    private async Task ShowConfirmDelete(BuocDuyetPagingDto item)
    {
        var coQuyen = await BaseService.KiemTraQuyenVuViec("BuocDuyet", VuViec.Xoa.GetDescription());
        if (coQuyen == false)
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Bạn không có quyền xóa. Xin vui lòng liên hệ quản trị", false);
            return;
        }
        else
        {
            selectedMaDuyet = item.MaBuocDuyet;
            selectedBuocDuyet = item.TenBuocDuyet;
            await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteModal");
        }
    }

    private async Task ConfirmDelete()
    {
        if (selectedMaDuyet == null)
        {
            return;
        }
        var result = await BuocDuyetService.DeletePhieuAsync(selectedMaDuyet);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteModal");
        await LoadData();
        selectedMaDuyet = string.Empty;
        StateHasChanged();
    }

    private async Task OnEditRecord(BuocDuyetPagingDto item)
    {
        var coQuyen = await BaseService.KiemTraQuyenVuViec("BuocDuyet", VuViec.CapNhat.GetDescription());
        if (coQuyen == false)
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Bạn không có quyền cập nhật. Xin vui lòng liên hệ quản trị", false);
            return;
        }
        else
        {
            buocDuyet = new BuocDuyetModel
            {
                MaBuocDuyet = item.MaBuocDuyet,
                TenBuocDuyet = item.TenBuocDuyet,
                TenHienThi = item.TenHienThi,
                GhiChu = item.GhiChu,
                IsCreate = false
            };
            await buocDuyetModalRef.ShowPopup(buocDuyet);
        }
    }
    private async Task Insert()
    {
        var coQuyen = await BaseService.KiemTraQuyenVuViec("BuocDuyet", VuViec.Them.GetDescription());
        if (coQuyen == false)
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Bạn không có quyền thêm. Xin vui lòng liên hệ quản trị", false);
            return;
        }
        else
        {
            buocDuyet = new BuocDuyetModel();
            buocDuyet.IsCreate = true;
            await buocDuyetModalRef.ShowPopup(buocDuyet);
        }
    }
    public async Task OnSaved()
    {
        await LoadData();
        StateHasChanged();
    }
}