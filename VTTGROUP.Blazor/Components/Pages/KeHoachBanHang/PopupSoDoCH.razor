<div class="modal fade full" id="PopupSoDoCHModal" tabindex="-1" aria-hidden="true" @onclick="() => showButton = false">
	<div class="modal-dialog modal-fullscreen modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Danh sách căn hộ <span class="ms-1">@TenDotMoBan</span></h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng" @onclick="ClosePopupCH"></button>
			</div>
			<div class="modal-body modal-wraper" id="modal-body">
				<div class="container-search-home">
					<div class="search-row" style="margin-bottom: 15px;">
						<div class="col-search wapper-congtrinh container-form">
							<div class="result-label-icon">
								<i class="mdi mdi-file-document"></i>
								<select name="MaBlock" id="MaBlock" multiple class="form-control" @ref="refBlock">
									@foreach (var item in ListBlock)
									{
										<option value="@(item.MaBlock)" selected="@SelectedBlocks.Contains(item.MaBlock)">
											@item.TenBlock
										</option>
									}
								</select>
							</div>
						</div>
						<ZoomSlider Min="10" Max="200" ZoomValue="@zoom" OnZoomChanged="HandleZoomChange" />
						@* <div class="col-search wapper-congtrinh container-form">
							<div class="result-label-icon">
								<i class="mdi mdi-file-document"></i>
								<select name="MaTang" id="MaTang" multiple class="form-control" @ref="refTang">
									@foreach (var item in ListTang)
									{
										<option value="@(item.MaTang)" selected="@SelectedTangs.Contains(item.MaTang)">
											[@item.MaTang]-@item.TenTang
										</option>
									}
								</select>
							</div>
						</div>
						<div class="col-search wapper-congtrinh container-form">
							<div class="result-label-icon">
								<i class="mdi mdi-file-document"></i>
								<select name="MaTruc" id="MaTruc" multiple class="form-control" @ref="refTruc">
									@foreach (var item in ListTruc)
									{
										<option value="@(item.MaTruc)" selected="@SelectedTrucs.Contains(item.MaTruc)">
											[@item.MaTruc]-@item.TenTruc
										</option>
									}
								</select>
							</div>
						</div> *@
					</div>
				</div>
				<div class="container-table-detail">
					<div class="view-canho view-canho-popup" id="container-view-canho">
						@if (DanhSachCanHo != null && DanhSachCanHo.Any())
						{
							bool coCanHoThuc = DanhSachCanHo.Any(x => !string.IsNullOrWhiteSpace(x.TenTang) && !string.IsNullOrWhiteSpace(x.TenSanPham) && !string.IsNullOrWhiteSpace(x.TenTruc));
							if (coCanHoThuc)
							{
								<table class="floor-table">
									<thead>
										<tr>
											<th class="floor-label-header">Tầng</th>
											@for (int i = 0; i < blocks.Count; i++)
											{
												var block = blocks[i];
												var fullMat = IsFullMat(block);
												var isLastBlock = i == blocks.Count - 1;
												var totalCol = MatCanHo.Sum(mat => GetTrucs(block, mat.MaView).Count) + (MatCanHo.Count - 1) - (!fullMat ? 1 : 0);
												<th colspan="@totalCol" class="border text-center font-bold uppercase p-2 block-label" @onclick="() => OnSeLectedBlock(block)">Block @block</th>

												if (!isLastBlock)
												{
													<th class="bg-white space-block"></th>
												}
											}
										</tr>
									</thead>

									<tbody>
										@foreach (var tang in TangList)
										{
											<tr>
												<td class="floor-label -tang-@tang" @onclick="() => OnSeLectedTang(tang)">
													@tang
												</td>
												@for (int i = 0; i < blocks.Count; i++)
												{
													var block = blocks[i];
													var isLastBlock = i == blocks.Count - 1;
													var fullMat = IsFullMat(block);
													foreach (var mat in MatCanHo)
													{
														var trucList = GetTrucs(block, mat.MaView);
														foreach (var truc in trucList)
														{
															var canHo = GetCanHo(block, tang, truc.TenTruc, mat.MaView);
															<td class="border text-center">
																@if (canHo != null)
																{
																	<div class="apartment default" @onclick="() => OnSeLectedCanHo(canHo)" style="background:@(canHo.MaMauDot)!important" id-block="" id-truc="truc-@(canHo.MaTruc)" id-tang="tang-@(canHo.TenTang)">
																		@canHo.TenSanPham
																		@if (canHo.IsKhongChonLai == true)
																		{
																			<div class="icon-not-choose">
																				<i class="bi bi-lock-fill"></i>
																			</div>
																		}
																	</div>
																}
																else
																{
																	<div class="no-default"></div>
																}
															</td>
														}

														if (mat != MatCanHo.Last() && fullMat)
														{
															<td class="bg-white space-truc"></td>
														}
													}

													if (!isLastBlock)
													{
														<td class="bg-white space-block"></td>
													}
												}
											</tr>
										}
									</tbody>

									<!-- 4. Footer: TRỤC LẦN NỮA -->
									<tfoot>
										<tr>
											<td class="floor-label-footer"></td>
											@for (int i = 0; i < blocks.Count; i++)
											{
												var block = blocks[i];
												var isLastBlock = i == blocks.Count - 1;
												var fullMat = IsFullMat(block);
												foreach (var mat in MatCanHo)
												{
													var trucList = GetTrucs(block, mat.MaView);
													foreach (var truc in trucList)
													{
														<td class="bg-yellow-400 border text-center text-sm font-semibold text-gray-700 p-2 label-truc -truc-@(truc.MaTruc)"
															@onclick="() => OnSeLectedTruc(block, truc, mat.MaView)">
															@truc.TenTruc
														</td>
													}

													if (mat != MatCanHo.Last() && fullMat)
													{
														<td class="bg-white space-truc"></td>
													}
												}

												if (!isLastBlock)
												{
													<td class="bg-white space-block"></td>
												}
											}
										</tr>
										<tr>
											<td class="floor-label-footer"></td>
											@for (int i = 0; i < blocks.Count; i++)
											{
												var block = blocks[i];
												var isLastBlock = i == blocks.Count - 1;

												var fullMat = IsFullMat(block);
												foreach (var mat in MatCanHo)
												{
													var trucList = GetTrucs(block, mat.MaView);
													if (trucList.Any())
													{
														<td colspan="@trucList.Count" class="p-2 bg-white text-center border font-semibold label-truc"
															@onclick="() => OnSeLectedMat(block, mat.MaView)">
															@mat.TenView
														</td>
													}
													if (mat != MatCanHo.Last() && fullMat)
													{
														<td class=" bg-white space-truc"></td>
													}
												}

												if (!isLastBlock)
												{
													<td class="bg-white space-block"></td>
												}
											}
										</tr>
									</tfoot>
								</table>
							}
							else
							{
								<div class="flex justify-center items-center relative wraper-no-apartment">
									<img src="assets/images/no-department.png" alt="Chưa có sơ đồ căn hộ"
										 class="max-w-full max-h-full object-contain" />
								</div>
							}
						}
						else
						{
							<div class="flex justify-center items-center relative wraper-no-apartment">
								<img src="assets/images/no-department.png" alt="Chưa có sơ đồ căn hộ"
									 class="max-w-full max-h-full object-contain" />
							</div>
						}
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<div id="scrollWrapper" class="wraper-list-dot">
