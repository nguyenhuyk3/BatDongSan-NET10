		var canHoAdds = GroupByBlock[block].Where(x => x.MaTruc?.Trim() == truc?.MaTruc.Trim() &&
		x.MaView?.Trim() == mat?.Trim() && string.IsNullOrEmpty(x.MaDotMoBan)).ToList();

		if (canHoAdds.Any())
		{
			foreach (var ch in canHoAdds)
			{
				if (ch.IsKhongChonLai == false)
				{
					var newSanPham = new SanPhamPopupPaginModel
						{
							MaSanPham = ch.MaSanPham,
							HeSoTuTinh = ch.HeSoTuTinh,
							DienTichTimTuong = ch.DienTichCanHo
