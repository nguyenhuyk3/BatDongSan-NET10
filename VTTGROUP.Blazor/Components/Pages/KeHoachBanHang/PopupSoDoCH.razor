	{
		var listMaCanHo = new List<SanPhamPopupPaginModel>();
		var canHos = GroupByBlock[block].Where(x => x.MaView?.Trim() == mat?.Trim() && string.IsNullOrEmpty(x.MaDotMoBan)).ToList();
		if (canHos.Any())
