	private void ShowContextMenu(MouseEventArgs e, string type, object data)
	{
		menuX = e.ClientX;
		menuY = e.ClientY;
		actionType = type;
		showButton = true;
		actionData = data;
	}
	private void OnActionClick()
	{
		showButton = false;
		switch (actionType)
		{
			case "Tang":
				var tang = (string)actionData!;
				var canHos = DanhSachCanHo.Where(x => x.TenTang?.Trim() == tang.Trim() && x.MaDotMoBan == MaDotMoBan).ToList();
				RemoveUncheck(canHos);
				break;

			case "Truc":
				var (block, truc, mat) = ((string, TrucSoDoModel, string))actionData!;
				var canHoTrucs = GroupByBlock[block].Where(x => x.MaTruc?.Trim() == truc?.MaTruc.Trim() &&
				x.MaView?.Trim() == mat?.Trim() && x.MaDotMoBan == MaDotMoBan).ToList();
				RemoveUncheck(canHoTrucs);
				break;

			case "ViewMat":
				var (b, m) = ((string, string))actionData!;
				var canHoMats = GroupByBlock[b].Where(x => x.MaView?.Trim() == m?.Trim() && x.MaDotMoBan == MaDotMoBan).ToList();
				RemoveUncheck(canHoMats);
				break;
		}
	}

	private async Task RemoveUncheck(List<SoDoCanHoModel> canHos)
	{
		var listMaCanHo = new List<SanPhamPopupPaginModel>();
		foreach (var ch in canHos)
		{
			if (ch.IsKhongChonLai == false && (ch.MaDotMoBan == MaDotMoBan))
			{
				var sanPham = new SanPhamPopupPaginModel
					{
						MaSanPham = ch.MaSanPham,
						HeSoTuTinh = ch.HeSoTuTinh,
						DienTichTimTuong = ch.DienTichCanHo
					};
				listMaCanHo.Add(sanPham);
			}
		}

		if (listMaCanHo.Any())
		{
			var result = await KeHoachBanHangService.RemoveCanHoCuaKeHoach(MaPhieuKH, MaDotMoBan, listMaCanHo);
			if (result.Status)
			{
				await LoadDanhSachCanHoData();
				//await OnReloadCanHo.InvokeAsync();
			}
			StateHasChanged();
		}

	}

	private void HandleZoomChange(int value)
	{
		zoom = value;
		StateHasChanged();
	}

