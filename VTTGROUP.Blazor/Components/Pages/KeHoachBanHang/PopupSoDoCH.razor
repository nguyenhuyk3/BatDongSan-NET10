					var newSanPham = new SanPhamPopupPaginModel
						{
							MaSanPham = ch.MaSanPham,
							HeSoTuTinh = ch.HeSoTuTinh,
							DienTichTimTuong = ch.DienTichCanHo
						};
					listMaCanHo.Add(newSanPham);
				}
			}
			if (listMaCanHo.Any())
			{
				hasChangeData = true;

				var result = await KeHoachBanHangService.ThemCanHoVaoKeHoach(MaPhieuKH, MaDotMoBan, listMaCanHo, true);
				if (result.Status)
				{
					await LoadDanhSachCanHoData();
					//await OnReloadCanHo.InvokeAsync();
				}
				StateHasChanged();
			}
		}
		else
		{
			var canHoRemoves = GroupByBlock[block].Where(x => x.MaView?.Trim() == mat?.Trim() && x.MaDotMoBan == MaDotMoBan).ToList();
			foreach (var ch in canHoRemoves)
			{
				if (ch.IsKhongChonLai == false)
				{
					var newSanPham = new SanPhamPopupPaginModel
						{
							MaSanPham = ch.MaSanPham,
							HeSoTuTinh = ch.HeSoTuTinh,
							DienTichTimTuong = ch.DienTichCanHo
						};
					listMaCanHo.Add(newSanPham);
				}
			}
			if (listMaCanHo.Any())
			{
				hasChangeData = true;

				var result = await KeHoachBanHangService.RemoveCanHoCuaKeHoach(MaPhieuKH, MaDotMoBan, listMaCanHo);
				if (result.Status)
				{
					await LoadDanhSachCanHoData();
					//await OnReloadCanHo.InvokeAsync();
				}
				StateHasChanged();
			}
		}
	}


