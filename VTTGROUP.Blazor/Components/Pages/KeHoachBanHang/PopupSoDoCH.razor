					{
						<ul>
							@foreach (var d in ListDot)
							{
								<li><span style="background-color:@d.MaMau"></span>@d.TenDotMoBan</li>
							}
						</ul>
					}
				</div>
				@* <button type="button" class="button button-action button-luu-phieu" @onclick="SubmitSelectedCanHo">
					Lưu
				</button> *@
				<button type="button" class="button button-action button-huy" @onclick="ClosePopupCH" data-bs-dismiss="modal">Đóng</button>
			</div>
		</div>
	</div>
</div>
@if (showButton)
{
	<button class="btn context-menu"
			style="position:fixed; top:@menuYpx; left:@menuXpx;"
			@onclick="OnActionClick">
		Bỏ chọn
	</button>
}
@code {
	[Parameter]
	public EventCallback<SanPhamPopupPaginModel?> OnSelected { get; set; }
	[Parameter]
	public string? MaPhieuKH { get; set; }
	public string? MaDotMoBan { get; set; }
	public string? TenDotMoBan { get; set; }
	public string? MaDuAn { get; set; }
	[Parameter] public EventCallback OnReloadCanHo { get; set; }
	private string? SelectedBlock;
	public List<string> SelectedBlocks { get; set; } = new();
	private string? SelectedTang;
	public List<string> SelectedTangs { get; set; } = new();
	private string? SelectedTruc;
	public List<string> SelectedTrucs { get; set; } = new();
	private bool isLoading = false;
	private List<DaDanhMucBlock> ListBlock = new();
	private List<DaDanhMucTang> ListTang = new();
	private List<DaDanhMucViewTruc> ListTruc = new();
	private List<DaDanhMucDotMoBan> ListDot = new();

	private List<SoDoCanHoModel> DanhSachCanHo = new();
	private List<ViewModel> MatCanHo = new();
	private Dictionary<string, List<SoDoCanHoModel>> GroupByBlock = new();
	private List<string> TangList = new();
	private List<string> blocks = new();

	private ElementReference refBlock;
	private ElementReference refTang;
	private ElementReference refTruc;

	List<SanPhamPopupPaginModel> SanPhamPopups = new();
	private bool _shouldScaleAfterRender;

	private bool showButton = false;
	private double menuX, menuY;
	private string menuXpx => $"{menuX}px";
	private string menuYpx => $"{menuY}px";
	private string actionType = "";
	private object? actionData;

	private int zoom = 100;

	private bool hasChangeData = false;


	@* @oncontextmenu:preventDefault="true"
	@oncontextmenu="@( (MouseEventArgs e) => ShowContextMenu(e, "Truc", (block, truc, mat)))" *@

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			//await JS.InvokeVoidAsync("select2Helper.initSelectMultipleChange", "MaBlock", "Chọn block", true, DotNetObjectReference.Create(this));
			await JS.InvokeVoidAsync("enableHorizontalScrollDrag", "scrollWrapper");
			//await JS.InvokeVoidAsync("select2Helper.initSelectMultipleChange", "MaTang", "Chọn tầng", true, DotNetObjectReference.Create(this));
			//await JS.InvokeVoidAsync("select2Helper.initSelectMultipleChange", "MaTruc", "Chọn trục", true, DotNetObjectReference.Create(this));
		}
		if (_shouldScaleAfterRender)
		{
			_shouldScaleAfterRender = false;
			await JS.InvokeVoidAsync("autoScaleSoDoCanHo");
			await JS.InvokeVoidAsync("select2Helper.resetAndInit", "MaBlock", "Chọn block", true, DotNetObjectReference.Create(this));
			await JS.InvokeVoidAsync("soDoCanHo.init", "#container-view-canho");
		}
	}

	private async Task LoadDanhSachCanHoData()
	{
		DanhSachCanHo = await KeHoachBanHangService.GetSoDoCanHoAsync(MaDuAn, SelectedBlock, SelectedTang, SelectedTruc, MaPhieuKH);
		GroupByBlock = DanhSachCanHo
		.GroupBy(x => x.TenBlock)
		.ToDictionary(g => g.Key, g => g.OrderBy(x => x.ThuTuTruc).ToList());

		blocks = GroupByBlock.Keys.ToList();

		TangList = DanhSachCanHo
		.Select(x => x.TenTang)
		.Distinct()
		.OrderByDescending(x => int.TryParse(x, out var t) ? t : 0)
		.ToList();

		StateHasChanged();
	}

	private List<TrucSoDoModel> GetTrucs(string block, string matCanHo)
	{
		if (!GroupByBlock.ContainsKey(block)) return new();

		return GroupByBlock[block]
		.Where(x => x.MaView?.Trim() == matCanHo?.Trim())
		.OrderBy(x => x.ThuTuTruc)
		.Select(x => new TrucSoDoModel
			{
				MaTruc = x.MaTruc,
				TenTruc = x.TenTruc
			})
		.DistinctBy(x => x.MaTruc)
		.ToList();
	}

	private bool IsFullMat(string block)
	{
		var countMat = 0;
		foreach (var mat in MatCanHo)
		{
			var trucList = GetTrucs(block, mat.MaView);
			if (trucList.Any())
			{
				countMat = countMat + 1;
			}
		}
		return countMat == 2;
	}

	private SoDoCanHoModel? GetCanHo(string block, string tang, string truc, string mat)
	{
		return GroupByBlock[block].FirstOrDefault(x =>
		x.TenTang?.Trim() == tang?.Trim() &&
		x.TenTruc?.Trim() == truc?.Trim() &&
		x.MaView?.Trim() == mat?.Trim()
		);
	}

	public async Task Show(DotMoBanCanHoTheoDuAn dot, string maDuAn, string maPhieuKH)
	{
		SelectedBlocks = new();
		SelectedBlock = string.Empty;
		MaDotMoBan = dot.MaDot;
		TenDotMoBan = dot.TenDot;
		MaDuAn = maDuAn;
		MaPhieuKH = maPhieuKH;
		ListBlock = await SanPhamService.GetByBlockTheoDuAnAsync(MaDuAn);
		ListDot = await SanPhamService.GetListDotMoBanAsync(MaDuAn);
		MatCanHo = await ViewService.GetByDuAnAsync(MaDuAn);
		SanPhamPopups = new();
		await LoadDanhSachCanHoData();
		await JS.InvokeVoidAsync("bootstrapModal.show", "#PopupSoDoCHModal");

		_shouldScaleAfterRender = true;
		hasChangeData = false;
		StateHasChanged();
	}

	[JSInvokable]
	public async Task OnSelectMultiChanged(string id, string[] selecteds)
	{
		if (id == "MaBlock")
		{
			SelectedBlocks = selecteds.ToList();
			SelectedBlock = string.Join(',', SelectedBlocks.ToArray());
			//SelectedTang = string.Empty;
			//SelectedTangs = new();
			//SelectedTruc = string.Empty;
			//SelectedTrucs = new();
			//ListTang = await SanPhamService.GetByTangTheoBlockAsync(SelectedBlock, MaDuAn);
			//ListTruc = await SanPhamService.GetByTrucTheoDuAnAsync(MaDuAn, SelectedBlock);
			StateHasChanged();
		}
		else if (id == "MaTang")
		{
			SelectedTangs = selecteds.ToList();
			SelectedTang = string.Join(',', SelectedTangs.ToArray());
		}
		else if (id == "MaTruc")
		{
			SelectedTrucs = selecteds.ToList();
			SelectedTruc = string.Join(',', SelectedTrucs.ToArray());
		}

		await LoadDanhSachCanHoData();

	}
	private async Task OnSeLectedBlock(string? block)
	{
		var listMaCanHo = new List<SanPhamPopupPaginModel>();
		var canHos = DanhSachCanHo.Where(x => x.TenBlock?.Trim() == block.Trim() && string.IsNullOrEmpty(x.MaDotMoBan)).ToList();
		if (canHos.Any())
		{
			foreach (var ch in canHos)
			{
				if (ch.IsKhongChonLai == false)
				{
					var newSanPham = new SanPhamPopupPaginModel
						{
							MaSanPham = ch.MaSanPham,
							HeSoTuTinh = ch.HeSoTuTinh,
							DienTichTimTuong = ch.DienTichCanHo
						};
					listMaCanHo.Add(newSanPham);
				}
			}
			if (listMaCanHo.Any())
			{
				hasChangeData = true;
				var result = await KeHoachBanHangService.ThemCanHoVaoKeHoach(MaPhieuKH, MaDotMoBan, listMaCanHo, true);
				if (result.Status)
				{
					await LoadDanhSachCanHoData();
					//await OnReloadCanHo.InvokeAsync();
				}
				StateHasChanged();
			}
		}
		else
		{
			var canHoRemoves = DanhSachCanHo.Where(x => x.TenBlock?.Trim() == block.Trim() && x.MaDotMoBan == MaDotMoBan).ToList();
			foreach (var ch in canHoRemoves)
			{
				if (ch.IsKhongChonLai == false)
				{
					var newSanPham = new SanPhamPopupPaginModel
						{
							MaSanPham = ch.MaSanPham,
							HeSoTuTinh = ch.HeSoTuTinh,
							DienTichTimTuong = ch.DienTichCanHo
						};
					listMaCanHo.Add(newSanPham);
				}
			}
			if (listMaCanHo.Any())
			{
				hasChangeData = true;
				var result = await KeHoachBanHangService.RemoveCanHoCuaKeHoach(MaPhieuKH, MaDotMoBan, listMaCanHo);
				if (result.Status)
				{
					await LoadDanhSachCanHoData();
					//await OnReloadCanHo.InvokeAsync();
				}
				StateHasChanged();
			}
		}
	}
