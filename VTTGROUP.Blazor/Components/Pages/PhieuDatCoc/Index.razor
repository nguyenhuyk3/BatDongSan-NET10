@page "/phieudatcoc"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.KeHoachBanHang
@using VTTGROUP.Blazor.Components.Pages.Paging
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model
@using VTTGROUP.Domain.Model.PhieuDatCoc
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@inject IBaseService BaseService
@inject CanHoService CanHoService
@inject PhieuGiuChoService PhieuGiuChoService
@inject PhieuDatCocService PhieuDatCocService
@inject DMKhachHangService DMKhachHangService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IWebHostEnvironment _env

<h1 class="legend-title">Phiếu đặt cọc</h1>
<div class="rounded-xl bg-white p-4 space-y-3 wraper-content-page">
    <div class="relative z-50">
        <div class="flex flex-wrap items-end gap-3">
            <div class="flex items-center">
                <div class="result-label-icon">
                    <i class="mdi mdi-calendar-today"></i>
                    <DateRangePicker OnDateRangeChanged="OnDateRangeChanged" @ref="dateRangeRef" />
                </div>
            </div>

            <UiSelect Icon="mdi mdi-file-document"
                      Placeholder="Chọn dự án"
                      Items="ListDA.Select(x => new UiSelect.SelectItem(x.MaDuAn!, x.TenDuAn!))"
                      @bind-Value="selectedDuAn"
                      OnChange="OnDTKHChanged" />

            <div class="ml-auto flex items-center gap-2">
                <MoreFilterPopup OnTrangThaiChanged="OnTTDChanged"
                                 OnReset="ResetAllParam" @ref="morePopupRef" />
                <AddButton Text="Phiếu đặt cọc" OnClick="Insert" />
            </div>
        </div>
    </div>
    <div class="flex items-center gap-3 my-3">
        <div class="w-[360px] md:w-[480px]">
            <InputSearch @bind-Value="search" OnSearch="Search" />
        </div>
        <div class="ml-auto h-11 flex items-center">
            <Pagination Page="@_page"
                        TotalPages="@totalPage"
                        TotalItems="@totalCount"
                        OnPageChanged="HandlePageChanged"
                        OnPageSizeChanged="HandlePageSizeChanged" />
        </div>
    </div>
    <SelectedDeleteList Count="@SelectedCount" OnRemoveList="RemoveSelectedAsync" OnDeleteList="@DeleteSelectedAsync" />
    <div class="container-table-detail">
        <div class="container-table-fixed has-paging">
            <table class="tbl table-form table-detail treeTable" id="table-data">
                <thead>
                    <tr class="cls_custome_back">
                        <th style="width: 40px" class="text-center" rowspan="2">
                            <input type="checkbox" class="form-check-input" checked="@IsSelectAll"
                                   @onchange="(e) => OnCheckboxAllChanged(e)" />
                        </th>
                        <th style="width: 40px" rowspan="2" class="text-center">
                            STT
                        </th>
                        <th style="width: 130px" rowspan="2" class="text-center">Hệ thống</th>
                        <th style="width: 220px" rowspan="2" class="text-center">Dự án</th>
                        <th colspan="2" class="text-center">Khách hàng</th>
                        <th style="width: 70px" rowspan="2" class="text-center">Phiếu ĐK</th>
                        <th colspan="2" style="text-align:center">Thông tin căn hộ</th>
                        <th style="width: 200px" rowspan="2">Nội dung</th>
                        <th style="width: 90px" rowspan="2" class="text-center">
                            Trạng thái
                        </th>
                        <th style="width: 50px" rowspan="2">
                            &nbsp;
                        </th>
                    </tr>
                    <tr class="cls_custome_back">
                        <th style="width: 140px;text-align:center">Thông tin</th>
                        <th style="width: 70px;text-align:center">Thao tác</th>
                        <th style="width: 70px;text-align:center">Căn hộ</th>
                        <th style="width: 100px;text-align:center">Giá bán ST</th>
                    </tr>
                </thead>
                <tbody class="content-table">
                    @if (listPDC != null && listPDC.Count > 0)
                    {
                        @foreach (var item in listPDC)
                        {
                            <tr class="initialized">
                                <td class="text-center">
                                    @if (item.TrangThaiDuyet < 1 && item.NguoiLap == maNhanVienHT)
                                    {
                                        <input type="checkbox" class="form-check-input"
                                               checked="@item.IsSelected"
                                               @onchange="(e) => OnCheckboxChanged(item, e)" />
                                    }
                                </td>
                                <td style="text-align:center">
                                    <span>@item.STT</span>
                                </td>
                                <td>
                                    <div class="item-phieu" @onclick="() => OnEditRecord(item.MaPhieuDC.ToString())">@item.MaPhieuDC</div>
                                    <span class="created-label">@item.HoVaTen</span>
                                    <div class="created-date-label">@string.Format("{0:dd/MM/yyyy}", item.NgayLap)</div>
                                </td>
                                <td>
                                    <span>@item.TenDuAn</span>
                                </td>
                                @*Hiển thị thông tin của khách hàng*@
                                <td>
                                    <div class="item-phieu" @onclick="() => OnMaKHRecord(item.MaKhachHang.ToString())">@item.MaKhachHang</div>
                                    <span class="created-label">@item.TenKhachHang</span>
                                    <div class="created-date-label">@string.Format("{0:dd/MM/yyyy}", item.NgayKi)</div>
                                </td>
                                <td class="text-center">
                                    <div class="icon-button" data-title="Lịch sử thay đổi KH" data-position="left">
                                        <a href="javascript:void(0)" @onclick="() => OnViewLichSuKhachHang(item.MaKhachHang)">
                                            <span><i class="mdi mdi-history"></i></span>
                                        </a>
                                    </div>
                                </td>
                                <td>
                                    <div class="item-phieu"><span class="input-value" @onclick="() => OnViewPDK(item.MaPhieuDangKy)">@item.MaPhieuDangKy</span></div>
                                </td>
                                <td>
                                    <div class="item-phieu"><span class="input-value" @onclick="() => OnViewCH(item.MaCanHo, item.MaDuAn)">@item.TenSanPham</span></div>
                                </td>
                                <td style="text-align:right">
                                    @string.Format("{0:N0}", item.GiaBanSauThue)
                                </td>
                                <td>
                                    @item.GhiChu
                                </td>
                                <td class="text-center">
                                    <span class="status-label" style="color: @(item.Mau)" @onclick="() => LichSuDuyetPhieu(maCongViec, item.MaPhieuDC)">
                                        @item.TenTrangThai
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center flex-column">
                                        @if (item.TrangThaiDuyet < 1 && item.NguoiLap == maNhanVienHT)
                                        {

                                            <div class="icon-button" data-title="Cập nhật" data-position="left">
                                                <a href="javascript:void()" @onclick="() => OnEditRecord(item.MaPhieuDC!)">
                                                    <span>
                                                        <i class="mdi mdi-pencil">
                                                        </i>
                                                    </span>
                                                </a>
                                            </div>
                                            <div class="icon-button" data-title="Xóa" data-position="left">
                                                <a href="javascript:void(0)" @onclick="() => ShowConfirmDelete(item.MaPhieuDC!)"><span><i class="mdi mdi-delete "></i></span></a>
                                            </div>

                                        }
                                        else
                                        {
                                            @if (item.MaTrangThai == "3" && item.IsDaKy == false)
                                            {
                                                <div class="icon-button" data-title="Cập nhật ngày ký" data-position="left">
                                                    <a href="javascript:void(0);"
                                                       @onclick="() => CapNhatNgayKy(item)">
                                                        <i class="bi bi-calendar2-event text-warning fs-5"></i>
                                                    </a>
                                                </div>
                                            }
                                            else if (item.MaTrangThai == "3" && item.IsDaKy == true)
                                            {
                                                if (string.IsNullOrEmpty(item.MaHopDong) && string.IsNullOrEmpty(item.MaPhieuThanhLy))
                                                {
                                                    <div class="icon-button" data-title="Tạo hợp đồng" data-position="left">
                                                        <a href="javascript:void(0);"
                                                           @onclick="() => OnHopDong(item.MaPhieuDC)">
                                                            <i class="bi bi-receipt text-warning"></i>
                                                        </a>
                                                    </div>
                                                    <div class="icon-button" data-title="Thanh lý đặt cọc" data-position="left">
                                                        <a href="javascript:void(0);"
                                                           @onclick="() => OnTaoPhieuThanhLy(item.MaPhieuDC)">
                                                            <i class="bi bi-file-earmark-x text-danger"></i>
                                                        </a>
                                                    </div>
                                                }
                                                else
                                                {
                                                    if (!string.IsNullOrEmpty(item.MaHopDong))
                                                    {
                                                        <div class="icon-button" data-title="Đã tạo hợp đồng" data-position="left">
                                                            <a href="javascript:void(0);" @onclick="() => OnPhieuHopDongRecord(item.MaHopDong)">
                                                                <i class="bi bi-cash-stack text-primary"></i>
                                                            </a>
                                                        </div>
                                                    }
                                                    if (!string.IsNullOrEmpty(item.MaPhieuThanhLy))
                                                    {
                                                        <div class="icon-button" data-title="Đã thanh lý" data-position="left">
                                                            <a href="javascript:void(0);" @onclick="() => OnThanhLyRecord(item.MaPhieuThanhLy)">
                                                                <i class="bi bi-file-text text-success"></i>
                                                            </a>
                                                        </div>
                                                    }
                                                }
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            @if (listPDC == null || !listPDC.Any())
            {
                <div class="p-2">Không có dữ liệu</div>
            }
        </div>
    </div>
    <ConfirmDeleteModal ModalId="confirmDeleteModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa phiếu đặt cọc này <strong>@selectedMaPhieu</strong> không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDelete">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>
    <ConfirmDeleteModal ModalId="confirmDeleteListModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa danh sách phiếu đặt cọc này không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDeleteList">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>
</div>

<PopupLichSuDuyetPhieu @ref="guiDuyetModalRef" />
<CanHoDetails @ref="canHoModalRef" />
<PopupNgayKy @ref="ngayKyModalRef" OnSelected="OnNgayKySelected" />
<PopupLichSuKhachHangChiTiet @ref="popupLichSuKHRef" />
@code {
    private DotNetObjectReference<Index>? _dotNetRef;
    private string? selectedDuAn;
    private string? selectedMaPhieu;
    private bool isLoading = false;
    int _page = 1;
    int _pageSize = 10;
    int totalPage = 1;
    int totalCount;
    string? search;
    private string? tuNgay { get; set; } = DateTime.Now.AddMonths(-1).ToString("dd/MM/yyyy");
    private string? denNgay { get; set; } = DateTime.Now.ToString("dd/MM/yyyy");

    List<PhieuDatCocPaginDto> listPDC = new();
    private List<DaDanhMucDuAn> ListDA = new();

    private string? selectedTrangThaiDuyet;
    private PopupLichSuDuyetPhieu? guiDuyetModalRef;
    DateRangePicker dateRangeRef;
    MoreFilterPopup morePopupRef;
    private string maNhanVienHT;
    private string maCongViec = "PhieuDatCoc";
    private CanHoDetails? canHoModalRef;
    private PopupNgayKy? ngayKyModalRef;
    private PopupLichSuKhachHangChiTiet? popupLichSuKHRef;
    int SelectedCount => listPDC?.Count(x => x.IsSelected) ?? 0;
    private bool IsSelectAll = false;

    // Chặn re-init JS
    private bool _jsInited;
    /* --------- 1) LOAD DỮ LIỆU Ở ĐÂY --------- */
    protected override async Task OnInitializedAsync()
    {
        await BaseService.CheckPermissionAsync(maCongViec, VuViec.Xem.GetDescription());
        ListDA = await CanHoService.GetByDuAnAsync();
        maNhanVienHT = await BaseService.MaNhanVienHienTai();
        await LoadPhieuDatCoc(); // Blazor tự render lại sau khi hàm này xong → không cần StateHasChanged()
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {

        if (firstRender && !_jsInited)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaDuAn", "Chọn dự án", true);
            _jsInited = true;
        }

        // if (firstRender)
        // {
        //     await BaseService.CheckPermissionAsync(maCongViec, VuViec.Xem.GetDescription());
        //     _dotNetRef = DotNetObjectReference.Create(this);
        //     await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaDuAn", "Chọn dự án", true);
        //     await JS.InvokeVoidAsync("tooltipHelper.init");
        //     ListDA = await CanHoService.GetByDuAnAsync();
        //     maNhanVienHT = await BaseService.MaNhanVienHienTai();
        //     await LoadPhieuDatCoc();
        //     // StateHasChanged();
        // }
        // if (listPDC.Any())
        // {
        //     var config = new List<FixColumnConfig>
        //     {
        //         new FixColumnConfig { left = 0 },
        //         new FixColumnConfig { right = 0 }
        //     };
        //     await JS.InvokeVoidAsync("applyStickyColumnsDynamic", "table-data", config);
        // }

    }

    private async Task ShowConfirmDelete(string maPhieu)
    {
        await BaseService.CheckPermissionAsync(maCongViec, VuViec.Xoa.GetDescription());
        selectedMaPhieu = maPhieu;
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteModal");
    }

    private async Task ConfirmDelete()
    {
        if (selectedMaPhieu == null || string.IsNullOrEmpty(selectedMaPhieu))
        {
            return;
        }
        var result = await PhieuDatCocService.DeletePDCAsync(selectedMaPhieu, _env.WebRootPath);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteModal");
        await LoadPhieuDatCoc();
        selectedMaPhieu = string.Empty;
        StateHasChanged();
    }

    private async Task OnDTKHChanged(string? duAn)
    {
        if (isLoading) return;
        selectedDuAn = string.IsNullOrWhiteSpace(duAn) ? null : duAn;
        _page = 1;
        await LoadPhieuDatCoc();
    }

    private async Task OnTTDChanged(string trangThai)
    {
        var newTTD = trangThai;
        if (newTTD == selectedTrangThaiDuyet || isLoading)
        {
            return;
        }
        selectedTrangThaiDuyet = newTTD;
        _page = 1;
        await LoadPhieuDatCoc();
    }

    private async Task LoadPhieuDatCoc()
    {
        isLoading = true;
        try
        {
            var (data, total) = await PhieuDatCocService.GetPagingAsync(selectedDuAn, _page, _pageSize, search, selectedTrangThaiDuyet, tuNgay, denNgay);
            listPDC = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandlePageChanged(int newPage)
    {
        _page = newPage;
        await LoadPhieuDatCoc();
    }

    private async Task HandlePageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        _page = 1;
        await LoadPhieuDatCoc(); // Gọi lại API với PageSize mới
    }
    private async Task OnDateRangeChanged((string? Start, string? End) range)
    {
        tuNgay = range.Start;
        denNgay = range.End;
        await LoadPhieuDatCoc();
    }

    private async Task OnEditRecord(string maPhieu)
    {
        Nav.NavigateTo($"/phieudatcoc/edit/{maPhieu}");
    }

    private void Insert()
    {
        Nav.NavigateTo("/phieudatcoc/create");
        return;
    }

    private async Task Search(string? keyword)
    {
        search = keyword;
        _page = 1;
        await LoadPhieuDatCoc();
    }

    async Task NextPage()
    {
        _page++;
        await LoadPhieuDatCoc();
    }

    async Task PreviousPage()
    {
        _page--;
        await LoadPhieuDatCoc();
    }
    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    private async Task LichSuDuyetPhieu(string MaCongViec, string MaPhieu)
    {
        await guiDuyetModalRef?.ShowLSDP(MaCongViec, MaPhieu);
    }

    private async Task ResetAllParam()
    {
        _page = 1;
        _pageSize = 10;
        search = null;
        selectedTrangThaiDuyet = null;
        selectedDuAn = null;
        tuNgay = null;
        denNgay = null;
        await LoadPhieuDatCoc();
        await dateRangeRef.ResetAsync();
        await morePopupRef.RestAllMore();
        await JS.InvokeVoidAsync("select2Helper.resetMultipleSelects", new[] { "MaDuAn", "TrangThaiDuyet" });
        StateHasChanged();
    }

    private async Task ResetMore()
    {
        _page = 1;
        _pageSize = 10;
        await LoadPhieuDatCoc();
    }

    private async Task OnMaKHRecord(string maKH)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/khachhang/edit/" + maKH);
    }

    private async Task OnViewPDK(string maPhieuDK)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/phieudangky/edit/" + maPhieuDK);
    }

    private async Task OnViewCH(string maCanHo, string maDuAn)
    {
        if (canHoModalRef != null)
        {
            var canHo = await BaseService.ThongTinChiTietSanPham(maDuAn, maCanHo);
            await canHoModalRef.Show(canHo);
        }
    }

    private async Task CapNhatNgayKy(PhieuDatCocPaginDto item)
    {
        await ngayKyModalRef?.ShowThongTin(item);
    }

    private async Task OnNgayKySelected(PhieuDatCocModel item)
    {
        var result = await PhieuDatCocService.XacNhanNgayKyAsync(item);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await LoadPhieuDatCoc();
    }

    private async Task OnHopDong(string maPhieu)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/hopdongmuaban/create/" + maPhieu);
    }

    private async Task OnTaoPhieuThanhLy(string maPhieu)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/thanhlydatcoc/create/" + maPhieu);
    }

    private async Task OnPhieuHopDongRecord(string maPhieu)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/hopdongmuaban/edit/" + maPhieu);
    }

    private async Task OnThanhLyRecord(string maPhieu)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/thanhlydatcoc/edit/" + maPhieu);
    }

    private async Task OnViewLichSuKhachHang(string maKhachHang)
    {
        if (popupLichSuKHRef != null && !string.IsNullOrEmpty(maKhachHang))
        {
            await popupLichSuKHRef.Show(maKhachHang);
        }
    }

    private async Task RemoveSelectedAsync()
    {
        IsSelectAll = false;
        foreach (var item in listPDC)
        {
            item.IsSelected = IsSelectAll;
        }
    }

    private async Task DeleteSelectedAsync()
    {
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteListModal");
    }

    private async Task ConfirmDeleteList()
    {
        var selected = listPDC.Where(d => d.IsSelected).ToList();
        if (selected.Count == 0) return;
        var result = await PhieuDatCocService.DeleteListAsync(selected, _env.WebRootPath);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteListModal");
        await LoadPhieuDatCoc();
        StateHasChanged();
    }

    private async Task OnCheckboxAllChanged(ChangeEventArgs e)
    {
        IsSelectAll = (bool)e.Value;
        foreach (var item in listPDC)
        {
            if (item.TrangThaiDuyet < 1 && item.NguoiLap == maNhanVienHT)
            {
                item.IsSelected = IsSelectAll;
            }
        }
    }

    private async Task OnCheckboxChanged(PhieuDatCocPaginDto item, ChangeEventArgs e)
    {
        item.IsSelected = (bool)e.Value;
        IsSelectAll = listPDC.All(x => x.IsSelected);
    }
}

<style>
    table.table-detail thead tr.cls_custome_back th.group-header {
        background-color: #e6f0ff !important;
        color: #003366 !important;
        font-weight: bold;
        text-align: center;
        vertical-align: middle;
    }

    /* Đảm bảo icon đồng bộ */
    .icon-button i {
        font-size: 25px; /* tương đương fs-5, đồng bộ cho tất cả */
        width: 24px; /* tạo khung vuông đồng đều */
        height: 24px;
        line-height: 24px; /* căn giữa icon trong khung */
        text-align: center;
        vertical-align: middle;
    }

    /* Nếu icon FA to hơn BI thì chỉnh lại cho cân */
    .icon-button .fa {
        font-size: 25px !important;
    }

</style>