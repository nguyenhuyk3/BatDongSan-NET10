        Record.MaDatCocChoKyLai = entity2.MaDatCocChoKyLai;

        // Lấy CSTT mặc định từ BH_PhieuDangKiChonCan_CSBH (LoaiCS='CSTT', IsChon=1)
        var maCSTTMacDinh = await PhieuDatCocService.GetCSTTMacDinhTuPhieuDKAsync(maPhieuDK);
        Record.MaChinhSachTT = !string.IsNullOrEmpty(maCSTTMacDinh) ? maCSTTMacDinh : entity2.MaCSTT;

        var entity = await PhieuDatCocService.ThongTinKhachHang(maPhieuDK, string.Empty, Record.MaDuAn, Record.MaChinhSachTT);
        Record.MaKhachHang = entity.MaKhachHang;
        Record.TenKhachHang = entity.TenKhachHang;
        Record.NgaySinh = !string.IsNullOrEmpty(entity.NgaySinh) ? DateTime.ParseExact(entity.NgaySinh, "dd/MM/yyyy", CultureInfo.InvariantCulture) : (DateTime?)null;
        Record.SoDienThoai = entity.SoDienThoai;
        Record.IDCard = entity.IdCard;
        Record.NgayCap = !string.IsNullOrEmpty(entity.NgayCapIdCard) ? DateTime.ParseExact(entity.NgayCapIdCard, "dd/MM/yyyy", CultureInfo.InvariantCulture) : (DateTime?)null;
        Record.NoiCap = entity.NoiCapIdCard;
        Record.DiaChiThuongTru = entity.DiaChiThuongTru;
        Record.DiaChiHienNay = entity.DiaChiHienNay;
        Record.DotMoBan = entity.MaDotMoBan;
        Record.TenDotMoBan = entity.TenDotMoBan;
        Record.MaCanHo = entity.MaCanHo;
        Record.TenCanHo = entity.TenCanHo;
        Record.GiaTriCK = entity.GiaTriCK;
        Record.IDKhachHangCT = entity.IDKhachHangCT;

        Record.DienTichTimTuong = entity.DienTichTimTuong;
        Record.DienTichSanVuon = entity.DienTichSanVuon;
        Record.DienTichLotLong = entity.DienTichLotLong;
        Record.GiaDat = entity.GiaDat;
        Record.DonGiaDat = entity.DonGiaDat;
        Record.GiaCanHoTruocThue = entity.GiaCanHoTruocThue;
        Record.TyLeThueVAT = entity.TyLeThueVAT;
        Record.GiaCanHoSauThue = entity.GiaCanHoSauThue;
        Record.TyLeCK = entity.TyLeCK;
        Record.GiaTriCK = entity.GiaTriCK;
        Record.GiaBanTruocThue = entity.GiaBanTruocThue;
        Record.GiaBanTienThue = entity.GiaBanTienThue;
        Record.GiaBanSauThue = entity.GiaBanSauThue;
        Record.TyLeQuyBaoTri = entity.TyLeQuyBaoTri;
        Record.TienQuyBaoTri = entity.TienQuyBaoTri;
        ListCSTT = await PhieuDatCocService.GetChinhSachThanhToanAsync(Record.MaDuAn, maPhieuDK);
        ListTDTT = await PhieuDatCocService.GetByTienDoThanhToanAsync(Record.MaChinhSachTT, String.Empty, Record.GiaBanTruocThue, Record.GiaBanTienThue, Record.MaPhieuDK);
        ListMI = await PhieuDatCocService.GetByMauInAsync(Record.MaDuAn);
        await LoadCSTTMacDinhTuPhieuDC();
    }

    private async Task OnPhieuDKChanged(ChangeEventArgs e)
    {
        selectedPDKRaw = e.Value.ToString();
        if (!string.IsNullOrEmpty(selectedPDKRaw))
        {
            var parts = selectedPDKRaw.Split('|');
            if (parts.Length == 6)
            {
                Record.MaPhieuDK = parts[0];
                Record.MaDatCocChoKyLai = parts[3];

                // Lấy CSTT mặc định từ BH_PhieuDangKiChonCan_CSBH (LoaiCS='CSTT', IsChon=1)
                var maCSTTMacDinh = await PhieuDatCocService.GetCSTTMacDinhTuPhieuDKAsync(Record.MaPhieuDK);
                Record.MaChinhSachTT = !string.IsNullOrEmpty(maCSTTMacDinh) ? maCSTTMacDinh : parts[5];
            }
        }
        else
        {
            Record.MaPhieuDK = string.Empty;                 // -> HasPDK = false
            await ResetThongTin();
            // Reset các thông tin phụ thuộc nếu cần
            ListTDTT?.Clear();
            // Nếu muốn reset CSTT về rỗng:
            Record.MaChinhSachTT = string.Empty;
            ListCSTT = await PhieuDatCocService.GetChinhSachThanhToanAsync(Record.MaDuAn, string.Empty);
            await DestroyCSTTSelect2Async();  // dọn Select2 (vì block bị ẩn)
            StateHasChanged(); // bắt buộc để ẩn 2 block
            return;
        }
        var entity = await PhieuDatCocService.ThongTinKhachHang(Record.MaPhieuDK, string.Empty, Record.MaDuAn, Record.MaChinhSachTT);
        Record.MaKhachHang = entity.MaKhachHang;
        Record.TenKhachHang = entity.TenKhachHang;
        Record.MaDoiTuongKH = entity.MaDoiTuongKH;
        Record.NguoiDaiDien = entity.NguoiDaiDien;
        Record.ChucVuNguoiDaiDien = entity.ChucVuNguoiDaiDien;
        Record.NguoiLienHe = entity.NguoiLienHe;
        Record.SoDienThoaiNguoiLienHe = entity.SoDienThoaiNguoiLienHe;
        Record.NgaySinh = !string.IsNullOrEmpty(entity.NgaySinh) ? DateTime.ParseExact(entity.NgaySinh, "dd/MM/yyyy", CultureInfo.InvariantCulture) : (DateTime?)null;
        Record.SoDienThoai = entity.SoDienThoai;
        Record.IDCard = entity.IdCard;
        Record.NgayCap = !string.IsNullOrEmpty(entity.NgayCapIdCard) ? DateTime.ParseExact(entity.NgayCapIdCard, "dd/MM/yyyy", CultureInfo.InvariantCulture) : (DateTime?)null;
        Record.NoiCap = entity.NoiCapIdCard;
        Record.DiaChiThuongTru = entity.DiaChiThuongTru;
        Record.DiaChiHienNay = entity.DiaChiHienNay;
        Record.DotMoBan = entity.MaDotMoBan;
        Record.TenDotMoBan = entity.TenDotMoBan;
        Record.MaCanHo = entity.MaCanHo;
        Record.TenCanHo = entity.TenCanHo;
        Record.GiaTriCK = entity.GiaTriCK;
        Record.IDKhachHangCT = entity.IDKhachHangCT;

        Record.DienTichTimTuong = entity.DienTichTimTuong;
        Record.DienTichSanVuon = entity.DienTichSanVuon;
        Record.DienTichLotLong = entity.DienTichLotLong;
        Record.GiaDat = entity.GiaDat;
        Record.DonGiaDat = entity.DonGiaDat;
        Record.GiaCanHoTruocThue = entity.GiaCanHoTruocThue;
        Record.TyLeThueVAT = entity.TyLeThueVAT;
        Record.GiaCanHoSauThue = entity.GiaCanHoSauThue;
        Record.TyLeCK = entity.TyLeCK;
        Record.GiaTriCK = entity.GiaTriCK;
        Record.GiaBanTruocThue = entity.GiaBanTruocThue;
        Record.GiaBanTienThue = entity.GiaBanTienThue;
        Record.GiaBanSauThue = entity.GiaBanSauThue;
        Record.TyLeQuyBaoTri = entity.TyLeQuyBaoTri;
        Record.TienQuyBaoTri = entity.TienQuyBaoTri;
        ListCSTT = await PhieuDatCocService.GetChinhSachThanhToanAsync(Record.MaDuAn, e.Value?.ToString());
        ListTDTT = await PhieuDatCocService.GetByTienDoThanhToanAsync(Record.MaChinhSachTT, String.Empty, Record.GiaBanTruocThue, Record.GiaBanTienThue, Record.MaPhieuDK);
        // await LoadCSTTMacDinhTuPhieuDC();
        await DestroyCSTTSelect2Async();
        StateHasChanged();                // render ra options mới
        await InitCSTTSelect2Async();     // init lại để thấy thành combobox
        await JS.InvokeVoidAsync("eval", $@"$('#MaChinhSachTT').val('{Record?.MaChinhSachTT}').trigger('change');");
        // StateHasChanged();
    }
