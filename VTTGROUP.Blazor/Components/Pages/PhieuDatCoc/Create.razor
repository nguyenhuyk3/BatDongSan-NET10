    private async Task ThongTinPhieuDK(string maPhieuDK)
    {
        var entity2 = await PhieuDatCocService.GetByPhieuDangKyDCAsync(id);
        Record.MaDuAn = entity2.MaDuAn;
        Record.TenDuAn = entity2.TenDuAn;
