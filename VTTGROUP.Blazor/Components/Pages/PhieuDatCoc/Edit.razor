    private bool IsLoading = false;
    int Percent;
    string Status = "";
    int Index, Total;
    CancellationTokenSource? _cts;
    private async Task PrintPhieuDC()
    {
        IsLoading = true;
        Percent = 0; Status = "Bắt đầu..."; Index = 0; Total = 0;
        _cts = new CancellationTokenSource();
        var progress = new Progress<ExportProgress>(p =>
                {
                    Percent = Math.Clamp(p.Percent, 0, 100);
                    Status = p.Message;
                    Index = p.Index;
                    Total = p.Total;
                    InvokeAsync(StateHasChanged);
                });
        try
        {
            var (name, bytes) = await PhieuDatCocService.GenerateAllDocsZipProgressAsync(id, progress, _cts.Token);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBytes", name, base64, "application/zip");
            Status = "Hoàn tất.";
            Percent = 100;
        }
        catch (OperationCanceledException)
        {
            Status = "Đã hủy.";
        }
        catch (Exception ex)
        {
            Status = "Lỗi: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }
    void Cancel() => _cts?.Cancel();

