@page "/phieuxacnhanthanhtoan/create"
@using System.Globalization
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.Uploads
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model.HopDongChuyenNhuong
@using VTTGROUP.Domain.Model.KhachHang
@using VTTGROUP.Domain.Model.PhieuXacNhanThanhToan
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Model
@inject LoadingService Loading
@inject IBaseService BaseService
@inject CanHoService CanHoService
@inject HopDongChuyenNhuongService HopDongChuyenNhuongService
@inject PhieuXacNhanThanhToanService PhieuXacNhanThanhToanService
@inject IJSRuntime JS
@inject NavigationManager Nav
<EditForm id="formDuAn" EditContext="@editContext">
    <h1 class="legend-title">Phiếu xác nhận thanh toán</h1>
    <div class="container-form">
        <div class="container-tabs">
            <div class="row">
                <div class="col-md-12">
                    <ul class="tab-element">
                        <li class="tab-item @(currentTab == 1 ? "actived-tab" : null)" data-id="1" id="linkTab1">Thông tin chung</li>
                        <li class="tab-item @(currentTab == 2 ? "actived-tab" : null)" data-id="2" id="linkTab2">Công nợ phải thu</li>
                        @if (Record.IsCanTruNguonKhac)
                        {
                            <li class="tab-item @(currentTab == 3 ? "actived-tab" : null)" data-id="3" id="linkTab3">Nguồn chuyển đổi</li>
                        }
                    </ul>
                </div>
            </div>
            <MessageErrorForm />
            <div class="wapper-content-tab" id="formDuAn">
                <div class="tab-content-item @(currentTab == 1 ? "actived-tab" : null)" data-id="1" id="tab1">
                    <div class="col-lg-10 mx-auto row">
                        <InfoList Items="@InfoItems" />
                        <div class="wapper-input col-lg-12">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Dự án <i class="point-validate">*</i></span>
                                    @if (string.IsNullOrEmpty(Record.MaDuAn))
                                    {
                                        <select id="MaDuAn" class="form-control input-validation" name="MaDuAn" @onchange="OnDuAnChanged">
                                            <option value=""> Chọn dự án </option>
                                            @if (ListDA?.Any() == true)
                                            {
                                                @foreach (var item in ListDA)
                                                {
                                                    <option value="@item.MaDuAn" selected="@(Record.MaDuAn == item.MaDuAn)">
                                                        @item.TenDuAn
                                                    </option>
                                                }
                                            }
                                        </select>
                                        <span class="error-validation">Vui lòng chọn dự án</span>
                                    }
                                    else
                                    {
                                        <div class="input-wraper-choose">
                                            <DisableTextBox Value="@Record.TenDuAn" />
                                            <div class="icon-choose right" @onclick="ClearDuAn">
                                                <i class="bi bi-x-lg"></i>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Số chứng từ <i class="point-validate">*</i></span>
                                    <input class="input-form input-validation" id="SoChungTu" name="SoChungTu" type="text" @bind="@Record.SoChungTu">
                                    <span class="error-validation">Vui lòng nhập số chứng từ</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Ngày hạch toán</span>
                                    <FlatpickrInput Id="NgayHachToan" Name="NgayHachToan" @bind-Value="Record.NgayHachToan"
                                                    Placeholder=""
                                                    CssClass="form-control datetime-picker"
                                                    Options="dateOptions" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Loại chứng từ <i class="point-validate">*</i></span>
                                    @if (string.IsNullOrEmpty(Record.MaKhachHang))
                                    {
                                        <select id="LoaiChungTu" class="form-control input-validation" name="LoaiChungTu" @onchange="OnLoaiPhieuChanged">
                                            <option value=""> Chọn loại chứng từ </option>
                                            <option value="T">
                                                Thu
                                            </option>
                                            <option value="C">
                                                Chi
                                            </option>
                                        </select>
                                    }
                                    else
                                    {
                                        <DisableTextBox Value="@(Record.LoaiPhieu == "T" ? "Thu" : "Chi")" />
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Hình thức thanh toán <i class="point-validate">*</i></span>
                                    <select id="MaHinhThucTT" class="form-control input-validation" name="MaHinhThucTT" @onchange="OnHTTTChanged">
                                        <option value=""> Chọn hình thức thanh toán </option>
                                        @if (ListHTTT?.Any() == true)
                                        {
                                            @foreach (var item in ListHTTT)
                                            {
                                                <option value="@($"{item.MaHttt}|{item.TenHttt}|{item.IsCanTruNguonKhac}")">
                                                    @item.TenHttt
                                                </option>
                                            }
                                        }
                                    </select>
                                    <span class="error-validation">Vui lòng chọn hình thức thanh toán</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Mã khách hàng <i class="point-validate">*</i></span>
                                    @if (string.IsNullOrEmpty(Record.MaKhachHang))
                                    {
                                        <div class="input-wraper-choose">
                                            <div class="icon-choose left" @onclick="ShowPopupKhachHang">
                                                <i class="bi bi-journal-plus"></i>
                                            </div>
                                            <input class="input-form input-validation" id="MaKhachHang" name="MaKhachHang" readonly="readonly" type="text" @bind="@Record.MaKhachHang">
                                            @if (!string.IsNullOrEmpty(Record.MaKhachHang))
                                            {
                                                <div class="icon-choose right" @onclick="ClearHD">
                                                    <i class="bi bi-x-lg"></i>
                                                </div>
                                            }
                                        </div>
                                        <span class="error-validation">Vui lòng chọn khách hàng</span>
                                    }
                                    else
                                    {
                                        <div class="item-phieu" @onclick="() => OnMaKHRecord(Record.MaKhachHang.ToString())">@Record.MaKhachHang</div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Tên khách hàng </span>
                                    <input class="input-form input-validation" id="TenKhachHang" name="TenKhachHang" readonly="readonly" type="text" value="@Record.TenKhachHang">
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-12">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Tập tin đính kèm</span>
                                    <div class="contatiner-upload-files">
                                        <FileUploader AllowExtensions="allowedExtensions"
                                                      MaxFileSize="10485760"
                                                      AllowMultiple="true"
                                                      OnFilesChanged="HandleFiles" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-12">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Ghi chú</span>
                                    <textarea class="textarea-input " cols="20" id="GhiChu" rows="3" tabindex="2" @bind="Record.NoiDung"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="tab-content-item @(currentTab == 2 ? "actived-tab" : null)" data-id="2" id="tab2">
                    <div class="col-lg-10 mx-auto row">
                        <InfoList Items="@InfoItems" />
                    </div>
                    <div class="col-lg-12 mx-auto row">
                        <div class="wapper-button-head-table mb-2" style="width: 100%">
                            <div class="button-action-title" style="margin-left: 0;">
                                <div class="icon-button" @onclick="AddCongNo">
                                    <i class="mdi mdi-playlist-plus"></i>
                                </div>
                                <span>Chi tiết</span>
                            </div>
                            <div style="margin-left: auto; display: flex; align-items: center;">
                            </div>

                        </div>
                        <table class="tbl table table-hover table-form table-detail" id="tblNhanViens">
                            <thead>
                                <tr>
                                    <th style="width: 50px" class="text-center">
                                        STT
                                    </th>
                                    <th style="width: 130px" class="text-center">
                                        Mã phiếu tham chiếu
                                    </th>
                                    <th style="width: 250px" class="text-center">
                                        Nội dung
                                    </th>
                                    <th style="width: 150px" class="text-center">
                                        Số tiền
                                    </th>
                                    <th style="width: 40px" class="text-center">
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="content-table">
                                @if (ListCN != null && ListCN.Any() == true)
                                {
                                    <Virtualize ItemsProvider="LoadChiTietCongNoProvider" Context="x" ItemSize="40" @ref="virtualizeRef">
                                        <tr>
                                            <td class="text-center">@((x.index + 1))</td>
                                            <td>
                                                <span class="item-phieu" @onclick="() => OnViewPCN(x.item.MaPhieuCongNo)">@x.item.MaPhieuCongNo</span>
                                            </td>
                                            <td>@(x.item.NoiDung)</td>
                                            <td class="text-right">
                                                <InputCurrency T="decimal"
                                                               Id=@($"SoTien{x.index + 1}")
                                                               Format="#,##0"
                                                               CssClass="input-form form-control input-validation select-on-click w-100 p-1 ms-2"
                                                               @bind-Value="x.item.SoTien"
                                                               @bind-Value:after="() => ClampSoTien(x.item)" />

                                            </td>
                                            <td class="text-center">
                                                <div class="icon-button" data-title="Xóa" data-position="left">
                                                    <a href="javascript:void(0)" @onclick="() => DeleteRowPCN(x.item)"><span><i class="mdi mdi-delete "></i></span></a>
                                                </div>
                                            </td>
                                        </tr>
                                    </Virtualize>
                                }
                                @if (ListCN != null && ListCN.Any())
                                {
                                    var tongSoTienTT = ListCN.Sum(x => (decimal?)x.SoTien ?? 0m);
                                    <tr class="row-total">
                                        <td></td>
                                        <td colspan="2" class="text-left">Tổng cộng</td>
                                        <td class="text-right">@string.Format("{0:N0}", tongSoTienTT)</td>
                                        <td></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                @if (Record.IsCanTruNguonKhac)
                {
                    <div class="tab-content-item @(currentTab == 3 ? "actived-tab" : null)" data-id="3" id="tab3">
                        <div class="col-lg-10 mx-auto row">
                            <InfoList Items="@InfoItems" />
                        </div>
                        <div class="col-lg-12 mx-auto row">
                            <div class="wapper-button-head-table mb-2" style="width: 100%">
                                <div class="button-action-title" style="margin-left: 0;">
                                    <div class="icon-button" @onclick="AddNCD">
                                        <i class="mdi mdi-playlist-plus"></i>
                                    </div>
                                    <span>Nguồn</span>
                                </div>
                                <div style="margin-left: auto; display: flex; align-items: center;">
                                </div>

                            </div>
                            <table class="tbl table table-hover table-form table-detail" id="tblNhanViens">
                                <thead>
                                    <tr>
                                        <th style="width: 50px" class="text-center">
                                            STT
                                        </th>
                                        <th style="width: 130px" class="text-center">
                                            Số phiếu
                                        </th>
                                        <th style="width: 130px" class="text-center">
                                            Ngày
                                        </th>
                                        <th style="width: 250px" class="text-center">
                                            Nội dung
                                        </th>
                                        <th style="width: 100px" class="text-center">Số tiền</th>
                                        <th style="width: 50px"></th>
                                    </tr>
                                </thead>
                                <tbody class="content-table">
                                    @if (ListNCD != null && ListNCD.Any() == true)
                                    {
                                        <Virtualize ItemsProvider="LoadChiTietNguonCDProvider" Context="x" ItemSize="40" @ref="virtualizeNCDRef">
                                            <tr>
                                                <td class="text-center">@((x.index + 1))</td>
                                                <td>
                                                    <span class="item-phieu" @onclick="() => OnViewPGC(x.item.MaPhieu)">@x.item.MaPhieu</span>
                                                </td>
                                                <td>
                                                    @string.Format("{0:dd/MM/yyyy}", x.item.Ngay)
                                                </td>
                                                <td>@(x.item.NoiDung)</td>
                                                <td class="text-right">@($"{x.item.SoTien:#,##0.##}")</td>
                                                <td class="text-center">
                                                    <div class="icon-button" data-title="Xóa" data-position="left">
                                                        <a href="javascript:void(0)" @onclick="() => DeleteRowNCD(x.item)"><span><i class="mdi mdi-delete "></i></span></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </Virtualize>
                                    }
                                    @if (ListNCD != null && ListNCD.Any())
                                    {
                                        var tongSoTienTT = ListNCD.Sum(x => (decimal?)x.SoTien ?? 0m);
                                        var tongSoTienCD = ListNCD.Sum(x => (decimal?)x.SoTienConLai ?? 0m);
                                        <tr class="row-total">
                                            <td></td>
                                            <td colspan="2" class="text-left">Tổng cộng</td>
                                            <td class="text-right">@string.Format("{0:N0}", tongSoTienTT)</td>
                                            <td class="text-right">@string.Format("{0:N0}", tongSoTienCD)</td>
                                            <td></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="container-button">
        <div class="actions-left">
            <UiButton Preset="back" Variant="secondary" OnClick="BackUrl" />
        </div>
        <div class="actions-right">
            <UiButton Preset="save" Variant="primary" OnClick="SubmitFormJs" />
        </div>
    </div>
</EditForm>
<PopupKhachHang @ref="khachHangModalRef" OnSelected="SelectedKhachHang" />
<PopupChiTietCongNo @ref="congNoModalRef" OnSelectedCTCN="SelectedCongNo" />
<PopupChiTietNguonChuyenDoi @ref="nguonCDModalRef" OnSelectedNCD="SelectedNCD" />
@code {
    private EditContext editContext;
    private PhieuXacNhanThanhToanModel? Record = new();
    private List<DaDanhMucDuAn> ListDA = new();
    private List<PhieuXacNhanThanhToanPhieuCongNoModel> ListCN = new();
    private List<PhieuXacNhanThanhToanNguonChuyenDoiModel> ListNCD = new();
    private List<HtDanhMucHinhThucThanhToan> ListHTTT = new();
    private string selectedHTTTRaw;
    private PopupKhachHang? khachHangModalRef;
    private PopupChiTietCongNo? congNoModalRef;
    private PopupChiTietNguonChuyenDoi? nguonCDModalRef;
    private string[] allowedExtensions = FileTypeSets.Document;
    private Virtualize<(PhieuXacNhanThanhToanPhieuCongNoModel item, int index)>? virtualizeRef;
    private Virtualize<(PhieuXacNhanThanhToanNguonChuyenDoiModel item, int index)>? virtualizeNCDRef;

    int currentTab = 1;
    void SwitchTab(int id) => currentTab = id;
    private object dateOptions = new
    {
        dateFormat = "d/m/Y",
        enableTime = false,
        todayButton = true
    };

    private List<InfoItem> InfoItems = new();
    private bool HasHopDong => !string.IsNullOrWhiteSpace(Record?.MaKhachHang);

    [SupplyParameterFromQuery(Name = "draft")]
    public string? Draft { get; set; }
    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(Record);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync("XacNhanThanhToan", VuViec.Them.GetDescription());
            await JS.InvokeVoidAsync("tabHelper.initTabs");
            await JS.InvokeVoidAsync("modalHelper.makeAllDraggable");

            var js = new System.Text.StringBuilder();
            js.AppendLine("setTimeout(function(){");

            if (string.IsNullOrEmpty(Record.MaDuAn))
            {
                js.AppendLine("  select2Helper.initSelectChange('MaDuAn','Chọn dự án',true);");
                js.AppendLine("  select2Helper.initSelectChange('LoaiChungTu','Chọn loại chứng từ',true);");
            }
            js.AppendLine("  select2Helper.initSelectChange('MaHinhThucTT','Chọn hình thức thanh toán',true);");
            js.AppendLine("}, 300);");

            await JS.InvokeVoidAsync("eval", js.ToString());


            ListDA = await HopDongChuyenNhuongService.GetByDuAnAsync();
            ListHTTT = await PhieuXacNhanThanhToanService.GetByHinhThucTTAsync();
            var result = await PhieuXacNhanThanhToanService.GetByIdAsync(string.Empty);
            if (result.Status)
            {
                Record = (PhieuXacNhanThanhToanModel)result.Data;
                if (!string.IsNullOrWhiteSpace(Draft))
                {
                    var draft = await PhieuXacNhanThanhToanService.GetDraftAsync(Draft);
                    if (draft != null)
                    {
                        // GÁN CỨNG
                        Record.MaDuAn = draft.MaDuAn;
                        Record.TenDuAn = draft.TenDuAn;
                        Record.MaKhachHang = draft.MaKhachHang;
                        Record.TenKhachHang = draft.TenKhachHang;
                        Record.LoaiPhieu = draft.LoaiPhieu;
                        // Tab2
                        ListCN = draft.ListCN ?? new();
                    }
                }
                InfoItems = new()
                {
                    new() { Text="Mã phiếu", Value=Record.MaPhieu},
                    new() { Text="Ngày lập", Value=string.Format("{0:dd/MM/yyyy}", Record.NgayLap)},
                    new() { Text="Người lập", Value=Record.NguoiLap.HoVaTen},
                };
            }
            StateHasChanged();
        }
        await JS.InvokeVoidAsync("tabHelper.initTabs");
    }

    private async Task OnDuAnChanged(ChangeEventArgs e)
    {
        await JS.InvokeVoidAsync("eval", "try { $('#MaDuAn').select2('destroy'); } catch(e) {}");
        var maDuAn = e.Value?.ToString();
        Record.MaDuAn = maDuAn;
        Record.TenDuAn = ListDA?.FirstOrDefault(x => x.MaDuAn == maDuAn)?.TenDuAn ?? string.Empty;
        ClearKHFields();
        StateHasChanged();
    }

    private async Task ClearDuAn()
    {
        Record.MaDuAn = string.Empty;
        Record.TenDuAn = string.Empty;
        ClearKHFields();
        StateHasChanged();
        await Task.Delay(50); // chờ Blazor render lại select trước khi init select2
        await JS.InvokeVoidAsync("eval", "try { select2Helper.initSelectChange('MaDuAn','Chọn dự án',true); } catch(e) {}");
    }

    private async Task OnLoaiPhieuChanged(ChangeEventArgs e)
    {
        await JS.InvokeVoidAsync("eval", "try { $('#LoaiChungTu').select2('destroy'); } catch(e) {}");
        Record.LoaiPhieu = e.Value?.ToString();
        ClearKHFields();               // reset các field phụ thuộc
        StateHasChanged();
    }

    private async Task OnHTTTChanged(ChangeEventArgs e)
    {
        selectedHTTTRaw = e.Value.ToString();
        if (!string.IsNullOrEmpty(selectedHTTTRaw))
        {
            var parts = selectedHTTTRaw.Split('|');
            if (parts.Length == 3)
            {
                Record.MaHinhThucTT = parts[0];
                Record.TenHinhThucTT = parts[1];
                Record.IsCanTruNguonKhac = Convert.ToBoolean(parts[2]);
                if (!Record.IsCanTruNguonKhac)
                {
                    ListNCD.Clear();
                }
            }
        }
    }

    private async Task SubmitFormJs()
    {
        var dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("validateFormBlazor", "formDuAn", dotNetRef);
    }

    [JSInvokable]
    public async Task SubmitForm()
    {
        if (!ValidateBeforeSave(out var msg))
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", msg, false);
            return;
        }
        Loading.Show();
        try
        {
            var result = await PhieuXacNhanThanhToanService.SavePhieuAsync(Record, ListCN, ListNCD);
            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
            if (result.Status)
            {
                if (!string.IsNullOrWhiteSpace(Draft))
                    await PhieuXacNhanThanhToanService.DeleteDraftAsync(Draft);
                Nav.NavigateTo($"/phieuxacnhanthanhtoan/edit/{result.Id}");
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", ex.Message, false);
        }
        finally
        {
            Loading.Hide();
        }
    }

    private void BackUrl()
    {
        Nav.NavigateTo("/phieuxacnhanthanhtoan");
    }

    public void HandleFiles(List<UploadedFileModel> files)
    {
        Record.Files = files;
    }

    private async Task ShowPopupKhachHang()
    {
        if (khachHangModalRef != null)
        {
            await khachHangModalRef.Show(Record.MaDuAn, Record.LoaiPhieu);
        }
    }

    private async Task SelectedKhachHang(PhieuXacNhanThanhToanPhieuCongNoModel? item)
    {
        Record.MaKhachHang = item.MaKhachHang;
        Record.TenKhachHang = item.TenKhachHang;
        ListCN.Clear();
        ListNCD.Clear();
        ListCN = new List<PhieuXacNhanThanhToanPhieuCongNoModel>();
        ListNCD = new List<PhieuXacNhanThanhToanNguonChuyenDoiModel>();
        StateHasChanged();
    }

    private async Task SelectedCongNo(List<PhieuXacNhanThanhToanPhieuCongNoModel?> listCH)
    {
        foreach (var item in listCH)
        {
            if (item == null) continue; // ✅ Bỏ qua dòng null
            bool isExist = ListCN.Any(x => x.MaPhieuCongNo == item.MaPhieuCongNo);
            if (!isExist)
            {
                ListCN.Add(new PhieuXacNhanThanhToanPhieuCongNoModel
                {
                    MaPhieuCongNo = item.MaPhieuCongNo,
                    IdChungTu = item.IdChungTu,
                    NoiDung = item.NoiDung,
                    SoTien = item.SoTien,
                    SoTienGoc = item.SoTien,
                });
            }
        }
        if (virtualizeRef != null)
        {
            await virtualizeRef.RefreshDataAsync();
        }
    }

    private async Task SelectedNCD(List<PhieuXacNhanThanhToanNguonChuyenDoiModel?> listCH)
    {
        foreach (var item in listCH)
        {
            if (item == null) continue; // ✅ Bỏ qua dòng null
            bool isExist = ListNCD.Any(x => x.MaPhieu == item.MaPhieu);
            if (!isExist)
            {
                ListNCD.Add(new PhieuXacNhanThanhToanNguonChuyenDoiModel
                {
                    MaPhieu = item.MaPhieu,
                    Ngay = item.Ngay,
                    NoiDung = item.NoiDung,
                    SoTien = item.SoTien,
                    SoTienConLai = item.SoTienConLai,
                });
            }
        }
        if (virtualizeNCDRef != null)
        {
            await virtualizeNCDRef.RefreshDataAsync();
        }
    }


