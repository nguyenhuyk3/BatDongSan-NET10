    private async Task SelectedCanTruDC(List<ChinhSachThanhToanChiTietModel>? selected)
    {
        if (_hdPickingCanTru is null) return;
        if (selected is null || selected.Count == 0) return;

        var hd = _hdPickingCanTru;

        Record.ListChinhSachHopDongCanTruDatCoc ??= new List<ChinhSachThanhToanHopDongChiTietCanTruDatCoc>();

        // ✅ xoá placeholder trống của đợt HĐ này
        Record.ListChinhSachHopDongCanTruDatCoc.RemoveAll(x =>
            x.DotTTHD == hd.DotTT && x.DotTTDC <= 0);

        // ✅ tập DotTTDC đã dùng toàn CSTT
        var usedDots = Record.ListChinhSachHopDongCanTruDatCoc
            .Where(x => x.DotTTDC > 0)
            .Select(x => x.DotTTDC)
            .ToHashSet();

        var added = 0;
        var skippedUsed = 0;
        var skippedOver = new List<int>(); // các dot bị vượt %

        // ✅ distinct theo DotTT (đợt đặt cọc)
        var pickList = selected
            .Where(x => x.DotTT > 0)
            .GroupBy(x => x.DotTT)
            .Select(g => g.First())
            .OrderBy(x => x.DotTT)
            .ToList();

        foreach (var dc in pickList)
        {
            // 1) đã dùng rồi => skip
            if (usedDots.Contains(dc.DotTT))
            {
                skippedUsed++;
                continue;
            }

            // 2) check vượt % hợp đồng => không cho add
            var percent = (decimal)(dc.TyLeTTDatCoc ?? 0);
            if (!CanAddCanTruPercent(hd, percent))
            {
                skippedOver.Add(dc.DotTT);
                continue;
            }

            // 3) add đúng tỷ lệ DB (không sửa)
            Record.ListChinhSachHopDongCanTruDatCoc.Add(new ChinhSachThanhToanHopDongChiTietCanTruDatCoc
            {
                MaCSTT = Record.MaCSTT ?? string.Empty,

                DotTTHD = hd.DotTT,
                NoiDungTTHD = hd.NoiDungTT,
                TyLeTTHD = hd.TyLeTTHopDong,

                DotTTDC = dc.DotTT,
                NoiDungTTDC = dc.NoiDungTT,
                TyLeTTDC = dc.TyLeTTDatCoc ?? 0
            });

            usedDots.Add(dc.DotTT);
            added++;
        }

        // Toast thông báo
        if (skippedUsed > 0)
            await JS.InvokeVoidAsync("showToast", "Thông báo",
                $"Có {skippedUsed} đợt đặt cọc đã được cấn trừ trước đó nên không thể chọn lại.", false);

        if (skippedOver.Count > 0)
            await JS.InvokeVoidAsync("showToast", "Thông báo",
                $"Không thể thêm các đợt: {string.Join(", ", skippedOver.Select(x => $"Đợt {x}"))} vì tổng tỷ lệ cấn trừ vượt tỷ lệ hợp đồng.", false);

        if (added > 0)
            await JS.InvokeVoidAsync("showToast", "Thông báo",
                $"Đã thêm {added} đợt đặt cọc vào đợt HĐ {hd.DotTT}.", true);

        StateHasChanged();
    }

    private bool CanAddCanTruPercent(ChinhSachThanhToanHopDongChiTietModel hd, decimal newPercent)
    {
        if (Record.ListChinhSachHopDongCanTruDatCoc is null) return newPercent <= (decimal)(hd.TyLeTTHopDong ?? 0);

        var max = (decimal)(hd.TyLeTTHopDong ?? 0);

        var currentSum = Record.ListChinhSachHopDongCanTruDatCoc
            .Where(x => x.DotTTHD == hd.DotTT && x.DotTTDC > 0)
            .Sum(x => x.TyLeTTDC ?? 0);

        return currentSum + newPercent <= max;
    }
