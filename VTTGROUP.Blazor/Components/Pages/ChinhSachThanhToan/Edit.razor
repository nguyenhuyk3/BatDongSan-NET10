    private bool IsDotThamChieuHopLe()
    {
        var listDotTT = Record.ListChinhSachThanhToan
                             .Select(x => x.DotTT)
                             .Distinct()
                             .ToHashSet();

        bool hasError = false;

        foreach (var item in Record.ListChinhSachThanhToan)
        {
            if (!listDotTT.Contains(item.DotThamChieu))
            {
                item.IsDotThamChieuInvalid = true; // Gắn cờ lỗi
                hasError = true;
                // _ = JS.InvokeVoidAsync("showToast", "Lỗi", $"Đợt tham chiếu {item.DotThamChieu} không hợp lệ!", "error");
            }
            else
            {
                item.IsDotThamChieuInvalid = false;
            }
        }

        return !hasError;
    }

