    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync(MaCongViec, VuViec.CapNhat.GetDescription());
            await JS.InvokeVoidAsync("tabHelper.initTabs");
            await JS.InvokeVoidAsync("modalHelper.makeAllDraggable");
            var result = await HopDongMuaBanService.GetByIdAsync(id);
            if (result.Status)
            {
                Record = (HopDongMuaBanModel)result.Data;
                InfoItems = new()
                {
                    new() { Text="Mã phiếu", Value=Record.MaHopDong},
                    new() { Text="Ngày lập", Value=string.Format("{0:dd/MM/yyyy}", Record.NgayLap)},
                    new() { Text="Người lập", Value=Record.NguoiLap.HoVaTen},
                    new() { Text="Dự án", Value=Record.TenDuAn, LargeWidth = true},
                };
                if (Record?.Files?.Any() == true)
                {
                    await uploaderRef.RenderInitialFiles(Record.Files, (Record.FlagTong == true ? false : true));
                    // await uploaderRef.RenderInitialFiles(Record.Files, (((Record.FlagTong || Record.IsDaKy == false) == true) ? false : true));
                }
                uploaderRef.IsDuyet = (Record.FlagTong == true ? false : true);
                // uploaderRef.IsDuyet = (((Record.FlagTong || Record.IsDaKy == false) == true) ? false : true);
            }
            ListTDTT = await HopDongMuaBanService.GetByTienDoThanhToanAsync(string.Empty, Record.MaHopDong, string.Empty);
            maNhanVienHT = await BaseService.MaNhanVienHienTai();
            // Reload thông tin mới nhất của từng khách hàng từ DB
            if (Record.ListKHDongSoHuu?.Any() == true)
            {
                foreach (var kh in Record.ListKHDongSoHuu)
                {
                    await ReloadKhachHang(kh);
                }
            }
            StateHasChanged();
        }
    }

