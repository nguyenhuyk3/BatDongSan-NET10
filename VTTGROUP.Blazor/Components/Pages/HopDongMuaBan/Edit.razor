    public async Task SelectedKhachHang(List<KhachHangPagingDto?> listCSTT)
    {
        foreach (var nv in listCSTT)
        {
            bool isExist = Record.ListKHDongSoHuu.Any(x => x.MaKhachHang == nv.MaKhachHang);
            if (!isExist)
            {
                Record.ListKHDongSoHuu.Add(new KhachHangDongSoHuuHopDong
                {
                    MaKhachHang = nv.MaKhachHang,
                    TenKhachHang = nv.TenKhachHang,
                    IdCard = nv.IdCard,
                    SoDienThoai = nv.SoDienThoai,
                    Email = nv.Email,
                    DiaChiLienLac = nv.DiaChiLienLac,
                    IDLanDieuChinh = nv.IDLanDieuChinh,
                    ISKhachHangDaiDien = false,
                });
            }
        }
        StateHasChanged();
    }

    private async Task DeleteRow(KhachHangDongSoHuuHopDong? item)
    {
        Record.ListKHDongSoHuu.Remove(item);
        StateHasChanged();
    }
    private async Task ChonDaiDien(KhachHangDongSoHuuHopDong? item)
    {
        // reset tất cả về false
        foreach (var kh in Record.ListKHDongSoHuu)
        {
            kh.ISKhachHangDaiDien = false;
        }

        // gán lại người vừa chọn
        item.ISKhachHangDaiDien = true;
    }

