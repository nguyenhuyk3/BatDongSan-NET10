    private async Task ThongTinPhieuDC(string maPhieuDC)
    {
        var entity2 = await HopDongMuaBanService.GetByPhieuDatCocChuaLenHopDongAsync(maPhieuDC);
        Record.MaPhieuDC = maPhieuDC;
        Record.MaCanHo = entity2.MaCanHo;
        Record.TenCanHo = entity2.TenSanPham;
        Record.MaChinhSachTT = entity2.MaChinhSachTT;
        Record.DotMoBan = entity2.MaDotMoBan;
        Record.TenDotMoBan = entity2.TenDuAn;
        Record.TenChinhSachTT = entity2.TenCSTT;
        Record.MaDuAn = entity2.MaDuAn;
        Record.TenDuAn = entity2.TenDuAn;

        var entity = await HopDongMuaBanService.ThongTinKhachHang(string.Empty, Record.MaPhieuDC, Record.MaDuAn, string.Empty);
        Record.MaKhachHang = entity.MaKhachHang;
        Record.TenKhachHang = entity.TenKhachHang;
        Record.NgaySinh = !string.IsNullOrEmpty(entity.NgaySinh) ? DateTime.ParseExact(entity.NgaySinh, "dd/MM/yyyy", CultureInfo.InvariantCulture) : (DateTime?)null;
        Record.SoDienThoai = entity.SoDienThoai;
        Record.IDCard = entity.IdCard;
        Record.NgayCap = !string.IsNullOrEmpty(entity.NgayCapIdCard) ? DateTime.ParseExact(entity.NgayCapIdCard, "dd/MM/yyyy", CultureInfo.InvariantCulture) : (DateTime?)null;
        Record.NoiCap = entity.NoiCapIdCard;
        Record.DiaChiThuongTru = entity.DiaChiThuongTru;
        Record.DiaChiHienNay = entity.DiaChiHienNay;
        Record.DienTichTimTuong = entity.DienTichTimTuong;
        Record.DienTichSanVuon = entity.DienTichSanVuon;
        Record.DienTichLotLong = entity.DienTichLotLong;
        Record.GiaDat = entity.GiaDat;
        Record.DonGiaDat = entity.DonGiaDat;
        Record.GiaCanHoTruocThue = entity.GiaCanHoTruocThue;
        Record.TyLeThueVAT = entity.TyLeThueVAT;
        Record.GiaCanHoSauThue = entity.GiaCanHoSauThue;
        Record.TyLeCK = entity.TyLeCK;
        Record.GiaTriCK = entity.GiaTriCK;
        Record.GiaBanTruocThue = entity.GiaBanTruocThue;
        Record.GiaBanTienThue = entity.GiaBanTienThue;
        Record.GiaBanSauThue = entity.GiaBanSauThue;
        Record.TyLeQuyBaoTri = entity.TyLeQuyBaoTri;
        Record.TienQuyBaoTri = entity.TienQuyBaoTri;
        Record.IDLanDieuChinhKH = entity.IDKhachHangCT;
        ListMI = await HopDongMuaBanService.GetByMauInAsync(Record.MaDuAn);
        ListTDTT = await HopDongMuaBanService.GetByTienDoThanhToanAsync(Record.MaChinhSachTT, String.Empty, Record.MaPhieuDC);

        var newKH = new KhachHangDongSoHuuHopDong
        {
            MaKhachHang = entity.MaKhachHang,
            TenKhachHang = entity.TenKhachHang,
            IdCard = entity.IdCard,
            SoDienThoai = entity.SoDienThoai,
            Email = entity.Email,
            DiaChiLienLac = entity.DiaChiHienNay,
            IDLanDieuChinh = entity.IDKhachHangCT,
            ISKhachHangDaiDien = true,
        };
        Record.ListKHDongSoHuu.Add(newKH);

        // Reload lại từ DB để lấy thông tin đầy đủ nhất
        await ReloadKhachHang(newKH);
    }

    private async Task OnPhieuDKChanged(ChangeEventArgs e)
    {
        selectedPDKRaw = e.Value.ToString();
        if (!string.IsNullOrEmpty(selectedPDKRaw))
        {
            var parts = selectedPDKRaw.Split('|');
            if (parts.Length == 7)
            {
                Record.MaPhieuDC = parts[0];
                Record.MaCanHo = parts[1];
                Record.TenCanHo = parts[2];
                Record.MaChinhSachTT = parts[3];
                Record.DotMoBan = parts[4];
                Record.TenDotMoBan = parts[5];
                Record.TenChinhSachTT = parts[6];
            }
        }
        else
        {
            Record.MaPhieuDC = string.Empty;
        }
        var entity = await HopDongMuaBanService.ThongTinKhachHang(string.Empty, Record.MaPhieuDC, Record.MaDuAn, string.Empty);
        Record.MaKhachHang = entity.MaKhachHang;
        Record.TenKhachHang = entity.TenKhachHang;
        Record.NgaySinh = !string.IsNullOrEmpty(entity.NgaySinh) ? DateTime.ParseExact(entity.NgaySinh, "dd/MM/yyyy", CultureInfo.InvariantCulture) : (DateTime?)null;
        Record.SoDienThoai = entity.SoDienThoai;
        Record.IDCard = entity.IdCard;
        Record.NgayCap = !string.IsNullOrEmpty(entity.NgayCapIdCard) ? DateTime.ParseExact(entity.NgayCapIdCard, "dd/MM/yyyy", CultureInfo.InvariantCulture) : (DateTime?)null;
        Record.NoiCap = entity.NoiCapIdCard;
        Record.DiaChiThuongTru = entity.DiaChiThuongTru;
        Record.DiaChiHienNay = entity.DiaChiHienNay;
        Record.DienTichTimTuong = entity.DienTichTimTuong;
        Record.DienTichSanVuon = entity.DienTichSanVuon;
        Record.DienTichLotLong = entity.DienTichLotLong;
        Record.GiaDat = entity.GiaDat;
        Record.DonGiaDat = entity.DonGiaDat;
        Record.GiaCanHoTruocThue = entity.GiaCanHoTruocThue;
        Record.TyLeThueVAT = entity.TyLeThueVAT;
        Record.GiaCanHoSauThue = entity.GiaCanHoSauThue;
        Record.TyLeCK = entity.TyLeCK;
        Record.GiaTriCK = entity.GiaTriCK;
        Record.GiaBanTruocThue = entity.GiaBanTruocThue;
        Record.GiaBanTienThue = entity.GiaBanTienThue;
        Record.GiaBanSauThue = entity.GiaBanSauThue;
        Record.TyLeQuyBaoTri = entity.TyLeQuyBaoTri;
        Record.TienQuyBaoTri = entity.TienQuyBaoTri;
        Record.IDLanDieuChinhKH = entity.IDKhachHangCT;
        ListTDTT = await HopDongMuaBanService.GetByTienDoThanhToanAsync(Record.MaChinhSachTT, String.Empty, Record.MaPhieuDC);

        // Xóa KH cũ nếu có (tránh trùng khi đổi phiếu DC)
        Record.ListKHDongSoHuu.RemoveAll(x => x.MaKhachHang == entity.MaKhachHang);

        var newKH = new KhachHangDongSoHuuHopDong
        {
            MaKhachHang = entity.MaKhachHang,
            TenKhachHang = entity.TenKhachHang,
            IdCard = entity.IdCard,
            SoDienThoai = entity.SoDienThoai,
            Email = entity.Email,
            DiaChiLienLac = entity.DiaChiHienNay,
            IDLanDieuChinh = entity.IDKhachHangCT,
            ISKhachHangDaiDien = true,
        };
        Record.ListKHDongSoHuu.Add(newKH);

        // Reload lại từ DB để lấy thông tin mới nhất
        await ReloadKhachHang(newKH);
        StateHasChanged();
    }

