            await JS.InvokeVoidAsync("tabHelper.initTabs");
            await JS.InvokeVoidAsync("eval", @"
            setTimeout(function() { 
                select2Helper.initSelectChange('MaDuAn', 'Chọn dự án', true);
                select2Helper.initSelectChange('MaPhieuDC', 'Chọn phiếu đặt cọc', true);
                select2Helper.initSelectChange('MaMauIn', 'Chọn mẫu in', true);
            }, 300);");
            var result = await HopDongMuaBanService.GetByIdAsync(string.Empty);
            if (result.Status)
            {
                Record = (HopDongMuaBanModel)result.Data;
            }
            if (!string.IsNullOrEmpty(id))
            {
                Record.FlagDC = "1";
                await ThongTinPhieuDC(id);
            }
            else
            {
                ListDA = await PhieuGiuChoService.GetByDuAnAsync();
                ListPDK = await HopDongMuaBanService.GetByPhieuDatCocChuaLenHDAsync(Record.MaDuAn);
            }
            InfoItems = new()
