    # region Hiển thị popup và cập nhập thông tin khách hàng

    // Hiển thị popup
    private async Task OpenCapNhatKhachHang(string? maKhachHang)
    {
        if (string.IsNullOrWhiteSpace(maKhachHang) || popupCapNhatKHRef == null)
        {
            return;
        }

        await popupCapNhatKHRef.Show(maKhachHang);
    }

    // Tải lại thông tin khách hàng sau khi cập nhập
    private async Task ReloadKhachHang(KhachHangDongSoHuuHopDong? item)
    {
        if (item == null) return;

        Loading.Show();

        try
        {
            var result = await DMKhachHangService.GetByIdAsync(item.MaKhachHang);

            if (result.Status && result.Data is KhachHangTamModel khachHang)
            {
                item.TenKhachHang = khachHang.TenKhachHang;
                item.IdCard = khachHang.IdCard;
                item.SoDienThoai = khachHang.SoDienThoai;
                item.Email = khachHang.Email;
                item.DiaChiLienLac = khachHang.DiaChiHienNay;
                item.IDLanDieuChinh = khachHang.IDLanDieuChinh;

                StateHasChanged();
            }
        }
        finally
        {
            Loading.Hide();
        }
    }

    // Lưu thông tin khách hàng
    private async Task OnKhachHangSaved(string maKhachHang)
    {
        // Reload lại thông tin khách hàng đã cập nhật trong bảng đồng sở hữu
        var item = Record.ListKHDongSoHuu.FirstOrDefault(x => x.MaKhachHang == maKhachHang);

        if (item != null)
        {
            await ReloadKhachHang(item);
        }

        // Đồng bộ lại danh sách trong PopupKhachHang nếu đang mở (giống Edit.razor)
        if (popupRef != null)
        {
            var result = await DMKhachHangService.GetByIdAsync(maKhachHang);
            if (result.Status && result.Data is KhachHangTamModel khachHang)
            {
                await popupRef.RefreshKhachHang(maKhachHang, khachHang);
            }
        }
    }

