@page "/loaigoc/edit/{id}"
@using System.Text.Json
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model.LoaiGoc
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Model
@inject BlockService BlockService
@inject LoaiGocService LoaiGocService
@inject IBaseService BaseService
@inject IJSRuntime JS
@inject NavigationManager Nav

<h1 class="legend-title">Loại góc</h1>
<div class="container-form">
    <div class="container-tabs">
        <div class="row">
            <div class="col-md-12">
            </div>
        </div>
        <MessageErrorForm />
        <div class="wapper-content-tab">
            <div data-id="1" class="tab-content-item actived-tab" id="tab1">
                <div class="col-lg-10 mx-auto row">
                    <div class="wapper-input col-lg-6">
                        <div class="row">
                            <div class="form-group-input">
                                <span class="title-field">Dự án <i class="point-validate">*</i></span>
                                <DisableTextBox Value="@Record.TenDuAn" />
                            </div>
                        </div>
                    </div>
                    <div class="wapper-input col-lg-6">
                        <div class="row">
                            <div class="form-group-input">
                                <span class="title-field">Mã góc</span>
                                <DisableTextBox Value="@Record.MaLoaiGoc" />
                                <input id="MaTang" name="MaLoaiGoc" type="hidden" value="@Record.MaLoaiGoc">
                            </div>
                        </div>

                    </div>
                    <div class="wapper-input col-lg-6">
                        <div class="row">
                            <div class="form-group-input">
                                <span class="title-field">Tên góc <i class="point-validate">*</i></span>
                                <input class="input-form input-validation" id="TenLoaiGoc" name="TenLoaiGoc" type="text" value="@Record.TenLoaiGoc">
                                <span class="error-validation">Vui lòng nhập tên góc</span>
                            </div>
                        </div>
                    </div>

                    <div class="wapper-input col-lg-6">
                        <div class="row">
                            <div class="form-group-input">
                                <span class="title-field">Hệ số <i class="point-validate">*</i></span>
                                <input class="input-form input-validation" id="HeSoGoc" name="HeSoGoc" style="width:40px;text-align:right" type="text" value="@string.Format("{0:#,#0.####}", Record.HeSoGoc)">
                                <span class="error-validation">Vui lòng nhập hệ số</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container-button">
    <div class="actions-left">
        <UiButton Preset="back" Variant="secondary" OnClick="BackUrl" />
    </div>
    <div class="actions-right">
        <UiButton Preset="save" Variant="primary" OnClick="SubmitFormJs" />
    </div>
</div>
@code {
    [Parameter]
    public string? id { get; set; }
    private LoaiGocModel? Selected = new();
    private LoaiGocModel? Record = new();
    private List<DaDanhMucDuAn> ListDA = new();

    protected override async Task OnInitializedAsync()
    {
        var result = await LoaiGocService.GetByIdAsync(id ?? string.Empty);
        ListDA = await BlockService.GetByDuAnAsync();
        if (result.Status)
        {
            Record = (LoaiGocModel?)result.Data;
            if (Record == null)
            {
                Record = new LoaiGocModel();
            }
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync("KhuVuc", VuViec.CapNhat.GetDescription());
            await JS.InvokeVoidAsync("select2Helper.initWithPlaceholder", "MaDuAn", "Chọn dự án", true);
            await JS.InvokeVoidAsync("InputUtils.makeCurrencyFormat", "HeSoGoc", 18, 4);
            if (!string.IsNullOrEmpty(Record.MaDuAn))
            {
                await JS.InvokeVoidAsync("select2Helper.setValue", "MaDuAn", Record.MaDuAn.ToString());
            }
        }
    }

    private async Task SubmitFormJs()
    {
        var dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("validateForm", "tab1", dotNetRef);

    }

    [JSInvokable]
    public async Task SubmitForm(Dictionary<string, JsonElement> data)
    {
        var model = new LoaiGocModel
        {
            MaLoaiGoc = data.GetValueOrDefault("MaLoaiGoc").GetString(),
            TenLoaiGoc = data.GetValueOrDefault("TenLoaiGoc").GetString(),
            HeSoGoc = Convert.ToDecimal(data.GetValueOrDefault("HeSoGoc").GetString())
        };
        var result = await LoaiGocService.UpdateByIdAsync(model);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
    }
    private void BackUrl()
    {
        Nav.NavigateTo("/loaigoc");

    }
}
