    // ==== CORE: tính DuocChon theo công thức mới (CSTT dùng tổng CSKM) ====
    private void RecalcChosenValues()
    {
        if (Record?.ListPDKCSBH == null) return;

        var giaBanTruocThue = Record.GiaBanTruocThue ?? 0m;
        var giaBanChinhThucTruocThue = Record.GiaBanChinhThucTruocThue ?? 0m;
        var ptt = GetPhuongThucTinhCk(); // 1 hoặc 2

        // reset toàn bộ trước
        foreach (var it in Record.ListPDKCSBH)
        {
            it.ThanhTienKMGiaBanDuocChon = 0m;
            it.ThanhTienKMGiaBanChinhThucDuocChon = 0m;
        }

        static string Norm(string? s) => (s ?? "").Trim().ToUpperInvariant();

        // =========================
        // PASS 1: Tính nhóm CSKM (và CSTT có IsCheckBox=1 xem như CSKM)
        // =========================
        var rowsAsCSKM = Record.ListPDKCSBH
            .Where(x =>
            {
                var loai = Norm(x.LoaiCS);
                return loai == "CSKM" || (loai == "CSTT" && x.IsCheckBox == true); // CSTT tick => tính như CSKM
            })
            .OrderBy(x => x.SttUuTien)
            .ThenBy(x => x.MaCS)
            .ToList();

        decimal tongCSKM_Capped = 0m;
        decimal tongCSKM_Official = 0m;

        foreach (var r in rowsAsCSKM)
        {
            if (!r.IsChon)
            {
                r.ThanhTienKMGiaBanDuocChon = 0m;
                r.ThanhTienKMGiaBanChinhThucDuocChon = 0m;
                continue;
            }

            var ht = Norm(r.HinhThucKM); // QT/TM/TL
            var giaTriKM = r.GiaTriKM ?? 0m;

            decimal chosenCapped = 0m;
            decimal chosenOfficial = 0m;

            if (ht == "QT")
            {
                chosenCapped = giaTriKM;
                chosenOfficial = giaTriKM;
            }
            else if (ht == "TM" && r.IsCKTyLe == false)
            {
                chosenCapped = giaTriKM;
                chosenOfficial = giaTriKM;
            }
            else
            {
                // tỷ lệ
                if (ptt == 2)
                {
                    var baseCapped = Math.Max(0m, giaBanTruocThue - tongCSKM_Capped);
                    var baseOfficial = Math.Max(0m, giaBanChinhThucTruocThue - tongCSKM_Official);

                    chosenCapped = baseCapped * giaTriKM / 100m;
                    chosenOfficial = baseOfficial * giaTriKM / 100m;
                }
                else
                {
                    chosenCapped = giaBanTruocThue * giaTriKM / 100m;
                    chosenOfficial = giaBanChinhThucTruocThue * giaTriKM / 100m;
                }
            }

            r.ThanhTienKMGiaBanDuocChon = Math.Round(chosenCapped, 0, MidpointRounding.AwayFromZero);
            r.ThanhTienKMGiaBanChinhThucDuocChon = Math.Round(chosenOfficial, 0, MidpointRounding.AwayFromZero);

            tongCSKM_Capped += r.ThanhTienKMGiaBanDuocChon ?? 0m;
            tongCSKM_Official += r.ThanhTienKMGiaBanChinhThucDuocChon ?? 0m;
        }

        // =========================
        // PASS 2: Tính nhóm CSTT thật (IsCheckBox=0)
        // =========================
        var rowsCSTT = Record.ListPDKCSBH
            .Where(x => Norm(x.LoaiCS) == "CSTT" && x.IsCheckBox == false)
            .OrderBy(x => x.SttUuTien)
            .ThenBy(x => x.MaCS)
            .ToList();

        foreach (var r in rowsCSTT)
        {
            if (!r.IsChon)
            {
                r.ThanhTienKMGiaBanDuocChon = 0m;
                r.ThanhTienKMGiaBanChinhThucDuocChon = 0m;
                continue;
            }

            var ht = Norm(r.HinhThucKM); // QT/TM/TL
            var giaTriKM = r.GiaTriKM ?? 0m;

            decimal chosenCapped = 0m;
            decimal chosenOfficial = 0m;

            if (ht == "QT")
            {
                chosenCapped = giaTriKM;
                chosenOfficial = giaTriKM;
            }
            else if (ht == "TM" && r.IsCKTyLe == false)
            {
                // tiền mặt cố định
                chosenCapped = giaTriKM;
                chosenOfficial = giaTriKM;
            }
            else
            {
                // ====== ĐIỀU KIỆN CUỐI CÙNG MỚI (CSTT là CSTT) ======
                // Base = Giá bán - Tổng được chọn của CSKM (không trừ theo CSTT trước đó)
                var baseCapped = Math.Max(0m, giaBanTruocThue - tongCSKM_Capped);
                var baseOfficial = Math.Max(0m, giaBanChinhThucTruocThue - tongCSKM_Official);

                chosenCapped = baseCapped * giaTriKM / 100m;
                chosenOfficial = baseOfficial * giaTriKM / 100m;
            }

            r.ThanhTienKMGiaBanDuocChon = Math.Round(chosenCapped, 0, MidpointRounding.AwayFromZero);
            r.ThanhTienKMGiaBanChinhThucDuocChon = Math.Round(chosenOfficial, 0, MidpointRounding.AwayFromZero);
        }

        // Các nhóm khác (nếu có) bạn có thể giữ y như cũ.
    }

    // ==== Tổng theo công thức mới ====
    private decimal TongUuDaiDuKien =>
        Record?.ListPDKCSBH?.Sum(x => x.ThanhTienKMGiaBanDuocChon ?? 0m) ?? 0m;

    private decimal GiaBanSauUuDai =>
        Math.Max(0m, (Record?.GiaBanTruocThue ?? 0m) - TongUuDaiDuKien);

