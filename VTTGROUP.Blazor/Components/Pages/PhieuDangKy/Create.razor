@page "/phieudangky/create/{id}"
@using System.Text.Json
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model.CanHo
@using VTTGROUP.Domain.Model.GioHang
@using VTTGROUP.Domain.Model.KhachHang
@using VTTGROUP.Domain.Model.KhachHangTam
@using VTTGROUP.Domain.Model.PhieuDangKy
@using VTTGROUP.Domain.Model.KeHoachBanHang
@using VTTGROUP.Domain.Model.PhieuGiuCho
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Model
@inject IBaseService BaseService
@inject CanHoService CanHoService
@inject PhieuDangKyService PhieuDangKyService
@inject LoadingService Loading
@inject IJSRuntime JS
@inject NavigationManager Nav

<h1 class="legend-title">Phiếu giữ chỗ</h1>
<EditForm id="formDuAn" EditContext="@editContext">
    <div class="container-form">
        <div class="container-tabs">
            <MessageErrorForm />
            <div class="wapper-content-tab">
                <div data-id="1" class="tab-content-item actived-tab" id="tab1">
                    <div class="col-lg-10 mx-auto row">
                        <InfoList Items="@InfoItems" />
                        <div class="col-lg-12">
                            <div class="section-head">
                                <span class="section-head__text">Thông tin sản phẩm</span>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Căn hộ</span>
                                    <div class="item-phieu"><span class="input-value" @onclick="() => OnViewCH(Record.MaCanHo)">@Record.TenCanHo</span></div>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Diện tích tim tường</span>
                                    <DisableTextBox Class="is-right" Value="@string.Format("{0:N2}", Record.DienTichCanHo)" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Diện tích thông thủy</span>
                                    <DisableTextBox Class="is-right" Value="@string.Format("{0:N2}", Record.DienTichLotLong)" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Diện tích sân vườn</span>
                                    <DisableTextBox Class="is-right" Value="@string.Format("{0:N2}", Record.DienTichSanVuon)" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Giá bán trước thuế</span>
                                    <DisableTextBox Class="is-right" Value="@string.Format("{0:N0}", Record.GiaBanTruocThue)" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Giá bán sau thuế</span>
                                    <DisableTextBox Class="is-right" Value="@string.Format("{0:N0}", Record.GiaBan)" />
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="section-head">
                                <span class="section-head__text">Chính sách bán hàng</span>
                            </div>
                        </div>
                        <div class="table-responsive table-responsive-soft">
                            <table class="tbl table table-form table-detail table-policy" id="table-data">
                                <thead>
                                    <tr>
                                        <th style="text-align:center">Nhóm loại</th>
                                        <th style="text-align:center">STT</th>
                                        <th style="text-align:center">Ưu đãi</th>
                                        <th style="text-align:center">Thành tiền/Tỷ lệ</th>
                                     @*    <th style="text-align:center">Giá trị ưu đãi theo chính sách</th> *@
                                        <th style="text-align:center">Giá trị ưu đãi chọn</th>
                                        <th></th>
                                    </tr>
                                </thead>

                                @if (Record?.ListPDKCSBH?.Any() == true)
                                {
                                    var items = Record.ListPDKCSBH;

                                    var groups = items
                                    .GroupBy(x => new { x.LoaiCS, x.TenLoaiCS })
                                    .OrderBy(g => OrderLoai(g.Key.LoaiCS))
                                    .ThenBy(g => g.Key.TenLoaiCS)
                                    .ToList();

                                    @foreach (var g in groups)
                                    {
                                        // giữ thứ tự ưu tiên
                                        var rows = g.OrderBy(x => x.SttUuTien).ThenBy(x => x.MaCS).ToList();

                                        <tbody class="content-table booking-group">
                                            @for (int i = 0; i < rows.Count; i++)
                                            {
                                                var r = rows[i];

                                                <tr @key="r.MaCS">
                                                    @if (i == 0)
                                                    {
                                                        <td rowspan="@rows.Count">@r.TenLoaiCS</td>
                                                    }

                                                    <td style="text-align:center">@(r.SttUuTien)</td>
                                                    <td>@r.TenCS</td>

                                                    <td class="text-right">@FormatGiaTriKM(r)</td>

                                                    @* <td class="text-right">@((r.ThanhTienKMGiaBan ?? 0m).ToString("N0"))</td> *@

                                                    <td class="text-right">@((r.ThanhTienKMGiaBanDuocChon ?? 0m).ToString("N0"))</td>

                                                    <td style="text-align:center">
                                                        @if (!r.IsCheckBox) @* radio *@
                                                        {
                                                            <input type="radio"
                                                                   class="form-check-input"
                                                                   name="CSTT"
                                                                   checked="@r.IsChon"
                                                                   @onchange="@(_ => SelectCstt(r))" />
                                                        }
                                                        else
                                                        @* checkbox *@
                                                        {
                                                            <input type="checkbox"
                                                                   class="form-check-input"
                                                                   checked="@r.IsChon"
                                                                   @onchange="@((ChangeEventArgs e) => ToggleCskm(r, e))" />
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    }

                                    <tbody class="content-table">
                                        <tr class="row-total">
                                            <td colspan="4" class="text-left">Tổng ưu đãi dự kiến</td>
                                            <td class="text-right">@TongUuDaiDuKien.ToString("N0")</td>
                                            <td></td>
                                        </tr>
                                        <tr class="row-total">
                                            <td colspan="4" class="text-left">Giá bán sau ưu đãi (chưa VAT)</td>
                                            <td class="text-right">@GiaBanSauUuDai.ToString("N0")</td>
                                            <td></td>
                                        </tr>
                                    </tbody>
                                }
                                else
                                {
                                    <tbody>
                                        <tr>
                                            <td colspan="7" class="text-center text-muted">Không có dữ liệu chính sách.</td>
                                        </tr>
                                    </tbody>
                                }
                            </table>

                        </div>

                        <div class="col-12">
                            <div class="section-head">
                                <span class="section-head__text">Thông tin khách hàng</span>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Phiếu booking</span>
                                    <div class="input-wraper-choose">
                                        <div class="icon-choose left" @onclick="AddPhieuGC">
                                            <i class="bi bi-journal-plus"></i>
                                        </div>
                                        <input class="input-form" id="MaPhieuBooking" name="MaPhieuBooking" readonly="readonly" type="text" @bind="@Record.MaPhieuBooking">
                                        @if (!string.IsNullOrEmpty(Record.MaPhieuBooking))
                                        {
                                            <div class="icon-choose right" @onclick="ClearPhieuGiuCho">
                                                <i class="bi bi-x-lg"></i>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Khách hàng</span>
                                    <div class="input-wraper-choose">
                                        <div class="icon-choose left" @onclick="ShowPopupKhachHang">
                                            <i class="bi bi-person-add"></i>
                                        </div>
                                        <input class="input-form" id="MaKhachHang" name="MaKhachHang" readonly="readonly" type="hidden" @bind="@Record.MaKhachHang">
                                        <input class="input-form" id="TenKhachHang" name="TenKhachHang" readonly="readonly" type="text" @bind="@Record.TenKhachHang">
                                        @if (!string.IsNullOrEmpty(Record.MaKhachHang))
                                        {
                                            <div class="icon-choose right" @onclick="ClearKH">
                                                <i class="bi bi-x-lg"></i>
                                            </div>
                                        }
                                    </div>
                                    <span class="error-validation">Vui lòng chọn khách hàng</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Sàn môi giới</span>
                                    <select id="MaSanGiaoDich" name="MaSanGiaoDich" class="form-control" @onchange="OnSanGiaoDichChanged">
                                        <option value=""> Chọn sàn giao dịch </option>
                                        @foreach (var item in ListSGG)
                                        {
                                            <option value="@(item.MaSanGiaoDich)">@item.TenSanGiaoDich</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Nhân viên môi giới</span>
                                    <InputText class="form-control" @bind-Value="Record.TenNhanVienMoiGioi" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-12">
                            <div class="row">
                                <div class="form-group-input group-input-grid">
                                    <span class="title-field">Nội dung <i class="point-validate">*</i></span>
                                    <textarea class="textarea-input input-validation" cols="20" id="GhiChu" @bind="Record.NoiDung" rows="3"></textarea>
                                </div>
                                <span class="error-validation">Vui lòng nhập nội dung</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-button">
        <div class="actions-left">
            <UiButton Preset="back" Variant="secondary" OnClick="BackUrl" />
        </div>
        <div class="actions-right">
            <UiButton Preset="save" Variant="primary" OnClick="SubmitFormJs" />
        </div>
    </div>
</EditForm>
<PopupKhachHang OnSelected="SelectedKhachHang" />
<PopupPhieuGC @ref="phieuGCModalRef" OnSelectedPGC="SelectedPGC" />
<CanHoDetails @ref="canHoModalRef" />
@code {
    [Parameter]
    public string id { get; set; }
    private EditContext editContext;
    // private PopupCanHo? canHoModalRef;
    private PopupPhieuGC? phieuGCModalRef;
    private PhieuDangKyModel? Record = new();
    private List<DmSanGiaoDich> ListSGG = new();
    private List<BhChinhSachThanhToan> ListCSTT = new();
    private List<Select2Config> _select2Configs = new();
    private CanHoDetails? canHoModalRef;
    private List<InfoItem> InfoItems = new();

    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(Record);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await BaseService.CheckPermissionAsync("PhieuDangKy", VuViec.Them.GetDescription());

        ListSGG = await PhieuDangKyService.GetBySanGiaoDichAsync();

        // 1) Lấy last selected
        var lastJson = await JS.InvokeAsync<string>("localGioHangHelper.getLastSelected");
        if (!string.IsNullOrWhiteSpace(lastJson))
        {
            GioHangItem? last = null;
            try
            {
                last = JsonSerializer.Deserialize<GioHangItem>(lastJson);
            }
            catch { /* ignore */ }

            var lastMaGioHang = (last?.MaGioHang ?? "").Trim();
            var lastMaSanPham = (last?.MaSanPham ?? "").Trim();

            // 2) Đúng giỏ hàng đang mở thì mới lấy
            if (!string.IsNullOrWhiteSpace(lastMaGioHang)
                && !string.IsNullOrWhiteSpace(lastMaSanPham)
                && string.Equals(lastMaGioHang, id, StringComparison.OrdinalIgnoreCase))
            {
                var soDoJson = await JS.InvokeAsync<string>(
                    "localGioHangHelper.getSoDoCanHoFromLocal",
                    id, lastMaSanPham);

                if (!string.IsNullOrWhiteSpace(soDoJson))
                {
                    SoDoCanHoModel? soDo = null;
                    try
                    {
                        soDo = JsonSerializer.Deserialize<SoDoCanHoModel>(soDoJson);
                    }
                    catch { /* ignore */ }

                    if (soDo != null)
                    {
                        // 3) Load record base theo giỏ hàng + mã sản phẩm (như bạn đang làm)
                        var result = await PhieuDangKyService.GetByGioHangIdAsync(id, soDo.MaSanPham ?? string.Empty, soDo);

                        if (result.Status && result.Data != null)
                        {
                            Record = (PhieuDangKyModel)result.Data;

                            // 4) Map thêm thông tin từ SoDoCanHoModel qua Record
                            Record.MaGioHang = id;
                            Record.MaCanHo = soDo.MaSanPham;
                            Record.TenCanHo = soDo.TenSanPham;

                            // tuỳ bạn có field nào trong Record thì map thêm:
                            Record.MaDuAn = soDo.MaDuAn;
                            Record.TenDuAn = soDo.TenDuAn;
                            // giá bán nếu Record có field phù hợp
                            Record.IsMoBanCoGia = soDo.IsMoBanCoGia;
                            Record.IsMoBanGiaTran = soDo.IsMoBanGiaTran;
                            Record.PhuongThucTinhCk = soDo.PhuongThucTinhCk;
                            Record.DienTichCanHo = (decimal?)soDo.DienTichCanHo ?? 0;
                            Record.DienTichLotLong = (decimal?)soDo.DienTichLotLong;
                            Record.DienTichSanVuon = (decimal?)soDo.DienTichSanVuon;
                            Record.GiaBanTruocThue = soDo.GiaBanTruocThue;
                            Record.GiaBanChinhThucTruocThue = soDo.GiaBanChinhThucTruocThue;
                            Record.GiaBan = soDo.GiaBan;//sau thuế
                            Record.GiaBanChinhThuc = soDo.GiaBanChinhThuc;//sau thuế


                            // 5) Load CSTT theo dự án
                            if (!string.IsNullOrWhiteSpace(Record.MaDuAn))
                                ListCSTT = await PhieuDangKyService.GetChinhSachThanhToanAsync(Record.MaDuAn);

                            InfoItems = new()
                        {
                            new() { Text="Mã phiếu", Value=Record.MaPhieu},
                            new() { Text="Ngày lập", Value=string.Format("{0:dd/MM/yyyy}", Record.NgayLap)},
                            new() { Text="Người lập", Value=Record.NguoiLap?.HoVaTen},
                            new() { Text="Dự án", Value=Record.TenDuAn},
                        };

                            // 6) Dọn localStorage để tránh dính dữ liệu cũ
                            //await JS.InvokeVoidAsync("localGioHangHelper.removeSoDoCanHoFromLocal", id, lastMaSanPham);
                            // await JS.InvokeVoidAsync("localGioHangHelper.clearLastSelected");
                        }
                    }
                }
            }
        }

        _select2Configs = new()
                {
                    new("MaSanGiaoDich", "Chọn sàn giao dịch", Record.SanGiaoDich?.ToString()),
                   // new("MaChinhSachTT", "Chọn chính sách thanh toán", Record.MaChinhSachTt?.ToString()),
                };
        await JS.InvokeVoidAsync("select2Helper.initMany", _select2Configs);
        StateHasChanged();
    }

    private async Task SubmitFormJs()
    {
        var dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("validateFormBlazor", "formDuAn", dotNetRef);
    }

    [JSInvokable]
    public async Task SubmitForm()
    {
        Loading.Show();
        try
        {
            var result = await PhieuDangKyService.SavePhieuAsync(Record);
            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);

            if (result.Status)
            {
                // ✅ Xoá draft localStorage SAU KHI lưu thành công
                if (!string.IsNullOrWhiteSpace(id) && !string.IsNullOrWhiteSpace(Record?.MaCanHo))
                {
                    await JS.InvokeVoidAsync("localGioHangHelper.removeSoDoCanHoFromLocal", id, Record.MaCanHo);
                    await JS.InvokeVoidAsync("localGioHangHelper.clearLastSelected");
                }

                Nav.NavigateTo($"/phieudangky/edit/{result.Id}");
                StateHasChanged();
            }
            else
            {
                Loading.Hide();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", ex.Message, false);
        }
        finally
        {
            Loading.Hide();
        }
    }


