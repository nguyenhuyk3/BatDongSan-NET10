@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.Paging
@using VTTGROUP.Domain.Model
@using VTTGROUP.Domain.Model.KhachHang
@using VTTGROUP.Domain.Model.PhieuGiuCho
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@inject KhachHangTamService KhachHangTamService
@inject PhieuDangKyService PhieuDangKyService
@inject IJSRuntime JS
<div class="modal fade" id="PopupPGCModalTam" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Danh sách phiếu giữ chỗ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body modal-wraper" id="modal-body">
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-[360px] md:w-[480px]">
                        <InputSearch @bind-Value="search" OnSearch="Search" />
                    </div>
                    <div class="ml-auto h-11 flex items-center">
                        <Pagination Page="@_page"
                                    TotalPages="@totalPage"
                                    TotalItems="@totalCount"
                                    OnPageChanged="HandlePageChanged"
                                    OnPageSizeChanged="HandlePageSizeChanged" />
                    </div>
                </div>
                <div class="container-table-detail">
                    <div class="container-table-fixed has-paging">
                        <table class="tbl table-form table-detail treeTable" id="table-data">
                            <thead>
                                <tr class="cls_custome_back">
                                    <th style="width: 50px" class="text-center">
                                        STT
                                    </th>
                                    <th style="width: 130px" class="text-center">
                                        Hệ thống
                                    </th>
                                    <th style="width: 130px" class="text-center">
                                        Khách hàng
                                    </th>
                                    <th style="width: 150px" class="text-center">
                                        Số tiền giữ chỗ
                                    </th>
                                    <th style="width: 250px" class="text-center">
                                        Nội dung
                                    </th>
                                    <th style="width: 90px">
                                        &nbsp;
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="content-table">
                                @if (listPGC != null && listPGC.Count > 0)
                                {
                                    @foreach (var item in listPGC)
                                    {
                                        <tr class="initialized">
                                            <td style="text-align:center">
                                                <span>@item.STT</span>
                                            </td>
                                            <td class="line-height-20">
                                                <div class="item-phieu" @onclick="() => OnEditRecord(item.MaPhieu.ToString())">@item.MaPhieu</div>
                                                <span class="created-label">@item.HoVaTen</span>
                                                <div class="created-date-label">@string.Format("{0:dd/MM/yyyy}", item.NgayLap)</div>
                                            </td>
                                            <td>
                                                <span>@item.TenKhachHang</span>
                                            </td>
                                            <td style="text-align:right">
                                                @string.Format("{0:N0}", item.SoTienGiuCho)
                                            </td>
                                            <td class="line-height-20">
                                                <span>@item.NoiDung</span>
                                            </td>
                                            <td class="text-center">
                                                <div class="d-flex justify-content-center align-items-center">
                                                    <div class="icon-button" data-title="Chọn" data-position="left">
                                                        <a href="javascript:void(0)" @onclick="() => TriggerChoosePGC(item)"><span><i class="bi bi-check-circle"></i></span></a>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                        @if (listPGC == null || !listPGC.Any())
                        {
                            <div class="p-2">Không có dữ liệu</div>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="button button-action button-huy" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
@code {
    [Parameter]
    public EventCallback<PhieuGiuChoPagingDto?> OnSelectedPGC { get; set; }
    private string? selectedLoaiKhachHang;
    private bool isLoading = false;
    int _page = 1;
    int _pageSize = 10;
    int totalPage = 1;
    int totalCount;
    string? search;
    List<PhieuGiuChoPagingDto> listPGC = new();
    public string? MaDuAn { get; set; }
    public string? MaSanGG { get; set; }
    protected override async Task OnInitializedAsync()
    {
        await LoadPhieuGiuCho();
    }

    private async Task TriggerChoosePGC(PhieuGiuChoPagingDto? item)
    {
        await OnSelectedPGC.InvokeAsync(item);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#PopupPGCModalTam");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
        }
    }

    private async Task OnDTKHChanged(ChangeEventArgs e)
    {
        var newKH = e.Value?.ToString();
        if (newKH == selectedLoaiKhachHang || isLoading)
        {
            return;
        }
        selectedLoaiKhachHang = newKH;
        _page = 1;
        await LoadPhieuGiuCho();
    }

    private async Task LoadPhieuGiuCho()
    {
        isLoading = true;
        try
        {
            var (data, total) = await PhieuDangKyService.GetPagingPGCPopupAsync(MaDuAn, MaSanGG, _page, _pageSize, search);
            listPGC = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }
    private async Task HandlePageChanged(int newPage)
    {
        _page = newPage;
        await LoadPhieuGiuCho();
    }

    private async Task HandlePageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        _page = 1;
        await LoadPhieuGiuCho(); // Gọi lại API với PageSize mới
    }

    private async Task Search(string? keyword)
    {
        search = keyword;
        _page = 1;
        await LoadPhieuGiuCho();
    }

    public async Task ShowPopupPGCAsync(string maDuAn, string maSanGG)
    {
        MaDuAn = maDuAn;
        MaSanGG = maSanGG;
        _page = 1;
        await LoadPhieuGiuCho();
        await JS.InvokeVoidAsync("bootstrapModal.show", "#PopupPGCModalTam");
        await JS.InvokeVoidAsync("modalHelper.makeAllDraggable");
        StateHasChanged();
    }

    private async Task OnEditRecord(string maPhieuGC)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/phieugiucho/edit/" + maPhieuGC);
    }

}
