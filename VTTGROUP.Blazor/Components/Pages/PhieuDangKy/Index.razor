    private async Task LoadData()
    {
        if (_activeTab == 2)
            await LoadTab2();
        else
            await LoadTab1();
    }

    private async Task LoadTab1()
    {
        isLoading = true;
        try
        {
            var (data, total) = await PhieuDangKyService.GetPagingAsync(
                selectedDuAn1, selectedMaSan1,
                _page, _pageSize,
                search1,
               null, false, tuNgay1, denNgay1
            );

            listPGC = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally { isLoading = false; }
    }

    private async Task LoadTab2()
    {
        isLoading = true;
        try
        {
            var (data, total) = await PhieuDangKyService.GetPagingAsync(
                selectedDuAn2, selectedMaSan2,
                _page2, _pageSize2,
                search2,
                selectedTrangThai2, true,
                tuNgay2, denNgay2
            );

            listPGC2 = data;
            totalCount2 = total;
            totalPage2 = (int)Math.Ceiling((double)totalCount2 / _pageSize2);
        }
        finally { isLoading = false; }
    }


