    private async Task ResetAllParam()
    {
        if (_activeTab == 1)
        {
            _page = 1; _pageSize = 10;
            search1 = null; selectedDuAn1 = null; selectedMaSan1 = null;
            tuNgay1 = null;
            //DateTime.Now.AddMonths(-1).ToString("dd/MM/yyyy");
            denNgay1 = null;
            //DateTime.Now.ToString("dd/MM/yyyy");

            await LoadTab1();
            if (dateRangeRef1 != null) await dateRangeRef1.ResetAsync();
            if (morePopupRef1 != null) await morePopupRef1.RestAllMore();
        }
        else
        {
            _page2 = 1; _pageSize2 = 10;
            search2 = null; selectedDuAn2 = null; selectedMaSan2 = null; selectedTrangThai2 = null;
            tuNgay2 = null;
            //DateTime.Now.AddMonths(-1).ToString("dd/MM/yyyy");
            denNgay2 = null;
            //DateTime.Now.ToString("dd/MM/yyyy");

            await LoadTab2();
            if (dateRangeRef2 != null) await dateRangeRef2.ResetAsync();
            if (morePopupRef2 != null) await morePopupRef2.RestAllMore();
        }

        StateHasChanged();
    }

