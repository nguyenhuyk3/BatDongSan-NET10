    private async Task OnCheckboxAllChanged(ChangeEventArgs e)
    {
        IsSelectAll = (bool)e.Value;
        foreach (var item in listPGC)
        {
            if (item.IsXacNhan == false && item.NguoiLap == maNhanVienHT && !item.IsHetHieuLuc)
            {
                item.IsSelected = IsSelectAll;
            }
        }
    }

    private async Task OnCheckboxChanged(PhieuDangKyPagingDto item, ChangeEventArgs e)
    {
        item.IsSelected = (bool)e.Value;
        IsSelectAll = listPGC.All(x => x.IsSelected);
    }

    private async Task ChangeTab(int tabId)
    {
        if (_activeTab == tabId) return;

        _activeTab = tabId;

        if (_activeTab == 2 && !_isTab2Loaded)
        {
            await LoadTab2();
            _isTab2Loaded = true;
        }

        StateHasChanged();
    }


