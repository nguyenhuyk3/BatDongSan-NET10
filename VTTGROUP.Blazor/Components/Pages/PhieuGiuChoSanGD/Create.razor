@page "/phieugiuchosangd/create"
@using System.Text.Json
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model.CongTrinh
@using VTTGROUP.Domain.Model.KhachHang
@using VTTGROUP.Domain.Model.KhachHangTam
@using VTTGROUP.Domain.Model.PhieuGiuCho
@using VTTGROUP.Domain.Model.SanPham
@using VTTGROUP.Domain.Model.ViewMatKhoi
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Model
@inject IBaseService BaseService
@inject CanHoService CanHoService
@inject PhieuGiuChoSanGDService PhieuGiuChoService
@inject LoadingService Loading
@inject IJSRuntime JS
@inject NavigationManager Nav
<EditForm id="formDuAn" EditContext="@editContext">
    <h1 class="legend-title">Phiếu booking giữ chỗ</h1>
    <div class="container-form">
        <div class="container-tabs">
            <div class="row">
                <div class="col-md-12">
                    @*   <ul class="tab-element">
                <li class="tab-item actived-tab" data-id="1" id="linkTab1">Thông tin chung</li>
                <div class="line-bot-nav animated" style="width: 154px; left: 0px;">
                </div>
                </ul> *@
                </div>
            </div>
            <MessageErrorForm />
            <div class="wapper-content-tab" id="formDuAn">
                <div data-id="1" class="tab-content-item actived-tab" id="tab1">
                    <div class="col-lg-10 mx-auto row">
                        <InfoList Items="@InfoItems" />
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Mã khách hàng <i class="point-validate">*</i></span>
                                    <div class="input-wraper-choose">
                                        <div class="icon-choose left" @onclick="ShowPopupKhachHang">
                                            <i class="bi bi-person-add"></i>
                                        </div>
                                        <input class="input-form input-validation" id="MaKhachHang" name="MaKhachHang" readonly="readonly" type="text" value="@Record.MaKhachHang">
                                    </div>
                                    <span class="error-validation">Vui lòng chọn khách hàng</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Tên khách hàng </span>
                                    <DisableTextBox Value="@Record.TenKhachHang" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-12">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Số tiền giữ chỗ</span>
                                    <DisableTextBox Class="is-right" Value="@string.Format("{0:N0}", Record.SoTienGiuCho)" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Sàn giao dịch</span>
                                    <DisableTextBox Value="@Record.TenSanGiaoDich" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Nhân viên môi giới</span>
                                    <InputText class="form-control" @bind-Value="Record.TenNhanVienMoiGioi" />
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Loại căn hộ</span>
                                    <select id="MaLoaiThietKe" name="MaLoaiThietKe" class="form-control" multiple @ref="selectLCHTKRef">
                                        <option value=""> Chọn loại thiết kế </option>
                                        @foreach (var item in ListLCHTK)
                                        {
                                            <option value="@(item.MaLoaiCanHo)">@item.TenLoaiCanHo</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">View mặt khối</span>
                                    <select id="MaMatKhoi" name="MaMatKhoi" class="form-control" multiple @ref="selectVMKRef">
                                        <option value=""> Chọn view mặt khối </option>
                                        @foreach (var item in ListViewMK)
                                        {
                                            <option value="@(item.MaMatKhoi)">@item.TenMatKhoi</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-12">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Ghi chú</span>
                                    <textarea class="textarea-input" cols="20" name="NoiDung" id="NoiDung" rows="3" tabindex="2" @bind="Record.NoiDung"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-button">
        <div class="actions-left">
            <VTTGROUP.Blazor.Components.CompChilds.UiButton Preset="back" Variant="secondary" OnClick="BackUrl" />
        </div>
        <div class="actions-right">
            <VTTGROUP.Blazor.Components.CompChilds.UiButton Preset="save" Variant="primary" OnClick="SubmitFormJs" />
        </div>
    </div>
</EditForm>
<PopupKhachHangSGD OnSelected="SelectedKhachHang" />
@code {
    private EditContext editContext;
    private PhieuGiuChoModel? Record = new();
    private List<DuAnTheoSanModel> ListDA = new();
    private List<DmSanGiaoDich> ListSGG = new();
    private DaDanhMucDotMoBan ListDMB = new();
    private List<DaDanhMucLoaiCanHo> ListLCHTK = new();
    private List<DaDanhMucViewMatKhoi> ListViewMK = new();
    private ElementReference selectLCHTKRef;
    private ElementReference selectVMKRef;
    private string? selectedCHTK;
    public List<string> SelectedCHTKList { get; set; } = new();
    private string? selectedVMK;
    public List<string> SelectedViewMKList { get; set; } = new();
    private CongTrinhSettingsModal CongTrinhSan;
    private List<InfoItem> InfoItems = new();
    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(Record);
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync("PhieuGiuChoSanGD", VuViec.Them.GetDescription());
            CongTrinhSan = await BaseService.ThongTinCongTrinhSan();
            if (string.IsNullOrEmpty(CongTrinhSan.MaCongTrinh))
            {
                ListDA = await PhieuGiuChoService.GetByDuAnAsync();
                await JS.InvokeVoidAsync("eval", @"
            setTimeout(function() {
                select2Helper.initSelectChange('MaDuAn', 'Chọn dự án', true);
            }, 300);");
            }
            var result = await PhieuGiuChoService.GetByIdAsync(string.Empty);
            if (result.Status)
            {
                Record = (PhieuGiuChoModel)result.Data;
                if (!string.IsNullOrEmpty(CongTrinhSan.MaCongTrinh))
                {
                    Record.MaDuAn = CongTrinhSan.MaCongTrinh;
                    Record.TenDuAn = CongTrinhSan.TenCongTrinh;
                }
                InfoItems = new()
                {
                    new() { Text="Mã phiếu", Value=Record.MaPhieu},
                    new() { Text="Ngày lập", Value=string.Format("{0:dd/MM/yyyy}", Record.NgayLap)},
                    new() { Text="Người lập", Value=Record.NguoiLap.HoVaTen},
                    new() { Text="Dự án", Value=Record.TenDuAn, LargeWidth = true},
                };
            }

            await JS.InvokeVoidAsync("select2Helper.initSelectMultipleChange", "MaLoaiThietKe", "Chọn loại thiết kế", true, DotNetObjectReference.Create(this));
            await JS.InvokeVoidAsync("select2Helper.initSelectMultipleChange", "MaMatKhoi", "Chọn view mặt khối", true, DotNetObjectReference.Create(this));
            await JS.InvokeVoidAsync("InputUtils.makeCurrencyFormat", "SoTienGiuCho", 18, 0);
            if (!string.IsNullOrEmpty(Record.MaDuAn))
            {
                await ThongTinDuAnChangedSGG();
            }
            StateHasChanged();
        }
    }

    private async Task SubmitFormJs()
    {
        var dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("validateFormBlazor", "formDuAn", dotNetRef);
    }

    [JSInvokable]
    public async Task SubmitForm()
    {
        Loading.Show();
        try
        {
            var result = await PhieuGiuChoService.SavePhieuGiuChoAsync(Record);
            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
            if (result.Status)
            {
                Nav.NavigateTo($"/phieugiuchosangd/edit/{result.Id}");
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", ex.Message, false);
        }
        finally
        {
            Loading.Hide();
        }
    }

    private void BackUrl()
    {
        Nav.NavigateTo("/phieugiuchosangd");
    }


    private async Task ShowPopupKhachHang()
    {
        await JS.InvokeVoidAsync("bootstrapModal.show", "#PopupChonKHModalTam");
        await JS.InvokeVoidAsync("modalHelper.makeAllDraggable");
    }

    private async Task SelectedKhachHang(KhachHangPagingDto? item)
    {
        Record.MaKhachHang = item.MaKhachHangTam;
        Record.TenKhachHang = item.TenKhachHang;
    }

    [JSInvokable]
    public async Task OnSelectMultiChanged(string id, string[] selectedBlocks)
    {
        if (id == "MaLoaiThietKe")
        {
            SelectedCHTKList = selectedBlocks.ToList();
            selectedCHTK = string.Join(',', SelectedCHTKList.ToArray());
            Record.MaLoaiThietKe = selectedCHTK;
        }
        else if (id == "MaMatKhoi")
        {
            SelectedViewMKList = selectedBlocks.ToList();
            selectedVMK = string.Join(',', SelectedViewMKList.ToArray());
            Record.MaMatKhoi = selectedVMK;
        }
    }

    private void OnDuAnChanged(ChangeEventArgs e)
    {
        Record.MaDuAn = e.Value?.ToString();
        ListDMB = PhieuGiuChoService.GetByDotMoBanAsync(Record.MaDuAn);
        Record.DotMoBan = ListDMB.MaDotMoBan;
        Record.TenDotMoBan = ListDMB.TenDotMoBan;
        selectedCHTK = null;
        SelectedCHTKList = new();
        ListLCHTK = PhieuGiuChoService.GetByLoaiThietKeTheoDuAnAsync(Record.MaDuAn);

        selectedVMK = null;
        SelectedViewMKList = new();
        ListViewMK = PhieuGiuChoService.GetBViewMatKhoiTheoDuAnAsync(Record.MaDuAn);
        Record.SoTienGiuCho = PhieuGiuChoService.SoTienGiuChoTheoDuAn(Record.MaDuAn);
        StateHasChanged();
    }

    private async Task ThongTinDuAnChangedSGG()
    {
        ListDMB = PhieuGiuChoService.GetByDotMoBanAsync(Record.MaDuAn);
        Record.DotMoBan = ListDMB.MaDotMoBan;
        Record.TenDotMoBan = ListDMB.TenDotMoBan;
        selectedCHTK = null;
        SelectedCHTKList = new();
        ListLCHTK = PhieuGiuChoService.GetByLoaiThietKeTheoDuAnAsync(Record.MaDuAn);

        selectedVMK = null;
        SelectedViewMKList = new();
        ListViewMK = PhieuGiuChoService.GetBViewMatKhoiTheoDuAnAsync(Record.MaDuAn);
        Record.SoTienGiuCho = PhieuGiuChoService.SoTienGiuChoTheoDuAn(Record.MaDuAn);
    }
}

<style>
    .input-wraper-choose {
        position: relative;
    }

        .input-wraper-choose .input-form {
            padding-left: 2.2rem;
            padding-right: 2.2rem;
        }

        .input-wraper-choose .icon-choose {
            font-size: 0.95rem;
            border-radius: 50%;
            color: var(--theme-color);
            cursor: pointer;
            transition: all 300ms ease-in-out;
            position: absolute;
            top: 3px;
            z-index: 2;
        }

            .input-wraper-choose .icon-choose.left {
                left: 0px;
            }

            .input-wraper-choose .icon-choose.right {
                right: 5px;
            }

</style>
