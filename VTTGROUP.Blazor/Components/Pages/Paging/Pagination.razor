@* ---------- PAGER UI ---------- *@
<div class="paging-wrap" aria-label="Pagination section">

    <!-- Page size (bên trái) -->
    <select id="pagesize" class="pg-size-select" @onchange="ChangePageSize" aria-label="Số dòng mỗi trang">
        @foreach (var size in pageSizeOptions)
        {
            <option value="@size" selected="@(size == PageSize)">@size / @(TotalItems != null ? string.Format("{0:#,##0}", TotalItems) : "trang")</option>
        }
        <option value="all" selected="@(PageSize == int.MaxValue)">All / @TotalItems?.ToString("#,##0")</option>
    </select>

    <!-- Thanh pager dạng viên thuốc có phân đoạn -->
    <nav class="pager" aria-label="Pagination">
        <!-- Prev chevron -->
        <button type="button"
                class="pager-item pager-chevron @(Page == 1 ? "is-disabled" : null)"
                disabled="@(Page == 1)"
                @onclick="() => GoToPage(Page - 1)">
            <i class="mdi mdi-chevron-left" aria-hidden="true"></i>
            <span class="sr-only">Trang trước</span>
        </button>

        @* Các nút trang, có "…" nếu cần *@
        @{
            var range = GetPageRange().ToList();
            var firstRange = range.FirstOrDefault();
            var lastRange = range.LastOrDefault();
        }

        @if (firstRange > 1)
        {
            <button type="button" class="pager-item" @onclick="() => GoToPage(1)">1</button>
            @if (firstRange > 2)
            {
                <span class="pager-item pager-ellipsis">…</span>
            }
        }

        @foreach (var pageNum in range)
        {
            if (pageNum == Page)
            {
                <span class="pager-item is-active" aria-current="page">@pageNum</span>
            }
            else
            {
                <button type="button" class="pager-item" @onclick="() => GoToPage(pageNum)">@pageNum</button>
            }
        }

        @if (lastRange < TotalPages)
        {
            @if (lastRange < TotalPages - 1)
            {
                <span class="pager-item pager-ellipsis">…</span>
            }
            <button type="button" class="pager-item" @onclick="() => GoToPage(TotalPages)">@TotalPages</button>
        }

        <!-- Next chevron -->
        <button type="button"
                class="pager-item pager-chevron @(Page == TotalPages ? "is-disabled" : null)"
                disabled="@(Page == TotalPages)"
                @onclick="() => GoToPage(Page + 1)">
            <i class="mdi mdi-chevron-right" aria-hidden="true"></i>
            <span class="sr-only">Trang sau</span>
        </button>
    </nav>
</div>

@code {
    [Parameter] public int Page { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; } = 1;
    [Parameter] public float? TotalItems { get; set; } = null;
    [Parameter] public int PageSize { get; set; } = 10;

    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    private readonly int[] pageSizeOptions = new[] { 10, 20, 25, 50, 100 };

    private async Task GoToPage(int pageNumber)
    {
        if (pageNumber >= 1 && pageNumber <= TotalPages && pageNumber != Page)
        {
            Page = pageNumber;
            await OnPageChanged.InvokeAsync(Page);
        }
    }

    private async Task ChangePageSize(ChangeEventArgs e)
    {
        var raw = e?.Value?.ToString()?.Trim();

        // 1) Nếu select trả về "all" (hoặc "tatca") => coi như All
        if (!string.IsNullOrEmpty(raw) &&
            (raw.Equals("all", StringComparison.OrdinalIgnoreCase)
             || raw.Equals("tatca", StringComparison.OrdinalIgnoreCase)))
        {
            PageSize = int.MaxValue;  // sentinel cho All (dùng chung toàn hệ thống)
            Page = 1;
            await OnPageSizeChanged.InvokeAsync(PageSize);
            return;
        }
        if (int.TryParse(e.Value?.ToString(), out var newSize))
        {
            PageSize = newSize;
            Page = 1; // reset về trang 1 khi đổi page size
            await OnPageSizeChanged.InvokeAsync(PageSize);
            //	await OnPageChanged.InvokeAsync(Page);
        }

    }

    private IEnumerable<int> GetPageRange()
    {
        var maxPages = 5; // số ô hiển thị giữa hai đầu
        var start = Math.Max(1, Page - 2);
        var end = Math.Min(TotalPages, start + maxPages - 1);

        if (end - start < maxPages - 1)
            start = Math.Max(1, end - maxPages + 1);

        return Enumerable.Range(start, end - start + 1);
    }
}
