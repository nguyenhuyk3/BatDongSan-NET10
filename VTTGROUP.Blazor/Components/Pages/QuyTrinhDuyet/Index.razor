@code {
    private DotNetObjectReference<Index>? _dotNetRef;
    private List<CongViecModel> DanhSach = new();
    private CongViecModel? selectedCongViec = new();
    private string? selectedDuAn;
    private string? selectedTrangThai = "1";
    private int? selectedId;
    private string? selectedQuyTrinh;
    private bool isLoading = false;
    int _page = 1;
    int _pageSize = 10;
    int totalPage = 1;
    int totalCount;
    string? search;
    List<QuyTrinhDuyetPagingDto> listTLDC = new();
    private List<DaDanhMucDuAn> ListDA = new();

    private bool IsSelectAll = false;

    private List<TrangThaiUserModel> TrangThaiUser = new()
    {
        new TrangThaiUserModel{MaTrangThai="1", TenTrangThai="Đang mở"},
        new TrangThaiUserModel{MaTrangThai="0", TenTrangThai="Đã đóng"},
    };
    protected override async Task OnInitializedAsync()
    {
        ListDA = await QuyTrinhDuyetService.GetByDuAnAsync();
        DanhSach = await CongViecService.GetTreeAllAsync();
        await LoadData();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {

            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaDuAn", "Chọn dự án", true);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "sltTrangThaiUser", "Chọn trạng thái", true);
            await JS.InvokeVoidAsync("tooltipHelper.init");
        }
        if (listTLDC.Any())
        {
            var config = new List<FixColumnConfig>
            {
                new FixColumnConfig { left = 0 },
                new FixColumnConfig { right = 0 }
            };
            await JS.InvokeVoidAsync("applyStickyColumnsDynamic", "table-data", config);
        }

    }

    private async Task ShowConfirmDelete(QuyTrinhDuyetPagingDto item)
    {
        selectedId = item.Id;
        selectedQuyTrinh = item.TenQuyTrinh;
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteModal");
    }

    private async Task ConfirmDelete()
    {
        if (selectedId == null)
        {
            return;
        }
        var result = await QuyTrinhDuyetService.DeletePhieuAsync(selectedId);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteModal");
        await LoadData();
        selectedId = null;
        StateHasChanged();
    }

    private async Task OnDTKHChanged(ChangeEventArgs e)
    {
        var newDA = e.Value?.ToString();
        if (newDA == selectedDuAn || isLoading)
        {
            return;
        }
        selectedDuAn = newDA;
        _page = 1;
        await LoadData();
    }

    private async Task OnDTKHChanged(string? duAn)
    {
        if (isLoading) return;
        selectedDuAn = string.IsNullOrWhiteSpace(duAn) ? null : duAn;
        _page = 1;
        await LoadData();
    }

    private async Task OnTrangThaiChanged(string value)
    {
        selectedTrangThai = value;
        _page = 1;
        await LoadData();
    }


    private async Task OnMaCongViecChanged(CongViecModel item)
    {
        selectedCongViec = item;
        _page = 1;
        await LoadData();
    }


    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var (data, total) = await QuyTrinhDuyetService.GetPagingAsync(selectedCongViec.MaCongViec, selectedDuAn, selectedTrangThai, _page, _pageSize, search);
            listTLDC = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }
    private async Task HandlePageChanged(int newPage)
    {
        _page = newPage;
        await LoadData();
    }

    private async Task HandlePageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        _page = 1;
        await LoadData();
    }
    private async Task Search(string? keyword)
    {
        search = keyword;
        _page = 1;
        await LoadData();
    }
    private async Task OnEditRecord(int? maPhieu)
    {
        Nav.NavigateTo($"/quytrinhduyet/edit/{maPhieu}");
    }
    private void Insert()
    {
        Nav.NavigateTo("/quytrinhduyet/create");
        return;
    }

}

