@page "/quytrinhduyet"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.Paging
@using VTTGROUP.Domain.Model
@using VTTGROUP.Domain.Model.PhanQuyen
@using VTTGROUP.Domain.Model.QuyTrinhDuyet
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@inject QuyTrinhDuyetService QuyTrinhDuyetService
@inject CongViecService CongViecService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IWebHostEnvironment _env

<h1 class="legend-title">Quy trình duyệt</h1>
<div class="rounded-xl bg-white p-4 space-y-3 wraper-content-page">
    <div class="relative z-50">
        <div class="flex flex-wrap items-end gap-3">
            <div class="col-search wapper-congtrinh container-form droplist-tree-index">
                <div class="result-label-icon">
                    <i class="mdi mdi-file-document"></i>
                    <TreeSelect Items="@DanhSach" OnSelected="OnMaCongViecChanged" ItemSelected="@selectedCongViec" />
                </div>
            </div>
            <UiSelect Icon="mdi mdi-file-document"
                      Placeholder="Chọn dự án"
                      Items="ListDA.Select(x => new UiSelect.SelectItem(x.MaDuAn!, x.TenDuAn!))"
                      @bind-Value="selectedDuAn"
                      OnChange="OnDTKHChanged" />
            <UiSelect Icon="mdi mdi-file-document"
                      Placeholder="Chọn trạng thái"
                      Items="TrangThaiUser.Select(x => new UiSelect.SelectItem(x.MaTrangThai!, x.TenTrangThai!))"
                      @bind-Value="selectedTrangThai"
                      OnChange="OnTrangThaiChanged" />
            <div class="ml-auto flex items-center gap-2">
                <AddButton Text="Qui trình duyệt" OnClick="Insert" />
            </div>
        </div>
    </div>
    <div class="flex items-center gap-3 my-3">
        <div class="w-[360px] md:w-[480px]">
            <InputSearch @bind-Value="search" OnSearch="Search" />
        </div>
        <div class="ml-auto h-11 flex items-center">
            <Pagination Page="@_page"
                        TotalPages="@totalPage"
                        TotalItems="@totalCount"
                        OnPageChanged="HandlePageChanged"
                        OnPageSizeChanged="HandlePageSizeChanged" />
        </div>
    </div>
    <div class="container-table-detail">
        <div class="container-table-fixed has-paging">
            <table class="tbl table-form table-detail treeTable" id="table-data">
                <thead>
                    <tr class="cls_custome_back">
                        <th style="width: 50px" class="text-center">
                            STT
                        </th>
                        <th style="width: 130px" class="text-center">
                            Tên quy trình
                        </th>
                        <th style="width: 130px" class="text-center">
                            Người lập
                        </th>
                        <th style="width: 130px" class="text-center">
                            Ngày lập
                        </th>
                        <th style="width: 130px" class="text-center">
                            Trạng thái
                        </th>
                        <th style="width: 90px">
                            &nbsp;
                        </th>
                    </tr>
                </thead>
                <tbody class="content-table">
                    @if (listTLDC != null && listTLDC.Count > 0)
                    {
                        @foreach (var item in listTLDC)
                        {
                            <tr class="initialized">
                                <td style="text-align:center">
                                    <span>@item.STT</span>
                                </td>
                                <td>
                                    <span>@item.TenQuyTrinh</span>
                                    <div class="item-phieu" @onclick="() => OnEditRecord(item.Id)">(@item.MaCongViec)</div>
                                </td>
                                <td>
                                    <span>@item.HoVaTen</span>
                                </td>
                                <td>
                                    @string.Format("{0:dd/MM/yyyy}", item.NgayLap)
                                </td>
                                <td>
                                    <span>@item.TrangThai</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center">
                                        <div class="icon-button" data-title="Cập nhật" data-position="left">
                                            <a href="javascript:void()" @onclick="() => OnEditRecord(item.Id!)">
                                                <span>
                                                    <i class="mdi mdi-pencil">
                                                    </i>
                                                </span>
                                            </a>
                                        </div>
                                        <div class="icon-button" data-title="Xóa" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => ShowConfirmDelete(item)"><span><i class="mdi mdi-delete "></i></span></a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            @if (listTLDC == null || !listTLDC.Any())
            {
                <div class="p-2">Không có dữ liệu</div>
            }
        </div>
    </div>

    <ConfirmDeleteModal ModalId="confirmDeleteModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa qui trình duyệt này <strong>@selectedQuyTrinh</strong> không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDelete">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>
</div>
