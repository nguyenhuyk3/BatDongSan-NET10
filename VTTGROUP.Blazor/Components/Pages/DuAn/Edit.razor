                                                    <i class="mdi mdi-content-save save-icon"></i>
                                                </button>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="content-table">
                                        @if (Record.ListView != null && Record.ListView.Any() == true)
                                        {
                                            int sttViewMK = 0;
                                            foreach (var item in Record.ListView)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        @(sttViewMK + 1)
                                                    </td>
                                                    <td>
                                                        @if (item.IsNew == false)
                                                        {
                                                            <DisableTextBox Value="@item.MaView" />
                                                        }
                                                        else
                                                        {
                                                            <InputText @bind-Value="item.MaView" class="form-control input-validation" />
                                                        }
                                                    </td>
                                                    <td><InputText @bind-Value="item.TenView" class="form-control input-validation" /></td>
                                                    <td class="text-center">
                                                        @if (item.SoLuongVMK == 0)
                                                        {
                                                            <button type="button"
                                                                    class="icon-button icon-inline icon-delete"
                                                                    title="Xóa"
                                                                    data-title="Xóa"
                                                                    data-position="left"
                                                                    @onclick="() => DeleteRowLoaiView(item)">
                                                                <i class="mdi mdi-delete"></i>
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                                sttViewMK++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </SectionHeader>
                    </div>
                    <div class="col-lg-10 mx-auto row">
                        <SectionHeader Title="Loại căn"
