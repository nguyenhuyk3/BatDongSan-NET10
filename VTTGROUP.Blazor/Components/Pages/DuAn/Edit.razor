                                                </tr>
                                                sttLoaiCan++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </SectionHeader>
                    </div>
                    <div class="col-lg-10 mx-auto row">
                        <SectionHeader Title="Loại diện tích"
                                       OnAdd="AddLoaiDienTich"
                                       DefaultExpanded="false">
                            <div class="overflow-auto loaidientich-table" id="container-table-fixed">
                                <table class="tbl table table-hover table-form table-detail">
                                    <thead>
                                        <tr>
                                            <th style="width:50px" class="text-center">
                                                STT
                                            </th>
                                            <th style="width:120px" class="text-center">
                                                Mã loại
                                            </th>
                                            <th style="width:200px" class="text-center">
                                                Tên loại
                                            </th>
                                            <th style="width:120px" class="text-center">
                                                Hệ số
                                            </th>
                                            <th style="width:50px" class="text-center">
                                                <button type="button"
                                                        class="icon-button icon-inline icon-save"
                                                        title="Lưu thay đổi loại diện tích"
                                                        data-title="Lưu thay đổi loại diện tích"
                                                        data-position="right"
                                                        @onclick="SaveLoaiDienTichList">
                                                    <i class="mdi mdi-content-save save-icon"></i>
                                                </button>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="content-table">
                                        @if (Record.ListLoaiDT != null && Record.ListLoaiDT.Any() == true)
                                        {
                                            int sttLDT = 0;
                                            foreach (var item in Record.ListLoaiDT)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        @(sttLDT + 1)
                                                    </td>
                                                    <td>
                                                        @if (item.IsNew == false)
                                                        {
                                                            <DisableTextBox Value="@item.MaLoaiDT" />
                                                        }
                                                        else
                                                        {
                                                            <InputText @bind-Value="item.MaLoaiDT" class="form-control input-validation" />
                                                        }
                                                    </td>
                                                    <td><InputText @bind-Value="item.TenLoaiDT" class="form-control input-validation" /></td>
                                                    <td>
                                                        <InputCurrency T="decimal"
                                                                       Id=@($"HeSoLDT{sttLDT+1}")
                                                                       Format="#,##0.####"
                                                                       CssClass="input-form is-right input-currency form-control input-validation select-on-click w-100 p-1 ms-2"
                                                                       @bind-Value="item.HeSo" />
                                                    </td>
                                                    <td class="text-center">
                                                        @if (item.SoLuongCanHo == 0)
                                                        {
                                                            <button type="button"
                                                                    class="icon-button icon-inline icon-delete"
                                                                    title="Xóa"
                                                                    data-title="Xóa"
                                                                    data-position="left"
                                                                    @onclick="() => DeleteRowLoaiDT(item)">
                                                                <i class="mdi mdi-delete"></i>
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                                sttLDT++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </SectionHeader>
                    </div>
                    <div class="col-lg-10 mx-auto row">
                        <SectionHeader Title="Loại layout"
                                       OnAdd="AddLoaiLayout"
                                       DefaultExpanded="false">
                            <div class="overflow-auto loailayout-table" id="container-table-fixed">
                                <table class="tbl table table-hover table-form table-detail">
                                    <thead>
                                        <tr>
                                            <th style="width:50px" class="text-center">
                                                STT
                                            </th>
                                            <th style="width:120px" class="text-center">
                                                Mã loại
                                            </th>
                                            <th style="width:200px" class="text-center">
                                                Tên loại
                                            </th>
                                            <th style="width:120px" class="text-center">
                                                Hình ảnh
                                            </th>
                                            <th style="width:50px" class="text-center">
                                                <button type="button"
                                                        class="icon-button icon-inline icon-save"
                                                        title="Lưu thay đổi loại layout"
                                                        data-title="Lưu thay đổi loại layout"
                                                        data-position="right"
                                                        @onclick="SaveLoaiLayoutList">
                                                    <i class="mdi mdi-content-save save-icon"></i>
                                                </button>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="content-table">
                                        @if (Record.ListLoaiLayout != null && Record.ListLoaiLayout.Any() == true)
                                        {
                                            int sttLayout = 0;
                                            foreach (var item in Record.ListLoaiLayout)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        @(sttLayout + 1)
                                                    </td>
                                                    <td>
                                                        @if (item.IsNew == false)
                                                        {
                                                            <DisableTextBox Value="@item.MaLoaiThietKe" />
                                                        }
                                                        else
                                                        {
                                                            <InputText @bind-Value="item.MaLoaiThietKe" class="form-control input-validation" />
                                                        }
                                                    </td>
                                                    <td><InputText @bind-Value="item.TenLoaiThietKe" class="form-control input-validation" /></td>
                                                    <td>
                                                        <div class="tang-image-cell">
                                                            @if (!string.IsNullOrEmpty(item.HinhAnhUrl))
                                                            {
                                                                <!-- Chỉ render khi có hình -->
                                                                <div class="tang-image-preview has-image">
                                                                    <img src="@item.HinhAnhUrl"
                                                                         class="tang-thumb-img"
                                                                         title="Nhấn để xem lớn"
                                                                         @onclick="@(() => JS.InvokeVoidAsync("window.open", item.HinhAnhUrl, "_blank"))" />

                                                                    <!-- Nút Xóa hình -->
                                                                    <button type="button"
                                                                            class="img-btn-close"
                                                                            title="Xóa hình"
                                                                            @onclick="() => RemoveImage(item)">
                                                                        <i class="mdi mdi-close"></i>
                                                                    </button>

                                                                    <!-- Nút Tải về (tròn vàng giữa khung) -->
                                                                    <button type="button"
                                                                            class="img-btn-download"
                                                                            title="Tải ảnh về"
                                                                            @onclick="() => DownloadImage(item)">
                                                                        <i class="bi bi-download text-white"></i>
                                                                    </button>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <!-- Không có hình: vẫn giữ chỗ cho cột, nhưng ẩn -->
                                                                <div class="tang-image-preview no-image"></div>
                                                            }

                                                            <!-- Ô upload bên phải -->
                                                            <label class="tang-upload-box">
                                                                <i class="mdi mdi-upload tang-upload-icon"></i>
                                                                <span>Click vào để tải ảnh</span>
                                                                <InputFile key="@_imageInputKey" class="d-none"
                                                                           OnChange="@(e => OnImageSelected(item, e))"
                                                                           accept="image/*" />
                                                            </label>
                                                        </div>
                                                    </td>
                                                    <td class="text-center">
                                                        @if (item.SoLuongCanHo == 0)
                                                        {
                                                            <button type="button"
                                                                    class="icon-button icon-inline icon-delete"
                                                                    title="Xóa"
                                                                    data-title="Xóa"
                                                                    data-position="left"
                                                                    @onclick="() => DeleteRowLoaiLayout(item)">
                                                                <i class="mdi mdi-delete"></i>
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                                sttLayout++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </SectionHeader>
                    </div>
