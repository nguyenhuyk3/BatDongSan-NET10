@code {
    [Parameter]
    public string? id { get; set; }

    private EditContext editContext;
    private string[] allowedExtensions = FileTypeSets.Image;
    private FileUploader uploaderRef;

    private DuAnModel? Record = new();
    private bool _isRendered = false;
    private List<Select2Config> _select2Configs = new();
    private PopupTang? tangModalRef;
    private PopupTruc? trucModalRef;
    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(Record);

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync("DMDuAn", VuViec.CapNhat.GetDescription());
            var result = await DuAnService.GetByIdAsync(id ?? string.Empty, _env.WebRootPath);
            if (result.Status)
            {
                Record = (DuAnModel?)result.Data ?? new DuAnModel();
                // 🔥 Recreate EditContext sau khi có dữ liệu thật
                editContext = new EditContext(Record);
                // Render file đã có (nếu có)
                if (Record?.Files?.Any() == true)
                {
                    await uploaderRef.RenderInitialFiles(Record.Files);
                }
            }
            else
            {
                await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
            }
            _isRendered = true;

            // Khởi tạo Select2 theo chuẩn Block (initMany)
            _select2Configs = new()
            {
                new("TrangThai", "Chọn trạng thái", Record?.TrangThai?.ToString())
            };

            // Chờ control render xong rồi init
            await Task.Delay(150);
            await JS.InvokeVoidAsync("select2Helper.initMany", _select2Configs);
            await ReapplyCurrencyFormat();
            StateHasChanged();
        }
    }

    private async Task SubmitFormJs()
    {
        var dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("validateFormBlazor", "formDuAn", dotNetRef);
    }

    [JSInvokable]
    public async Task SubmitForm()
    {
        var result = await DuAnService.UpdateByIdAsync(Record);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
    }

    public void HandleFiles(List<UploadedFileModel> files)
    {
        Record.Files = files;
    }

    private void BackUrl()
    {
        Nav.NavigateTo("/duan");
    }

    // Chuẩn cấu hình Select2 giống Block
    public class Select2Config
    {
        public string id { get; set; }
        public string placeholder { get; set; }
        public string? value { get; set; }
        public bool allowClear { get; set; } = true;

        public Select2Config(string id, string placeholder, string? value)
        {
            this.id = id;
            this.placeholder = placeholder;
            this.value = value;
        }
    }

    private async Task AddBlock()
    {
        if (Record == null)
            return;

        // Nếu ListBlock đang null thì khởi tạo trước
        if (Record.ListBlock == null)
            Record.ListBlock = new List<BlockModel>();

        var newBlock = new BlockModel
        {
            IsNew = true,
            // có thể set thêm default nếu cần
            SoLuongTang = 0,
            SoLuongTruc = 0
        };

        // ✅ Chèn vào vị trí 0 để nằm trên cùng
        Record.ListBlock.Insert(0, newBlock);

        // Nếu cần chắc ăn, gọi lại render
        // await InvokeAsync(StateHasChanged);
    }

    private Task HandleTangSaved(PopupTang.TangSavedArgs e)
    {
        var blk = Record?.ListBlock?.FirstOrDefault(x =>
                     string.Equals(x.MaBlock, e.MaBlock, StringComparison.OrdinalIgnoreCase));
        if (blk != null)
        {
            blk.SoLuongTang = e.SoLuongTang;   // ← cập nhật số tầng ngay
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private Task HandleTrucSaved(PopupTruc.TrucSavedArgs e)
    {
        var blk = Record?.ListBlock?.FirstOrDefault(x =>
                     string.Equals(x.MaBlock, e.MaBlock, StringComparison.OrdinalIgnoreCase));
        if (blk != null)
        {
            blk.SoLuongTruc = e.SoLuongTruc;   // ← cập nhật số trục ngay
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private async Task SaveBlockList()
    {
        var ok = await JS.InvokeAsync<bool>(
    "validateContainer",
    ".block-table",                      // id container phần Block
    ".container-mess-error",           // (tuỳ chọn) hộp báo lỗi đang dùng
    "Có trường dữ liệu không chính xác hoặc không hợp lệ" // (tuỳ chọn) message
);
        if (!ok) return; // dừng, không lưu
        Loading.Show();
        try
        {
            var result = await DuAnService.SaveBlocksAsync(Record.MaDuAn, Record.ListBlock);
            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
            if (result.Status)
            {
                // Sau khi lưu thành công: tất cả block coi như không còn "mới" nữa
                if (Record.ListBlock != null)
                {
                    foreach (var b in Record.ListBlock)
                    {
                        b.IsNew = false;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", ex.Message, false);
        }
        finally
        {
            Loading.Hide();
        }
    }

