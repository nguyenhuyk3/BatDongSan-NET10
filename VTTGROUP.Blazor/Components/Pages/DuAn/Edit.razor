        if (string.IsNullOrWhiteSpace(file.ContentType) ||
            !file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", "File phải là hình ảnh.", false);
            _imageInputKey = Guid.NewGuid().ToString(); // reset selection
            StateHasChanged();
            return;
        }

        // 2) Validate size (chặn ngay từ đầu)
        if (file.Size > MaxImageBytes)
        {
            var mb = (file.Size / 1024d / 1024d);
            await JS.InvokeVoidAsync("showToast", "Lỗi", $"Hình vượt quá 5MB (hiện ~{mb:0.00}MB).", false);
            _imageInputKey = Guid.NewGuid().ToString(); // reset selection
            StateHasChanged();
            return;
        }

        try
        {
            var fullDomain = Nav.BaseUri.TrimEnd('/');

            var uploadFolder = Path.Combine(_env.WebRootPath, "uploads", "LoaiLayout");
            Directory.CreateDirectory(uploadFolder);

            var ext = Path.GetExtension(file.Name);
            var fileName = $"{(item.MaLoaiThietKe ?? "LoaiLayout")}_{Guid.NewGuid():N}{ext}";
            var physicalPath = Path.Combine(uploadFolder, fileName);

            // 3) Double safety: OpenReadStream vẫn set 5MB
            await using var readStream = file.OpenReadStream(MaxImageBytes);
            await using var writeStream = File.Create(physicalPath);
            await readStream.CopyToAsync(writeStream);

            var relativePath = $"/uploads/LoaiLayout/{fileName}";
            item.HinhAnhUrl = relativePath;
            item.FullDomain = fullDomain + relativePath;

            await JS.InvokeVoidAsync("showToast", "Thông báo", "Upload hình thành công.", true);
        }
        catch (IOException)
        {
            // trường hợp stream bị lỗi IO
            await JS.InvokeVoidAsync("showToast", "Lỗi", "Không đọc được file. Vui lòng thử lại.", false);
            _imageInputKey = Guid.NewGuid().ToString();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            // nếu lỡ vượt size mà lọt (hiếm), Blazor có thể ném exception tại OpenReadStream/Copy
            await JS.InvokeVoidAsync("showToast", "Lỗi", ex.Message, false);
            _imageInputKey = Guid.NewGuid().ToString();
            StateHasChanged();
        }
    }

