@page "/duan/edit/{id}"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.Uploads
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model.Block
@using VTTGROUP.Domain.Model.DMLoaiThietKe
@using VTTGROUP.Domain.Model.DuAn
@using VTTGROUP.Domain.Model.LoaiCanHo
@using VTTGROUP.Domain.Model.LoaiGoc
@using VTTGROUP.Domain.Model.ViTri
@using VTTGROUP.Domain.Model.View
@using VTTGROUP.Domain.Model.ViewMatKhoi
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Model
@inject IBaseService BaseService
@inject DuAnService DuAnService
@inject LoadingService Loading
@inject IJSRuntime JS
@inject IWebHostEnvironment _env
@inject NavigationManager Nav

<PageTitle>Cập nhật dự án</PageTitle>

<EditForm id="formDuAn" EditContext="@editContext">
    <h1 class="legend-title">Dự án</h1>
    <div class="container-form">
        <div class="container-tabs">
            <div class="row">
                <div class="col-md-12">
                </div>
            </div>
            <MessageErrorForm />
            <div class="wapper-content-tab">
                <div data-id="1" class="tab-content-item actived-tab" id="tab1">
                    <div class="col-lg-10 mx-auto row">
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Mã dự án</span>
                                    <DisableTextBox Value="@Record.MaDuAn" />
                                    <InputText hidden @bind-Value="Record.MaDuAn" />
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Tên dự án <i class="point-validate">*</i></span>
                                    <InputText class="form-control input-validation" id="TenDuAn" @bind-Value="Record.TenDuAn" />
                                    <span class="error-validation">Vui lòng nhập tên dự án</span>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Địa chỉ <i class="point-validate">*</i></span>
                                    <InputText class="form-control input-validation" id="DiaChi" @bind-Value="Record.DiaChi" />
                                    <span class="error-validation">Vui lòng nhập địa chỉ</span>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Tỉnh thành</span>
                                    <InputText class="form-control" id="TinhThanh" @bind-Value="Record.TinhThanh" />
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Xã phường</span>
                                    <InputText class="form-control" id="XaPhuong" @bind-Value="Record.XaPhuong" />
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Trạng thái</span>
                                    <select id="TrangThai" name="TrangThai" class="form-control" @bind="Record.TrangThai">
                                        <option value="">-- Chọn trạng thái --</option>
                                        <option value="1">Đang mở bán</option>
                                        <option value="2">Sắp mở bán</option>
                                        <option value="3">Đóng dự án</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-12">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Tập tin đính kèm</span>
                                    <div class="contatiner-upload-files">
                                        <FileUploader @ref="uploaderRef" AllowExtensions="allowedExtensions"
                                                      MaxFileSize="10485760"
                                                      AllowMultiple="true"
                                                      OnFilesChanged="HandleFiles" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-12">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Ghi chú</span>
                                    <textarea class="textarea-input p-2 text-sm" cols="20" rows="5" tabindex="2" @bind="Record.GhiChu"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-10 mx-auto row">
                        <SectionHeader Title="Block"
                                       OnAdd="AddBlock"
                                       DefaultExpanded="false">
                            <div class="overflow-auto block-table" id="container-table-fixed">
                                <table class="tbl table table-hover table-form table-detail">
                                    <thead>
                                        <tr>
                                            <th style="width:50px" class="text-center">
                                                STT
                                            </th>
                                            <th style="width:120px" class="text-center">
                                                Mã block
                                            </th>
                                            <th style="width:200px" class="text-center">
                                                Tên block
                                            </th>
                                            <th style="width:120px" class="text-center">
                                                Tầng
                                            </th>
                                            <th style="width:120px" class="text-center">
                                                Trục
                                            </th>
                                            <th style="width:50px" class="text-center">
                                                <button type="button"
                                                        class="icon-button icon-inline icon-save"
                                                        title="Lưu thay đổi block"
                                                        data-title="Lưu thay đổi block"
                                                        data-position="right"
                                                        @onclick="SaveBlockList">
                                                    <i class="mdi mdi-content-save save-icon"></i>
                                                </button>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="content-table">
                                        @if (Record.ListBlock != null && Record.ListBlock.Any() == true)
                                        {
                                            int sttBlock = 0;
                                            foreach (var item in Record.ListBlock)
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        @(sttBlock + 1)
                                                    </td>
                                                    <td>
                                                        @if (item.IsNew == false)
                                                        {
                                                            <DisableTextBox Value="@item.MaBlock" />
                                                        }
                                                        else
                                                        {
                                                            <InputText @bind-Value="item.MaBlock" class="form-control input-validation" />
                                                        }
                                                    </td>
                                                    <td><InputText @bind-Value="item.TenBlock" class="form-control input-validation" /></td>
                                                    <td>
                                                        <div class="cell-with-icon">
                                                            <span>@($"{item.SoLuongTang:#,##0}")</span>
                                                            @if (!item.IsNew)@* chỉ hiện icon khi block cũ *@
                                                            {
                                                                <button type="button"
                                                                        class="icon-button icon-inline"
                                                                        title="Thêm tầng cho block"
                                                                        @onclick="() => AddTangForBlock(item)">
                                                                    <i class="mdi mdi-plus-circle-outline"></i>
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="cell-with-icon">
                                                            <span>@($"{item.SoLuongTruc:#,##0}")</span>
                                                            @if (!item.IsNew)@* chỉ hiện icon khi block cũ *@
                                                            {
                                                                <button type="button"
                                                                        class="icon-button icon-inline"
                                                                        title="Thêm trục cho block"
                                                                        @onclick="() => AddTrucForBlock(item)">
                                                                    <i class="mdi mdi-plus-circle-outline"></i>
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                    <td class="text-center">
                                                        @if (item.SoLuongTang == 0 && item.SoLuongTruc == 0)
                                                        {
                                                            <button type="button"
                                                                    class="icon-button icon-inline icon-delete"
                                                                    data-title="Xóa"
                                                                    data-position="left"
                                                                    @onclick="() => DeleteRowBlock(item)">
                                                                <i class="mdi mdi-delete"></i>
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                                sttBlock++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </SectionHeader>
                    </div>
                    <div class="col-lg-10 mx-auto row">
                        <SectionHeader Title="Mặt khối"
                                       OnAdd="AddView"
                                       DefaultExpanded="false">
                            <div class="overflow-auto loaiview-table" id="container-table-fixed">
                                <table class="tbl table table-hover table-form table-detail">
                                    <thead>
                                        <tr>
                                            <th style="width:50px" class="text-center">
                                                STT
                                            </th>
                                            <th style="width:120px" class="text-center">
                                                Mã loại
                                            </th>
                                            <th style="width:200px" class="text-center">
                                                Tên loại
                                            </th>
                                            <th style="width:50px" class="text-center">
                                                <button type="button"
                                                        class="icon-button icon-inline icon-save"
