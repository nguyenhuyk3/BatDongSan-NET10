                                                        }
                                                    </td>
                                                    <td><InputText @bind-Value="item.TenLoaiCanHo" class="form-control input-validation" /></td>
                                                    <td class="text-center">
                                                        @if (item.SoLuongCanHo == 0)
                                                        {
                                                            <button type="button"
                                                                    class="icon-button icon-inline icon-delete"
                                                                    title="Xóa"
                                                                    data-title="Xóa"
