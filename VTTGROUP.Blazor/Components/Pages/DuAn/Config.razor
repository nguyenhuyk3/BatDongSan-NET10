                    new() { FieldName="NgayQuaHanTungDotChoPhep", DisplayName="Ngày quá hạn từng đợt cho phép", Value=string.Format("{0:#,#0}", Record?.NgayQuaHanTungDotChoPhep), OriginalValue=string.Format("{0:#,#0}", Record?.NgayQuaHanTungDotChoPhep) },
