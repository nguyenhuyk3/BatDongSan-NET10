												{
													<div class="input-wraper-choose">
														<div class="d-flex align-items-center">
															<label class="switch-toggle mb-0">
																<input type="checkbox" checked="@Convert.ToBoolean(item.Value)" @onclick="(e) => OnToggleCheckbox(item, !Convert.ToBoolean(item.Value))" />
																<span class="slider"></span>
															</label>
															<span class="label-text ms-2 mb-0">@(Convert.ToBoolean(item.Value) ? "On" : "Off")</span>
