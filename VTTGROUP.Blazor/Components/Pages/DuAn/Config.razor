@page "/duan/config/{id}"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model.DMSanGiaoDich
@using VTTGROUP.Domain.Model.DuAn
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Model
@inject IBaseService BaseService
@inject DuAnService DuAnService
@inject IJSRuntime JS
@inject IWebHostEnvironment _env
@inject NavigationManager Nav
<PageTitle>Cấu hình dự án</PageTitle>
<EditForm id="formDuAn" EditContext="@editContext">
    <h1 class="legend-title">Cấu hình Dự án</h1>
    <div class="container-form">
        <div class="container-tabs">
            <div class="row">
                <div class="col-md-12">
                    <ul class="tab-element">
                        <li class="tab-item actived-tab" data-id="1" id="linkTab1">Thông tin cấu hình</li>
                        <li class="tab-item" data-id="2" id="linkTab2">Đợt mở bán</li>
                        <li class="tab-item" data-id="3" id="linkTab3">Sàn giao dịch</li>
                        <div class="line-bot-nav animated" style="width: 154px; left: 0px;">
                        </div>
                    </ul>
                </div>
            </div>
            <div class="wapper-content-tab">
                <div data-id="1" class="tab-content-item actived-tab" id="tab1">
                    <div class="col-lg-10 mx-auto row">
                        <div class="wapper-input col-lg-12">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Dự án</span>
                                    <span class="input-value">@Record.TenDuAn</span>
                                </div>
                            </div>

                        </div>
                        @if (Fields.Any())
                        {
                            @* foreach (var item in Fields)
