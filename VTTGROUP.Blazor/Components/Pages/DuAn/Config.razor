                    new() { FieldName="IsHienThiGiaTran", DisplayName="Hiển thị giá trần khi mở bán", Value=Record?.IsHienThiGiaTran?.ToString(), OriginalValue=Record?.IsHienThiGiaTran?.ToString() ,IsCheckBox = true},
