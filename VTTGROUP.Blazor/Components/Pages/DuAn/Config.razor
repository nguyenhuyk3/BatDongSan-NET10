											</div>
										</div>
									</div>
								}
							} *@
                            @* Group 1 *@
                            <div class="field-group">
                                <div class="row">
                                    @foreach (var fieldName in fieldGroups["Group1"])
                                    {
                                        var item = Fields.FirstOrDefault(f => f.FieldName == fieldName);
                                        if (item == null) { continue; }

                                        string extentText = fieldName == "ThoiGianChoBookGioHangRieng" || fieldName == "ThoiGianChoBookGioHangChung" ? "phút" :
                                        fieldName == "TyLeThueVAT" || fieldName == "TyLeQuyBaoTri" || fieldName == "TyLeLaiQuaHan" ? "%" : string.Empty;

                                        <div class="wapper-input @(item.IsCheckBox == true ? "col-lg-2" : "col-lg-6")">
                                            <div class="row">
                                                <div class="form-group-input">
                                                    <div class="title-field">@item.DisplayName</div>
                                                    @if (item.IsCheckBox == true)
                                                    {
                                                        <div class="input-wraper-choose">
                                                            <div class="d-flex align-items-center">
                                                                <label class="switch-toggle mb-0">
                                                                    <input type="checkbox" checked="@Convert.ToBoolean(item.Value)" @onclick="(e) => OnToggleCheckbox(item, !Convert.ToBoolean(item.Value))" />
                                                                    <span class="slider"></span>
                                                                </label>
                                                                <span class="label-text ms-2 mb-0">@(Convert.ToBoolean(item.Value) ? "On" : "Off")</span>
                                                            </div>
                                                            <div class="icon-choose">
                                                                <i class="bi bi-clock-history" @onclick="() => ViewHistory(item)"></i>
                                                            </div>
                                                        </div>
                                                    }
                                                    else if (item.FieldName == "PhuongThucTinhChietKhauKM")
                                                    {
                                                        <div class="input-wraper-choose @(item.HasError ? "has-error-danger" : "")">
                                                            <select class="form-select form-control input-form @(item.HasError ? "border-danger" : "")"
                                                                    id="@(item.FieldName)"
                                                                    @bind="item.Value">
                                                                <option value="">-- Chọn phương thức --</option>
                                                                <option value="1">Chiết khấu trực tiếp</option>
                                                                <option value="2">Chiết khấu theo STT</option>
                                                            </select>

                                                            @if (item.HasError)
                                                            {
                                                                <span class="error-validation xtop-2" style="display:block!important">
                                                                    Vui lòng chọn @item.DisplayName
                                                                </span>
                                                            }

                                                            <div class="icon-choose icon-mr" @onclick="() => Save(item)">
                                                                <i class="mdi mdi-content-save"></i>
                                                            </div>
                                                            <div class="icon-choose" @onclick="() => ViewHistory(item)">
                                                                <i class="bi bi-clock-history"></i>
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="input-wraper-choose @(item.HasError ? "has-error-danger" : "")">
                                                            @if (!string.IsNullOrEmpty(extentText))
                                                            {
                                                                <div class="input-group">
                                                                    <div class="input-group-text">@extentText</div>
                                                                    <input class="form-control select-on-click currency-input @(item.HasError ? "border-danger" : "")" type="text" id="@(item.FieldName)" @bind="item.Value" />
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <input class="form-control input-form select-on-click currency-input @(item.HasError ? "border-danger" : "")" type="text" id="@(item.FieldName)" @bind="item.Value" />
                                                            }
                                                            @if (item.HasError)
                                                            {
                                                                <span class="error-validation xtop-2" style="display:block!important">Vui lòng nhập @item.DisplayName</span>
                                                            }
                                                            <div class="icon-choose icon-mr" @onclick="() => Save(item)">
                                                                <i class="mdi mdi-content-save"></i>
                                                            </div>
                                                            <div class="icon-choose" @onclick="() => ViewHistory(item)">
                                                                <i class="bi bi-clock-history"></i>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            @* Group 2 *@
                            <div class="field-group">
                                <div class="row">
                                    @foreach (var fieldName in fieldGroups["Group2"])
                                    {
                                        var item = Fields.FirstOrDefault(f => f.FieldName == fieldName);
                                        if (item == null) { continue; }

                                        <div class="wapper-input col-lg-6">
                                            <div class="row">
                                                <div class="form-group-input">
                                                    @if (fieldName == "SoLuongBookingToiDa")
                                                    {
                                                        if (Fields.FirstOrDefault(f => f.FieldName == "ChoPhepNhieuBookingCho1Can")?.Value == "True")
                                                        {
                                                            <div class="title-field">@item.DisplayName</div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div class="title-field">@item.DisplayName</div>
                                                    }

                                                    @if (item.IsCheckBox == true)
                                                    {
                                                        <div class="input-wraper-choose">
                                                            <div class="d-flex align-items-center">
                                                                <label class="switch-toggle mb-0">
                                                                    <input type="checkbox" checked="@Convert.ToBoolean(item.Value)" @onclick="(e) => OnToggleCheckbox(item, !Convert.ToBoolean(item.Value))" />
                                                                    <span class="slider"></span>
                                                                </label>
                                                                <span class="label-text ms-2 mb-0">@(Convert.ToBoolean(item.Value) ? "On" : "Off")</span>
                                                            </div>
                                                            <div class="icon-choose">
                                                                <i class="bi bi-clock-history" @onclick="() => ViewHistory(item)"></i>
                                                            </div>
                                                        </div>
                                                    }
                                                    else if (Fields.FirstOrDefault(f => f.FieldName == "ChoPhepNhieuBookingCho1Can")?.Value == "True")
                                                    {
                                                        <div class="input-wraper-choose @(item.HasError ? "has-error-danger" : "")">
                                                            <input class="form-control input-form select-on-click currency-input @(item.HasError ? "border-danger" : "")" type="text" id="@(item.FieldName)" @bind="item.Value" />
                                                            @if (item.HasError)
                                                            {
                                                                <span class="error-validation xtop-2" style="display:block!important">Vui lòng nhập @item.DisplayName</span>
                                                            }
                                                            <div class="icon-choose icon-mr" @onclick="() => Save(item)">
                                                                <i class="mdi mdi-content-save"></i>
                                                            </div>
                                                            <div class="icon-choose" @onclick="() => ViewHistory(item)">
                                                                <i class="bi bi-clock-history"></i>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            @* Group 3 *@
                            <div class="field-group">
                                <div class="row">
                                    @foreach (var fieldName in fieldGroups["Group3"])
                                    {
                                        var item = Fields.FirstOrDefault(f => f.FieldName == fieldName);
                                        if (item == null)
                                        {
                                            if (fieldName == "EmptyColumn")
                                            {
                                                <div class="wapper-input col-lg-6"></div>
                                            }
                                            continue;
                                        }

                                        <div class="wapper-input col-lg-6">
                                            <div class="row">
                                                <div class="form-group-input">
                                                    @if ((fieldName == "ChenhLechGiaTran" || fieldName == "PhanSoLamTron"))
                                                    {
                                                        if (Fields.FirstOrDefault(f => f.FieldName == "IsHienThiGiaTran")?.Value == "True")
                                                        {
                                                            <div class="title-field">@item.DisplayName</div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div class="title-field">@item.DisplayName</div>
                                                    }

                                                    @if (item.IsCheckBox == true)
                                                    {
                                                        <div class="input-wraper-choose">
                                                            <div class="d-flex align-items-center">
                                                                <label class="switch-toggle mb-0">
                                                                    <input type="checkbox" checked="@Convert.ToBoolean(item.Value)" @onclick="(e) => OnToggleCheckbox(item, !Convert.ToBoolean(item.Value))" />
                                                                    <span class="slider"></span>
                                                                </label>
                                                                <span class="label-text ms-2 mb-0">@(Convert.ToBoolean(item.Value) ? "On" : "Off")</span>
                                                            </div>
                                                            <div class="icon-choose">
                                                                <i class="bi bi-clock-history" @onclick="() => ViewHistory(item)"></i>
                                                            </div>
                                                        </div>
                                                    }
                                                    else if (Fields.FirstOrDefault(f => f.FieldName == "IsHienThiGiaTran")?.Value == "True")
                                                    {
                                                        <div class="input-wraper-choose @(item.HasError ? "has-error-danger" : "")">
                                                            <input class="form-control input-form select-on-click currency-input @(item.HasError ? "border-danger" : "")" type="text" id="@(item.FieldName)" @bind="item.Value" />
                                                            @if (item.HasError)
                                                            {
                                                                <span class="error-validation xtop-2" style="display:block!important">Vui lòng nhập @item.DisplayName</span>
                                                            }
                                                            <div class="icon-choose icon-mr" @onclick="() => Save(item)">
                                                                <i class="mdi mdi-content-save"></i>
                                                            </div>
                                                            <div class="icon-choose" @onclick="() => ViewHistory(item)">
                                                                <i class="bi bi-clock-history"></i>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div data-id="2" class="tab-content-item" id="tab2">
                    <div class="col-lg-6 mx-auto row">
                        <div class="wapper-button-head-table mb-2" style="width: 100%">

                            <div class="button-action-title" style="margin-left: 0;">
                                <div class="icon-button" @onclick="AddDot">
                                    <i class="mdi mdi-playlist-plus"></i>
                                </div>
                                <span>Đợt mở bán</span>
                            </div>
                        </div>
                        @*Bảng hiển thị Đợt mở bán*@
                        <div class="overflow-auto" id="container-table-fixed">
                            <div class="overflow-auto" id="container-table-fixed">
                                <table id="table-data" class="tbl table table-hover table-form table-detail">
                                    <thead>
                                        <tr>
                                            <th class="text-center">STT</th>
                                            <th class="text-center">Tên đợt</th>
                                            <th class="text-center">Mã màu</th>
                                            <th class="text-center">Ngày bắt đầu</th>
                                            <th class="text-center">Ngày kết thúc</th>
                                            <th class="text-center">Trạng thái kích hoạt</th>
                                            <th class="text-center"></th>
                                        </tr>
                                    </thead>
                                    <tbody class="content-table">
                                        @if (ListDots != null && ListDots.Any())
                                        {
                                            foreach (var item in ListDots)
                                            {
                                                <tr>
                                                    <td class="text-center">@item.ThuTuHienThi</td>
                                                    <td>@item.TenDotMoBan</td>
                                                    <td class="text-center">
                                                        <span class="bg-mau-dot" style="background-color:@(item.MaMau)"></span>
                                                    </td>
                                                    <td class="text-center">@string.Format("{0:dd/MM/yyyy}", item.NgayBatDau)</td>
                                                    <td class="text-center">@string.Format("{0:dd/MM/yyyy}", item.NgayKetThuc)</td>
                                                    <td class="text-center">
                                                        <div class="d-flex align-items-center justify-content-center">
                                                            <label class="switch-toggle mb-0">
                                                                <input type="checkbox" checked="@(item.IsKichHoat ?? false)"
                                                                       @onclick="(e) => OnToggleDotCheckbox(item, !Convert.ToBoolean(item.IsKichHoat))" />
                                                                <span class="slider"></span>
                                                            </label>
                                                            <span class="label-text ms-2 mb-0">@(item.IsKichHoat == true ? "On" : "Off")</span>
                                                        </div>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="icon-choose icon-edit" @onclick="() => OpenEditDotPopup(item)">
                                                            <i class="mdi mdi-pencil"></i>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>


                        </div>
                    </div>
                </div>
                @* Tab 3 *@
                <div data-id="3" class="tab-content-item" id="tab3">
                    <div class="col-lg-6 mx-auto row">
                        @*Nút để hiển thị popup thêm sàn giao dịch*@
                        <div class="button-action-title"
                             style="
                                    margin-left: 0;
                                    margin-bottom: 8px;
                                    ">
                            <div class="icon-button" @onclick="OpenAddPopupSgd">
                                <i class="mdi mdi-playlist-plus"></i>
                            </div>
                            <span>Sàn giao dịch</span>
                        </div>
                        @*Table để hiển thị dữ liệu sàn*@
                        <div class="overflow-auto" id="container-table-fixed">
                            <table id="table-data" class="tbl table table-hover table-form table-detail">
                                <thead>
                                    <tr>
                                        <th class="text-center">STT</th>
                                        <th class="text-center">Mã sàn</th>
                                        <th class="text-center">Tên sàn</th>
                                        <th class="text-center">Số lượng booking</th>
                                        <th class="text-center"></th>
                                    </tr>
                                </thead>
                                <tbody class="content-table">
                                    @if (ListSGDs != null && ListSGDs.Any())
                                    {
                                        int i = 1;

                                        foreach (var item in ListSGDs)
                                        {

                                            <tr>
                                                <td class="text-center">@i</td>
                                                <td>@item.MaSanGiaoDich</td>
                                                <td>@item.TenSanGiaoDich</td>
                                                <td>
                                                    <InputCurrency T="int"
                                                                   Id=@($"SoLuongBooking{item.MaSanGiaoDich}")
                                                                   Format="#,##0"
                                                                   CssClass="input-form is-right input-currency form-control input-validation select-on-click w-100 p-1 ms-2"
                                                                   @bind-Value="item.SoLuongBooking" />
                                                </td>
                                                <td class="text-center">
                                                    <div class="d-flex align-items-center justify-content-center gap-2">
                                                        @*Nút lưu*@
                                                        <div class="icon-choose icon-mr icon-save" @onclick="() => SaveSGD(item)">
                                                            <i class="mdi mdi-content-save"></i>
                                                        </div>
                                                        @*Nút yêu cầu xóa*@
                                                        <div class="icon-choose icon-delete"
                                                             @onclick="() => AskDeleteSGD(item)">
                                                            <i class="mdi mdi-delete"></i>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>

                                            i++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-button">
        <div class="actions-left">
            <UiButton Preset="back" Variant="secondary" OnClick="BackUrl" />
        </div>
    </div>
</EditForm>
<PopupLichSu @ref="lichSuModalRef" />
<PopupCreateDot @ref="createDotModalRef" OnLoadDot="LoadDot" />
<PopupChinhSuaDotMoBan @ref="chinhSuaDotModalRef" OnUpdated="LoadDot" />
<PopupAddSanGiaoDich @ref="sanGiaoDichModalRef" OnSelected="OnSelectedSGDs" />
@if (showConfirm && editingItem != null)
{
    <div class="modal-xacnhan modal-backdrop fade show"></div>
    <div class="modal-xacnhan modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Xác nhận</h5>
                </div>
                <div class="modal-body">
                    <p>@confirmMessage</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="button button-action button-luu-phieu" @onclick="ConfirmSave">
                        Đồng ý
                    </button>
                    <button type="button" class="button button-action button-huy" @onclick="CancelConfirm">Hủy</button>
                </div>

            </div>
        </div>
    </div>
}
@if (showConfirmSGD && editingItemSGD != null)
{
    <div class="modal-xacnhan modal-backdrop fade show"></div>
    <div class="modal-xacnhan modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Xác nhận cập nhật số lượng booking</h5>
                </div>
                <div class="modal-body">
                    <p>@confirmMessage</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="button button-action button-luu-phieu" @onclick="ConfirmSaveSGD">
                        Đồng ý
                    </button>
                    <button type="button" class="button button-action button-huy" @onclick="CancelConfirm">Hủy</button>
                </div>

            </div>
        </div>
    </div>
}
@if (showConfirmDot && editingItemDot != null)
{
    <div class="modal-xacnhan modal-backdrop fade show"></div>
    <div class="modal-xacnhan modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Xác nhận</h5>
                </div>
                <div class="modal-body">
                    <p>@confirmMessage</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="button button-action button-luu-phieu" @onclick="ConfirmSaveDot">
                        Đồng ý
                    </button>
                    <button type="button" class="button button-action button-huy" @onclick="CancelConfirmSGD">Hủy</button>
                </div>
            </div>
        </div>
    </div>
}
@if (showConfirmDeleteSGD && deletingItemSGD != null)
{
    <div class="modal-xacnhan modal-backdrop fade show"></div>
    <div class="modal-xacnhan modal d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Xác nhận xoá</h5>
                </div>
                <div class="modal-body">
                    <p>@confirmMessage</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="button button-action button-luu-phieu" @onclick="ConfirmDeleteSGD">
                        Đồng ý
                    </button>
                    <button type="button" class="button button-action button-huy" @onclick="CancelDeleteSGD">Hủy</button>
                </div>

            </div>
        </div>
    </div>
}
