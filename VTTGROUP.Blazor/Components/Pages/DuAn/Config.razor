    void OnToggleCheckbox(ConfigFieldDto item, bool newValue)
    {
        // Lưu lại item đang xử lý + giá trị user vừa chọn
        item.Value = newValue.ToString();
        editingItem = item;
        pendingCheckboxValue = newValue;

        confirmMessage = $"Bạn chắc chắn muốn thay đổi {item.DisplayName}?";
        showConfirm = true;
    }
    async Task ViewHistory(ConfigFieldDto item)
    {
        await lichSuModalRef?.Show(Record?.MaDuAn, item);
    }

    void CancelConfirm()
    {
        if (editingItem != null)
        {
            editingItem.Value = editingItem.OriginalValue; //rollback
            editingItem.IsEditing = false;
        }

        editingItem = null;
        pendingCheckboxValue = null;
        showConfirm = false;
        StateHasChanged();
    }

    void Save(ConfigFieldDto item)
    {
        if (item.FieldName == "PhuongThucTinhChietKhauKM")
        {
            var v = (item.Value ?? "").Trim();
            if (v != "1" && v != "2")
            {
                item.HasError = true;
                return;
            }
        }
        else
        {
            if (string.IsNullOrWhiteSpace(item.Value?.ToString()))
            {
                item.HasError = true;
                return;
            }
        }
        // Nếu hợp lệ -> show popup confirm
        confirmMessage = $"Bạn có chắc muốn lưu {item.DisplayName}?";
        editingItem = item;
        showConfirm = true;
    }

    async Task ConfirmSave()
    {
        if (editingItem != null)
        {
            // var rawValue = editingItem.Value?.Replace(",", "");
            var rawValue = editingItem.Value?.ToString()?.Trim();

            if (editingItem.FieldName != "PhuongThucTinhChietKhauKM")
                rawValue = rawValue?.Replace(",", "");
            if (editingItem.FieldName == "IsKichHoatGh" || editingItem.FieldName == "IsMoBanCoGia" || editingItem.FieldName == "ChoPhepNhieuBookingCho1Can" || editingItem.FieldName == "IsHienThiGiaTran")
            {
                rawValue = pendingCheckboxValue?.ToString();
                editingItem.Value = pendingCheckboxValue.ToString();
            }

            var result = await DuAnService.UpdateCauHinhByIdAsync(id ?? string.Empty,
                                                        editingItem.FieldName,
                                                        rawValue);

            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);

            editingItem.OriginalValue = editingItem.Value;
            editingItem.IsEditing = false;
        }

        editingItem = null;
        pendingCheckboxValue = null;
        showConfirm = false;
        needInitJs = true;
        StateHasChanged();
    }

