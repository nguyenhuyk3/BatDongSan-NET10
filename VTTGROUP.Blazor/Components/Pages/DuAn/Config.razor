    private void AskDeleteSGD(SanGiaoDichBookingDto item)
    {
        confirmMessage = $"Bạn có chắc muốn xoá sàn giao dịch {item.TenSanGiaoDich} khỏi dự án?";
        deletingItemSGD = item; // Biến toàn cục để lưu lại item đang yêu cầu xóa, tránh trường hợp user click nhanh nhiều item khác
        showConfirmDeleteSGD = true;
    }

    private async Task ConfirmDeleteSGD()
    {
        if (deletingItemSGD != null)
        {
            var result = await DuAnService.RemoveSGDFromDuAnAsync(id ?? string.Empty, deletingItemSGD.MaSanGiaoDich);

            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);

            if (result.Status)
            {
                // Cập nhập lại danh sách sgd sau khi xóa 1 sgd
                ListSGDs = await DuAnService.GetSanGiaoDichBookingByDuAnAsync(id ?? string.Empty);

                await ReapplyCurrencyFormat();
            }
        }

        deletingItemSGD = null;
        showConfirmDeleteSGD = false;

        StateHasChanged();
    }

    private void CancelDeleteSGD()
    {
        deletingItemSGD = null;
        showConfirmDeleteSGD = false;

        StateHasChanged();
    }

    # endregion

    # region Xử lí thêm sàn giao dịch ở tab "Sàn giao dịch"
    private async Task OpenAddPopupSgd()
    {
        await sanGiaoDichModalRef?.ShowPopupAsync(id);
    }

    private async Task OnSelectedSGDs(List<SanGiaoDichPagingDto>? selectedSGDs)
    {
        if (selectedSGDs == null || !selectedSGDs.Any())
        {
            return;
        }

        var listMaSGDs = selectedSGDs.Select(s => s.MaSanGiaoDich).ToList();
        var result = await DuAnService.AddSGDToDuAnAsync(id ?? string.Empty, listMaSGDs);

        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);

        if (result.Status)
        {
            ListSGDs = await DuAnService.GetSanGiaoDichBookingByDuAnAsync(id ?? string.Empty);

            await ReapplyCurrencyFormat();

            StateHasChanged();
        }
    }
    #endregion
