															</div>
														}
														else
														{
															<input class="form-control input-form select-on-click currency-input @(item.HasError ? "border-danger" : "")" type="text" id="@(item.FieldName)" @bind="item.Value" />
														}
														@if (item.HasError)
														{
															<span class="error-validation xtop-2" style="display:block!important">Vui lòng nhập @item.DisplayName</span>
														}
														<div class="icon-choose icon-mr" @onclick="() => Save(item)">
															<i class="mdi mdi-content-save"></i>
														</div>
														<div class="icon-choose" @onclick="() => ViewHistory(item)">
															<i class="bi bi-clock-history"></i>
