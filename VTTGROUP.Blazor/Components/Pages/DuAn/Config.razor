    //Format định dạng số thập phân
    private async Task ReapplyCurrencyFormat()
    {
        await JS.InvokeVoidAsync("InputUtils.makeCurrencyFormatByClass", "input-currency", 9, 0);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync("DMDuAn", VuViec.CapNhat.GetDescription());
            await JS.InvokeVoidAsync("tabHelper.initTabs");
            if (Fields.Any())
            {
                foreach (var item in Fields)
                {
                    if (jsConfig.TryGetValue(item.FieldName, out var cfg))
                    {
                        await JS.InvokeVoidAsync("InputUtils.makeCurrencyFormatById", item.FieldName, cfg.len, cfg.dec);
                        await JS.InvokeVoidAsync("InputUtils.selectAllOnClickByClass", "select-on-click");
                    }
                }
            }
        }

        if (needInitJs)
        {
            if (Fields.Any())
            {
                foreach (var item in Fields)
                {
                    if (jsConfig.TryGetValue(item.FieldName, out var cfg))
                    {
                        await JS.InvokeVoidAsync("InputUtils.makeCurrencyFormatById", item.FieldName, cfg.len, cfg.dec);
                        await JS.InvokeVoidAsync("InputUtils.selectAllOnClickByClass", "select-on-click");
                    }
                }
            }
        }
    }

    Dictionary<string, (int len, int dec)> jsConfig = new()
{
