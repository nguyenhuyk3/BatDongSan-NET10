@page "/duan"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Model.DuAn
@using VTTGROUP.Domain.Helpers
@inject DuAnService DuAnService
@inject IBaseService BaseService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IWebHostEnvironment _env

<PageTitle>Danh sách dự án</PageTitle>

<h1 class="legend-title">Danh sách dự án</h1>

@* <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm mb-3 space-y-3"> *@
<div class="rounded-xl bg-white p-4 space-y-3 wraper-content-page">
    <div class="relative z-50">
        <div class="flex flex-wrap items-end gap-3">
            <div class="ml-auto flex items-center gap-2">
                <AddButton Text="Dự án" OnClick="Insert" />
            </div>
        </div>
    </div>
    @*   <div class="flex flex-wrap items-end gap-3">
    <div></div>
    <div class="ml-auto"></div>
    <VTTGROUP.Blazor.Components.CompChilds.AddButton Text="Thêm dự án" OnClick="Insert" />
    </div> *@

    <div class="container-table-detail">
        <div class="container-table-fixed has-paging">
            <table class="tbl table-form table-detail treeTable" id="table-data">
                <thead>
                    <tr class="cls_custome_back">
                        <th style="width: 120px" class="text-center">Mã dự án</th>
                        <th style="width: 220px" class="text-center">Tên dự án</th>
                        <th style="width: 240px" class="text-center">Địa chỉ</th>
                        <th style="width: 180px" class="text-center">Tỉnh thành</th>
                        <th style="width: 180px" class="text-center">Xã phường</th>
                        <th style="width: 240px" class="text-center">Ghi chú</th>
                        <th style="width: 160px" class="text-center">Trạng thái</th>
                        <th style="width: 90px">&nbsp;</th>
                    </tr>
                </thead>

                <tbody class="content-table">
                    @if (ChiTietDuAn != null && ChiTietDuAn.Any())
                    {
                        foreach (var item in ChiTietDuAn)
                        {
                            <tr class="initialized">
                                <td>
                                    <span>
                                        @item.MaDuAn
                                    </span>
                                </td>
                                <td><span>@item.TenDuAn</span></td>
                                <td><span>@item.DiaChi</span></td>
                                <td><span>@item.TinhThanh</span></td>
                                <td><span>@item.XaPhuong</span></td>
                                <td><span>@item.GhiChu</span></td>
                                <td>
                                    @if (item.TrangThai == 3)
                                    {
                                        <span>Đóng dự án</span>
                                    }
                                    else if (item.TrangThai == 2)
                                    {
                                        <span>Sắp mở bán</span>
                                    }
                                    else
                                    {
                                        <span>Đang mở bán</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center">
                                        <div class="icon-button" data-title="Cấu hình" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => OnConfigRecord(item.MaDuAn!)">
                                                <span><i class="mdi mdi-settings"></i></span>
                                            </a>
                                        </div>
                                        <div class="icon-button" data-title="Cập nhật" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => OnEditRecord(item.MaDuAn!)">
                                                <span><i class="mdi mdi-pencil"></i></span>
                                            </a>
                                        </div>
                                        <div class="icon-button" data-title="Xóa" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => ShowConfirmDelete(item.MaDuAn!)">
                                                <span><i class="mdi mdi-delete"></i></span>
                                            </a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            @if (ChiTietDuAn == null || !ChiTietDuAn.Any())
            {
                <div class="p-2">Không có dữ liệu</div>
            }
        </div>
    </div>



    @* <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true"> *@
    @*     <div class="modal-dialog modal-dialog-centered"> *@
    @*         <div class="modal-content delete-confirm"> *@
    @*             <button type="button" class="btn-close delete-close" data-bs-dismiss="modal" aria-label="Đóng"></button> *@

    @*             <div class="delete-head"> *@
    @*                 <div class="delete-badge"> *@
    @*                     <i class="mdi mdi-alert-circle-outline"></i> *@
    @*                 </div> *@
    @*                 <h5 class="delete-title">Xác nhận xoá thông tin</h5> *@
    @*                 <p class="delete-desc">Bạn có chắc muốn xóa công việc <strong>@selectedMaCongViec</strong> không?</p> *@
    @*             </div> *@

    @*             <div class="delete-actions"> *@
    @*                 <button type="button" class="btn-cancel" data-bs-dismiss="modal">Huỷ thao tác</button> *@
    @*                 <button type="button" class="btn-delete" @onclick="ConfirmDelete">Xoá vĩnh viễn</button> *@
    @*             </div> *@
    @*         </div> *@
    @*     </div> *@
    @* </div> *@
    <VTTGROUP.Blazor.Components.CompChilds.ConfirmDeleteModal ModalId="confirmDeleteModal"
                                                              Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa dự án <strong>@selectedMaCongViec</strong> không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDelete">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </VTTGROUP.Blazor.Components.CompChilds.ConfirmDeleteModal>

</div>

<style>
    .left-slot > * {
        margin-left: 0 !important;
    }
</style>

@code {
    private List<DuAnModel> ChiTietDuAn = new();
    private string? selectedMaCongViec;

    protected override async Task OnInitializedAsync()
    {
        ChiTietDuAn = await DuAnService.GetDuAnAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync("DMDuAn", VuViec.Xem.GetDescription());
        }
    }

    private async Task ShowConfirmDelete(string maDuAn)
    {
        var coQuyen = await BaseService.KiemTraQuyenVuViec("DMDuAn", VuViec.Xoa.GetDescription());
        if (coQuyen == false)
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Bạn không có quyền xóa. Xin vui lòng liên hệ quản trị", false);
            return;
        }
        selectedMaCongViec = maDuAn;
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteModal");
    }

    private async Task ConfirmDelete()
    {
        if (selectedMaCongViec == null || string.IsNullOrEmpty(selectedMaCongViec))
        {
            return;
        }
        var result = await DuAnService.DeleteDuAnAsync(selectedMaCongViec, _env.WebRootPath);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteModal");
        ChiTietDuAn = await DuAnService.GetDuAnAsync();
        selectedMaCongViec = string.Empty;
        StateHasChanged();
    }

    private async Task OnEditRecord(string maDuAn)
    {
        Nav.NavigateTo($"/duan/edit/{maDuAn}");
    }

    private async Task OnConfigRecord(string maDuAn)
    {
        Nav.NavigateTo($"/duan/config/{maDuAn}");
    }

    private void Insert()
    {
        Nav.NavigateTo("/duan/create");
        return;
    }
}
