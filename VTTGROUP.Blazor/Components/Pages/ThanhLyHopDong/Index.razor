@page "/thanhlyhopdong"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.Paging
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model
@using VTTGROUP.Domain.Model.ThanhLyHopDong
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@inject IBaseService BaseService
@inject ThanhLyHopDongService ThanhLyHopDongService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IWebHostEnvironment _env

<h1 class="legend-title">Thanh lý hợp đồng</h1>
<div class="container-search-home">
    <div class="search-row" style="margin-bottom: 15px;">
        <div class="col-search wapper-congtrinh container-form">
            <div class="result-label-icon">
                <i class="mdi mdi-calendar-today"></i>
                <DateRangePicker OnDateRangeChanged="OnDateRangeChanged" @ref="dateRangeRef" />
            </div>
        </div>
        <div class="col-search wapper-congtrinh container-form">
            <div class="result-label-icon">
                <i class="mdi mdi-file-document"></i>
                <select name="MaDuAn" id="MaDuAn" class="form-control" @onchange="OnDTKHChanged">
                    <option value="">-- Chọn dự án --</option>
                    @foreach (var item in ListDA)
                    {
                        <option value="@(item.MaDuAn)">@item.TenDuAn</option>
                    }
                </select>
            </div>
        </div>
        <div class="container-filter-home">
            <MoreFilterPopup OnTrangThaiChanged="OnTTDChanged"
                             OnReset="ResetMore" @ref="morePopupRef" />
            <div class="icon-button button-reset-all" @onclick="ResetAllParam" data-title="Xóa bộ lọc" data-position="left">
                <i class="mdi mdi-filter-remove"></i>
            </div>
        </div>
    </div>
    <div class="search-row">
        <div class="wapper-form-search">
            <input type="text" class="input-search input-form" autocomplete="off" @bind="search" id="searchText" name="TuKhoa" placeholder="Nhập nội dung cần tìm...">
            <button type="button" class="button-search" @onclick="Search">
                <i class="mdi mdi-magnify icon-search"></i>
            </button>
        </div>
        <div class="button-action-title">
            <div class="icon-button" id="btnThem" data-title="Thêm" data-position="left" @onclick="Insert">
                <i class="mdi mdi-plus-circle-outline"></i>
            </div>
            <span>Hợp đồng</span>
        </div>
    </div>
</div>
<div class="container-table-detail">
    <div class="container-table-fixed has-paging">
        <table class="tbl table-form table-detail treeTable" id="table-data">
            <thead>
                <tr class="cls_custome_back">
                    <th style="width: 50px">
                        STT
                    </th>
                    <th style="width: 130px">Hệ thống</th>
                    <th style="width: 220px">Dự án</th>
                    <th style="width: 170px">Hợp đồng</th>
                    <th style="width: 150px">
                        Giá trị hợp đồng
                    </th>
                    <th style="width: 150px">
                        Số tiền thanh lý
                    </th>
                    <th style="width: 250px">
                        Lý do
                    </th>
                    <th style="width: 90px">
                        &nbsp;
                    </th>
                </tr>
            </thead>
            <tbody class="content-table">
                @if (listTLDC != null && listTLDC.Count > 0)
                {
                    @foreach (var item in listTLDC)
                    {
                        <tr class="initialized">
                            <td style="text-align:center">
                                <span>@item.STT</span>
                            </td>
                            <td>
                                <div class="item-phieu" @onclick="() => OnEditRecord(item.MaPhieu.ToString())"><i class="bi bi-file-earmark-bar-graph"></i> @item.MaPhieu</div>
                                <div><i class="bi bi-calendar4-event me-1"></i> @string.Format("{0:dd/MM/yyyy}", item.NgayLap)</div>
                                <span><i class="bi bi-person-fill me-1"></i> @item.HoVaTen</span>
                            </td>
                            <td>
                                <span>@item.TenDuAn</span>
                            </td>
                            <td>
                                <div class="item-phieu" @onclick="() => OnViewHD(item.SoHopDong.ToString())"><i class="bi bi-file-earmark-bar-graph"></i> @item.SoHopDong</div>
                                <div @onclick="() => OnMaKHRecord(item.MaKhachHang.ToString())"><i class="bi bi-person-fill me-1"></i>@item.TenKhachHang</div>
                                <div><span class="input-value" @onclick="() => OnViewCH(item.MaCanHo,item.MaDuAn)"><i class="bi bi-building"></i> @item.TenSanPham</span></div>
                            </td>
                            <td class="td-money">
                                <div class="kv-row">
                                    <span class="kv-left">
                                        <i class="bi bi-file-earmark-bar-graph icon-gt"></i>
                                        <span data-bs-toggle="tooltip" data-bs-container="body" data-bs-boundary="window" title="Giá trị hợp đồng">GT</span>
                                    </span>
                                    <span class="kv-val">@string.Format("{0:N0}", item.GiaTriHopDong)</span>
                                </div>

                                <div class="kv-row">
                                    <span class="kv-left">
                                        <i class="bi bi-file-earmark-bar-graph icon-dt"></i>
                                        <span data-bs-toggle="tooltip" data-bs-container="body" data-bs-boundary="window" title="Số tiền đã thu">ĐT</span>
                                    </span>
                                    <span class="kv-val">@string.Format("{0:N0}", item.SoTienDaThu)</span>
                                </div>
                            </td>

                            <td class="td-money">
                                <div class="kv-row">
                                    <span class="kv-left">
                                        <i class="bi bi-wallet2 icon-vp"></i>
                                        <span data-bs-toggle="tooltip" data-bs-container="body" data-bs-boundary="window" title="Số tiền vi phạm hợp đồng">VP</span>
                                    </span>
                                    <span class="kv-val">@string.Format("{0:N0}", item.SoTienViPhamHopDong)</span>
                                </div>

                                <div class="kv-row">
                                    <span class="kv-left">
                                        <i class="bi bi-wallet2 icon-ht"></i>
                                        <span data-bs-toggle="tooltip" data-bs-container="body" data-bs-boundary="window" title="Số tiền hoàn trả">HT</span>
                                    </span>
                                    <span class="kv-val">@string.Format("{0:N0}", item.SoTienHoanTra)</span>
                                </div>
                            </td>

                            <td>
                                <span>@item.LyDoThanhLy</span>
                            </td>
                            <td class="text-center">
                                @if (item.TrangThaiDuyet < 1 && item.NguoiThanhLy == maNhanVienHT)
                                {
                                    <div class="d-flex justify-content-center align-items-center">
                                        <div class="icon-button" data-title="Cập nhật" data-position="left">
                                            <a href="javascript:void()" @onclick="() => OnEditRecord(item.MaPhieu!)">
                                                <span>
                                                    <i class="mdi mdi-pencil">
                                                    </i>
                                                </span>
                                            </a>
                                        </div>
                                        <div class="icon-button" data-title="Xóa" data-position="left">
                                            <a href="javascript:void(0)" @onclick="() => ShowConfirmDelete(item.MaPhieu!)"><span><i class="mdi mdi-delete "></i></span></a>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="icon-button" data-title="@item.TenTrangThai" data-position="left">
                                        <a href="javascript:void(0);" @onclick="() => LichSuDuyetPhieu(maCongViec,item.MaPhieu)">
                                            <i class="@(item.Icon) icon-trangthai" style="color: @(item.Mau)"></i>
                                        </a>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        @if (listTLDC == null || !listTLDC.Any())
        {
            <div class="p-2">Không có dữ liệu</div>
        }
    </div>
    <Pagination Page="@_page"
                TotalPages="@totalPage"
                OnPageChanged="HandlePageChanged"
                OnPageSizeChanged="HandlePageSizeChanged" />
</div>

<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Xác nhận xóa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc muốn xóa phiếu thanh lý hợp đồng <strong>@selectedSoPhieu</strong> không?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Xác nhận xóa</button>
            </div>
        </div>
    </div>
</div>
<PopupLichSuDuyetPhieu @ref="guiDuyetModalRef" />
<CanHoDetails @ref="canHoModalRef" />
@code {
    private DotNetObjectReference<Index>? _dotNetRef;
    private string? selectedDuAn;
    private string? selectedMaPhieu;
    private string? selectedSoPhieu;
    private bool isLoading = false;
    int _page = 1;
    int _pageSize = 10;
    int totalPage = 1;
    int totalCount;
    string? search;
    List<ThanhLyHopDongPagingDto> listTLDC = new();
    private List<DaDanhMucDuAn> ListDA = new();
    private string? tuNgay { get; set; } = DateTime.Now.AddMonths(-1).ToString("dd/MM/yyyy");
    private string? denNgay { get; set; } = DateTime.Now.ToString("dd/MM/yyyy");
    private PopupLichSuDuyetPhieu? guiDuyetModalRef;
    DateRangePicker dateRangeRef;
    MoreFilterPopup morePopupRef;
    private string? selectedTrangThaiDuyet;
    private string maCongViec = "ThanhLyHopDong";
    private CanHoDetails? canHoModalRef;
    private string maNhanVienHT;
   
 
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync(maCongViec, VuViec.Xem.GetDescription());
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaDuAn", "Chọn dự án", true);
            await JS.InvokeVoidAsync("tooltipHelper.init");
            ListDA = await ThanhLyHopDongService.GetByDuAnAsync();
            maNhanVienHT = await BaseService.MaNhanVienHienTai();
            await LoadPhieuThanhLyDC();
            StateHasChanged();
        }
        // if (listTLDC.Any())
        // {
        //     var config = new List<FixColumnConfig>
        //     {
        //         new FixColumnConfig { left = 0 },
        //         new FixColumnConfig { right = 0 }
        //     };
        //     await JS.InvokeVoidAsync("applyStickyColumnsDynamic", "table-data", config);
        // }

    }

    private async Task ShowConfirmDelete(string maPhieu)
    {
        var coQuyen = await BaseService.KiemTraQuyenVuViec(maCongViec, VuViec.Xoa.GetDescription());
        if (coQuyen == false)
        {
            await JS.InvokeVoidAsync("showToast", "Thông báo", "Bạn không có quyền xóa. Xin vui lòng liên hệ quản trị", false);
            return;
        }
        selectedMaPhieu = maPhieu;
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteModal");
    }

    private async Task ConfirmDelete()
    {
        if (selectedMaPhieu == null || string.IsNullOrEmpty(selectedMaPhieu))
        {
            return;
        }
        var result = await ThanhLyHopDongService.DeleteAsync(selectedMaPhieu);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteModal");
        await LoadPhieuThanhLyDC();
        selectedMaPhieu = string.Empty;
        StateHasChanged();
    }

    private async Task OnDTKHChanged(ChangeEventArgs e)
    {
        var newDA = e.Value?.ToString();
        if (newDA == selectedDuAn || isLoading)
        {
            return;
        }
        selectedDuAn = newDA;
        _page = 1;
        await LoadPhieuThanhLyDC();
    }

    async Task Search()
    {
        _page = 1;
        await LoadPhieuThanhLyDC();
    }

    private async Task LoadPhieuThanhLyDC()
    {
        isLoading = true;
        try
        {
            var (data, total) = await ThanhLyHopDongService.GetPagingAsync(selectedDuAn, _page, _pageSize, search, selectedTrangThaiDuyet, tuNgay, denNgay);
            listTLDC = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }
    private async Task HandlePageChanged(int newPage)
    {
        _page = newPage;
        await LoadPhieuThanhLyDC();
    }

    private async Task HandlePageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        _page = 1;
        await LoadPhieuThanhLyDC();
    }
    private async Task Search(string? keyword)
    {
        search = keyword;
        _page = 1;
        await LoadPhieuThanhLyDC();
    }
    private async Task OnEditRecord(string maPhieu)
    {
        Nav.NavigateTo($"/thanhlyhopdong/edit/{maPhieu}");
    }
    private void Insert()
    {
        Nav.NavigateTo("/thanhlyhopdong/create");
        return;
    }

    private async Task OnDateRangeChanged((string? Start, string? End) range)
    {
        tuNgay = range.Start;
        denNgay = range.End;
        await LoadPhieuThanhLyDC();
    }

    private async Task OnTTDChanged(string trangThai)
    {
        var newTTD = trangThai;
        if (newTTD == selectedTrangThaiDuyet || isLoading)
        {
            return;
        }
        selectedTrangThaiDuyet = newTTD;
        _page = 1;
        await LoadPhieuThanhLyDC();
    }

    private async Task ResetAllParam()
    {
        _page = 1;
        _pageSize = 10;
        search = null;
        selectedTrangThaiDuyet = null;
        selectedDuAn = null;
        tuNgay = null;
        denNgay = null;
        await LoadPhieuThanhLyDC();
        await dateRangeRef.ResetAsync();
        await morePopupRef.RestAllMore();
        await JS.InvokeVoidAsync("select2Helper.resetMultipleSelects", new[] { "MaDuAn", "TrangThaiDuyet" });
        StateHasChanged();
    }

    private async Task ResetMore()
    {
        _page = 1;
        _pageSize = 10;
        await LoadPhieuThanhLyDC();
    }

    private async Task LichSuDuyetPhieu(string MaCongViec, string MaPhieu)
    {
        await guiDuyetModalRef?.ShowLSDP(MaCongViec, MaPhieu);
    }

    private async Task OnMaKHRecord(string maKH)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/khachhang/edit/" + maKH);
    }

    private async Task OnViewHD(string maHopDong)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/hopdongmuaban/edit/" + maHopDong);
    }

    private async Task OnViewCH(string maCanHo, string maDuAn)
    {
        if (canHoModalRef != null)
        {
            var canHo = await BaseService.ThongTinChiTietSanPham(maDuAn, maCanHo);
            await canHoModalRef.Show(canHo);
        }
    }

}
