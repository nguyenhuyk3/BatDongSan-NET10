    private async Task OnCheckboxAllChanged(ChangeEventArgs e)
    {
        IsSelectAll = (bool)e.Value;
        foreach (var item in listPGC)
        {
            if (item.TrangThaiDuyet < 1 && item.NguoiLap == maNhanVienHT && string.IsNullOrWhiteSpace(item.MaPhieuTH))
            {
                item.IsSelected = IsSelectAll;
            }
        }
    }

    private async Task OnCheckboxChanged(PhieuGiuChoPagingDto item, ChangeEventArgs e)
    {
        item.IsSelected = (bool)e.Value;
        IsSelectAll = listPGC.All(x => x.IsSelected || !(x.TrangThaiDuyet < 1 && x.NguoiLap == maNhanVienHT) || !(string.IsNullOrWhiteSpace(x.MaPhieuTH)));
    }

