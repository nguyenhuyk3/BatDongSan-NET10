        selectedMaSan = newSGG;
        _page = 1;
        await LoadPhieuGiuCho();
    }

    private async Task LoadPhieuGiuCho()
    {
        isLoading = true;
        try
        {
            var (data, total) = await PhieuGiuChoService.GetPagingAsync(selectedDuAn, selectedMaSan, selectedTrangThaiDuyet ?? string.Empty, _page, _pageSize, search, tuNgay, denNgay);
            listPGC = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }

