@page "/sanpham/create"
@using System.Text.Json
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Domain.Model.SanPham
@using VTTGROUP.Domain.Model.ViewMatKhoi
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@using VTTGROUP.Domain.Model
@using VTTGROUP.Domain.Helpers
@implements IDisposable
@inject LoadingService Loading
@inject IBaseService BaseService
@inject ViewTrucService ViewTrucService
@inject SanPhamService SanPhamService
@inject BlockService BlockService
@inject IJSRuntime JS
@inject NavigationManager Nav

<EditForm id="formDuAn" EditContext="@editContext">
    <h1 class="legend-title">Sản phẩm</h1>
    <div class="container-form">
        <div class="container-tabs">
            <div class="row">
                <div class="col-md-12">
                </div>
            </div>
            <MessageErrorForm />
            <div class="wapper-content-tab">
                <div data-id="1" class="tab-content-item actived-tab" id="tab1">
                    <div class="col-lg-10 mx-auto row">
                        <InfoList Items="@InfoItems" />
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Dự án <i class="point-validate">*</i></span>
                                    <select id="MaDuAn" name="MaDuAn" class="form-control input-validation" @onchange="OnDuAnChanged">
                                        <option value="">-- Chọn dự án --</option>
                                        @foreach (var item in ListDA)
                                        {
                                            <option value="@item.MaDuAn">@item.TenDuAn</option>
                                        }
                                    </select>
                                    <span class="error-validation">Vui lòng chọn dự án</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Loại sản phẩm <i class="point-validate">*</i></span>
                                    <select id="MaLoaiSP" class="form-control input-validation" name="MaLoaiSP" @onchange="OnLoaiSPChanged">
                                        <option value="">Chọn loại sản phẩm</option>
                                        @foreach (var item in ListLSP)
                                        {
                                            <option value="@item.MaLoaiSanPham">@item.TenLoaiSanPham</option>
                                        }
                                    </select>
                                    <span class="error-validation">Vui lòng chọn loại sản phẩm</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Mã sản phẩm<i class="point-validate">*</i></span>
                                    <input class="input-form input-validation" id="MaSanPham" name="MaSanPham" type="text" @bind="@Record.MaSanPham">
                                    <span class="error-validation">Vui lòng nhập mã sản phẩm</span>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Tên sản phẩm <i class="point-validate">*</i></span>
                                    <input class="input-form input-validation" id="TenSanPham" name="TenSanPham" type="text" @bind="@Record.TenSanPham">
                                    <span class="error-validation">Vui lòng nhập tên sản phẩm</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Block <i class="point-validate">*</i></span>
                                    <select id="MaBlock" name="MaBlock" class="form-control input-validation" @onchange="OnBlockChanged">
                                        <option value="">-- Chọn block --</option>
                                        @foreach (var item in ListBlock)
                                        {
                                            <option value="@item.MaBlock">@item.TenBlock</option>
                                        }
                                    </select>
                                    <span class="error-validation">Vui lòng chọn block</span>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Tầng <i class="point-validate">*</i></span>
                                    <select id="MaTang" class="form-control input-validation" name="MaTang" @onchange="OnTangChanged">
                                        <option value="">Chọn tầng</option>
                                        @foreach (var item in ListTang)
                                        {
                                            <option value="@item.MaTang">@item.TenTang</option>
                                        }
                                    </select>
                                    <span class="error-validation">Vui lòng chọn tầng</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Trục <i class="point-validate">*</i></span>
                                    <select id="MaTruc" class="form-control input-validation" name="MaTruc" @onchange="OnTrucChanged">
                                        <option value="">Chọn trục</option>
                                        @foreach (var item in ListTruc)
                                        {
                                            <option value="@item.MaTruc">@item.TenTruc</option>
                                        }
                                    </select>
                                    <span class="error-validation">Vui lòng chọn trục</span>
                                </div>
                            </div>
                        </div>


                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Hệ số tầng</span>
                                    <input class="input-form text-right" type="text" value="@(string.Format("{0:#,##0.##}", Record.HeSoTang))" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Loại căn hộ</span>
                                    <select id="MaLoaiCan" class="form-control" name="MaLoaiCan" @onchange="OnLoaiCanChanged">
                                        <option value="">Chọn loại căn hộ</option>
                                        @foreach (var item in ListLCH)
                                        {
                                            <option value="@item.MaLoaiCanHo">@item.TenLoaiCanHo</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Loại diện tích</span>
                                    <select id="MaLoaiDt" class="form-control" name="MaLoaiDt" @onchange="OnLoaiDTChanged">
                                        <option value="">Chọn loại diện tích</option>
                                        @foreach (var item in ListLDT)
                                        {
                                            <option value="@item.MaLoaiDt">@item.TenLoaiDt</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Loại layout</span>
                                    <select id="MaLoaiThietKe" class="form-control" name="MaLoaiThietKe" @onchange="OnLoaiTKChanged">
                                        <option value="">Chọn loại layout</option>
                                        @foreach (var item in ListLoaiLayout)
                                        {
                                            <option value="@item.MaLoaiThietKe">@item.TenLoaiThietKe</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Hệ số thiết kế <i class="point-validate">*</i></span>
                                    <input class="input-form text-right" type="text" value="@(string.Format("{0:#,##0.##}", Record.HeSoDienTich))" readonly>
                                </div>
                            </div>
                        </div>


                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Hệ số trục</span>
                                    <input class="input-form text-right" type="text" value="@(string.Format("{0:#,##0.##}", Record.HeSoTruc))" readonly>
                                    <input type="hidden" value="@Record.MaLoaiGoc" id="MaLoaiGoc">
                                    <input type="hidden" value="@Record.MaViTri" id="MaViTri">
                                    <input type="hidden" value="@Record.MaView" id="MaView">
                                    <input type="hidden" value="@Record.MaMatKhoi" id="MaMatKhoi">
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Vị trí</span>
                                    <input class="input-form" type="text" value="@Record.TenViTri" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Hệ số vị trí</span>
                                    <input class="input-form text-right" type="text" value="@(string.Format("{0:#,##0.##}", Record.HeSoViTri))" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">View</span>
                                    <input class="input-form" type="text" value="@Record.TenView" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Hệ số view</span>
                                    <input class="input-form text-right" type="text" value="@(string.Format("{0:#,##0.##}", Record.HeSoView))" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Loại góc</span>
                                    <input class="input-form" type="text" value="@Record.TenLoaiGoc" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Hệ số góc</span>
                                    <input class="input-form text-right" type="text" value="@(string.Format("{0:#,##0.##}", Record.HeSoGoc))" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Mặt khối</span>
                                    <input class="input-form" type="text" value="@Record.TenMatKhoi" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="wapper-input col-lg-6" style="display:none">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Hệ số mặt khối</span>
                                    <input class="input-form text-right" type="text" value="@(string.Format("{0:#,##0.##}", Record.HeSoMatKhoi))" readonly>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Diện tích tim tường <i class="point-validate">*</i></span>
                                    <InputCurrency T="decimal" Id="DienTichTimTuong" Format="#,##0.0000" CssClass="input-form input-validation currency-input" @bind-Value="Record.DienTichTimTuong" />
                                    <span class="error-validation">Vui lòng nhập diện tích tim tường</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Diện tích thông thủy <i class="point-validate">*</i></span>
                                    <InputCurrency T="decimal" Id="DienTichThongThuy" Format="#,##0.0000" CssClass="input-form input-validation currency-input" @bind-Value="Record.DienTichThongThuy" />
                                    <span class="error-validation">Vui lòng nhập diện tích thông thủy</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Diện tích sân vườn</span>
                                    <InputCurrency T="decimal" Id="DienTichSanVuon" Format="#,##0.0000" CssClass="input-form currency-input" @bind-Value="Record.DienTichSanVuon" />
                                    <span class="error-validation">Vui lòng nhập diện tích sân vườn</span>
                                </div>
                            </div>
                        </div>
                        <div class="wapper-input col-lg-6">
                            <div class="row">
                                <div class="form-group-input">
                                    <span class="title-field">Hệ số view phụ</span>
                                    <InputCurrency T="decimal" Id="HeSoCanHo" Format="#,##0.0000" CssClass="input-form input-validation currency-input" @bind-Value="Record.HeSoCanHo" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-button">
        <div class="actions-left">
            <UiButton Preset="back" Variant="secondary" OnClick="BackUrl" />
        </div>
        <div class="actions-right">
            <UiButton Preset="save" Variant="primary" OnClick="SubmitFormJs" />
        </div>

    </div>
</EditForm>
@code {
    private EditContext editContext;
    private SanPhamModel? Record = new();
    private List<DaDanhMucDuAn> ListDA = new();
    private List<DaDanhMucLoaiSanPham> ListLSP = new();
    private List<DaDanhMucBlock> ListBlock = new();
    private List<DaDanhMucTang> ListTang = new();
    private List<DaDanhMucLoaiCanHo> ListLCH = new();
    private List<DaLoaiDienTich> ListLDT = new();
    private List<DaDanhMucLoaiThietKe> ListLoaiLayout = new();
    private List<DaDanhMucLoaiGoc> ListGoc = new();
    private List<DaDanhMucViTri> ListVT = new();
    private List<DaDanhMucView> ListView = new();
    private List<DaDanhMucViewTruc> ListTruc = new();
    private List<DaDanhMucViewMatKhoi> ListMMK = new();
    private List<InfoItem> InfoItems = new();
    private CancellationTokenSource? _duAnCts;
    private CancellationTokenSource? _blockCts;
    private bool _disposed;
    // Thêm field nếu chưa có
    private bool _isAuthorized = false;
    public void Dispose()
    {
        _disposed = true;
        _duAnCts?.Cancel();
        _duAnCts?.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(Record);
        ListDA = await BlockService.GetByDuAnAsync();
        ListLSP = await SanPhamService.GetByLoaiSanPhamAsync();
        StateHasChanged();
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync("SanPham", VuViec.Them.GetDescription());
            var result = await SanPhamService.GetByIdAsync(string.Empty);
            if (result.Status)
            {
                Record = (SanPhamModel?)result.Data;
                if (Record == null)
                {
                    Record = new SanPhamModel();
                }
                InfoItems = new()
                {
                    new() { Text="Ngày lập", Value=string.Format("{0:dd/MM/yyyy}", Record.NgayLap)},
                    new() { Text="Người lập", Value=Record.NguoiLap.HoVaTen},
                };
            }

            await JS.InvokeVoidAsync("eval", @"
            setTimeout(function() {
                select2Helper.initSelectChange('MaDuAn', 'Chọn dự án', true);
                select2Helper.initSelectChange('MaBlock', 'Chọn block', true);
                select2Helper.initSelectChange('MaTang', 'Chọn tầng', true);
                select2Helper.initSelectChange('MaLoaiCan', 'Chọn loại căn hộ', true);
                select2Helper.initSelectChange('MaLoaiDt', 'Chọn loại diện tích', true);
                select2Helper.initSelectChange('MaLoaiThietKe', 'Chọn loại diện tích', true);
                select2Helper.initSelectChange('MaTruc', 'Chọn trục', true);
                select2Helper.initSelectChange('MaLoaiSP', 'Chọn loại sản phẩm', true);
            }, 300);");
            await JS.InvokeVoidAsync("InputUtils.setInputMaPhieu", "MaSanPham");
            await JS.InvokeVoidAsync("InputUtils.makeCurrencyFormat", "DienTichTimTuong", 18, 4);
            await JS.InvokeVoidAsync("InputUtils.makeCurrencyFormat", "DienTichThongThuy", 18, 4);
            await JS.InvokeVoidAsync("InputUtils.makeCurrencyFormat", "DienTichSanVuon", 18, 4);
            await JS.InvokeVoidAsync("InputUtils.makeCurrencyFormat", "HeSoCanHo", 18, 4);
            //StateHasChanged();
        }
    }

