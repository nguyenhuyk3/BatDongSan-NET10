    [JSInvokable]
    public async Task SubmitForm()
    {
        Loading.Show();
        try
        {
            var result = await SanPhamService.SaveViewSanPhamAsync(Record);
            await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
            if (result.Status)
            {
                Nav.NavigateTo($"/sanpham/edit/{Record.MaSanPham}");
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", "Lỗi", ex.Message, false);
        }
        finally
        {
            Loading.Hide();
        }
    }

    private async Task OnDuAnChanged(ChangeEventArgs e)
    {
        // Hủy thao tác trước (nếu user đổi Dự án quá nhanh)
        _duAnCts?.Cancel();
        _duAnCts = new CancellationTokenSource();
        var ct = _duAnCts.Token;

        try
        {
            Record.MaDuAn = e.Value?.ToString();

            // 1) Clear model & list phụ thuộc (trước khi load)
            Record.MaBlock = null;
            Record.MaTang = null; Record.HeSoTang = 1; ListTang = new();
            Record.MaLoaiCan = null;

            Record.MaTruc = null; Record.HeSoTruc = 1; ListTruc = new();
            Record.MaViTri = null; Record.TenViTri = null; Record.HeSoViTri = 1;
            Record.MaView = null; Record.TenView = null; Record.HeSoView = 1;
            Record.MaLoaiGoc = null; Record.TenLoaiGoc = null; Record.HeSoGoc = 1;
            Record.MaMatKhoi = null; Record.TenMatKhoi = null; Record.HeSoMatKhoi = 1;

            // 2) Destroy select2 cũ TRƯỚC khi DOM đổi data
            await JS.InvokeVoidAsync("select2Helper.destroy", "#MaBlock");
            await JS.InvokeVoidAsync("select2Helper.destroy", "#MaTang");
            await JS.InvokeVoidAsync("select2Helper.destroy", "#MaLoaiCan");
            await JS.InvokeVoidAsync("select2Helper.destroy", "#MaLoaiDt");
            await JS.InvokeVoidAsync("select2Helper.destroy", "#MaLoaiThietKe");

            // 3) Load dữ liệu theo Dự án mới
            await LoadBlock();   // fill ListBlock theo Record.MaDuAn
            await LoadLCH();     // fill ListLoaiCanHo...
            await LoadLoaiDienTich(); //fill ListLoaiDienTich
            await LoadLoaiLayout(); //fill ListLoaiLayout
            // 4) Re-render để options mới xuất hiện trên DOM
            await InvokeAsync(StateHasChanged);

            // 5) Đợi 1 tick cho DOM “ổn định”, rồi re-init + clear
            await Task.Yield();
            if (_disposed || ct.IsCancellationRequested) return;

            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaBlock", "Chọn mã block", true);
            await JS.InvokeVoidAsync("select2Helper.clear", "MaBlock"); // đảm bảo không dính value cũ

            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaTang", "Chọn tầng", true);
            await JS.InvokeVoidAsync("select2Helper.clear", "MaTang"); // đảm bảo không dính value cũ

            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaLoaiCan", "Chọn loại thiết kế", true);
            await JS.InvokeVoidAsync("select2Helper.clear", "MaLoaiCan"); // đảm bảo không dính value cũ

            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaLoaiDt", "Chọn loại diện tích", true);
            await JS.InvokeVoidAsync("select2Helper.clear", "MaLoaiDt"); // đảm bảo không dính value cũ

            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaLoaiThietKe", "Chọn loại layout", true);
            await JS.InvokeVoidAsync("select2Helper.clear", "MaLoaiThietKe"); // đảm bảo không dính value cũ

            //  CapNhatHeSo();
        }
        catch (OperationCanceledException)
        {
            // bị hủy do user đổi dự án nhanh → bỏ qua
        }
    }

    private async Task OnBlockChanged(ChangeEventArgs e)
    {
        // Hủy phiên trước (user đổi nhanh)
        _blockCts?.Cancel();
        _blockCts = new CancellationTokenSource();
        var ct = _blockCts.Token;

        Record.MaBlock = e.Value?.ToString();

        // Nếu bỏ chọn Block → clear hết, destroy select2, rồi thoát
        if (string.IsNullOrWhiteSpace(Record.MaBlock))
        {
            // reset model/list phụ thuộc
            Record.MaTang = null; Record.HeSoTang = 1; ListTang = new();
            Record.MaTruc = null; Record.HeSoTruc = 1; ListTruc = new();

            Record.MaViTri = null; Record.TenViTri = null; Record.HeSoViTri = 1;
            Record.MaView = null; Record.TenView = null; Record.HeSoView = 1;
            Record.MaLoaiGoc = null; Record.TenLoaiGoc = null; Record.HeSoGoc = 1;
            Record.MaMatKhoi = null; Record.TenMatKhoi = null; Record.HeSoMatKhoi = 1;

            await JS.InvokeVoidAsync("select2Helper.destroy", "#MaTang");
            await JS.InvokeVoidAsync("select2Helper.destroy", "#MaTruc");
            await InvokeAsync(StateHasChanged);
            return;
        }

        // 1) Destroy select2 cũ TRƯỚC khi đổi data
        await JS.InvokeVoidAsync("select2Helper.destroy", "#MaTang");
        await JS.InvokeVoidAsync("select2Helper.destroy", "#MaTruc");


        // 2) Reset model phụ thuộc ngay lập tức (tránh hiển thị giá trị cũ)
        Record.MaTang = null; Record.HeSoTang = 1; ListTang = new();
        Record.MaTruc = null; Record.HeSoTruc = 1; ListTruc = new();

        Record.MaViTri = null; Record.TenViTri = null; Record.HeSoViTri = 1;
        Record.MaView = null; Record.TenView = null; Record.HeSoView = 1;
        Record.MaLoaiGoc = null; Record.TenLoaiGoc = null; Record.HeSoGoc = 1;
        Record.MaMatKhoi = null; Record.TenMatKhoi = null; Record.HeSoMatKhoi = 1;

        // 3) Load dữ liệu theo Block mới (song song để nhanh hơn)
        var loadTangTask = LoadTang();
        var loadTrucTask = LoadTruc();
        await Task.WhenAll(loadTangTask, loadTrucTask);

        // 4) Re-render để DOM có option mới
        await InvokeAsync(StateHasChanged);

        // 5) Đợi 1 tick cho DOM ổn định rồi re-init
        await Task.Yield();
        if (_disposed || ct.IsCancellationRequested) return;

        await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaTang", "Chọn tầng", true);
        await JS.InvokeVoidAsync("select2Helper.clear", "MaTang"); // đảm bảo không dính value cũ

        await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaTruc", "Chọn trục", true);
        await JS.InvokeVoidAsync("select2Helper.clear", "MaTruc"); // đảm bảo không dính value cũ

        // (tuỳ thích) focus vào MaTang cho thao tác nhanh
        // await JS.InvokeVoidAsync("select2Helper.focus", "#MaTang");

        CapNhatHeSo();
    }

