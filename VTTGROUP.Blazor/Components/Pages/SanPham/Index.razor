@page "/sanpham"
@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.Paging
@using VTTGROUP.Domain.Helpers
@using VTTGROUP.Domain.Model
@using VTTGROUP.Domain.Model.SanPham
@using VTTGROUP.Domain.Model.ViewMatKhoi
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@inject IBaseService BaseService
@inject MatKhoiService MatKhoiService
@inject SanPhamService SanPhamService
@inject CanHoService CanHoService
@inject BlockService BlockService
@inject TangService TangService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IWebHostEnvironment _env

<h1 class="legend-title">Danh sách sản phẩm</h1>

<div class="rounded-xl bg-white p-4 space-y-3 wraper-content-page">
    <div class="relative z-50">
        <div class="flex flex-wrap items-end gap-3">
            <UiSelect Icon="mdi mdi-office-building-outline"
                      Placeholder="Chọn dự án"
                      Items="ListDA.Select(x => new UiSelect.SelectItem(x.MaDuAn!, x.TenDuAn!))"
                      @bind-Value="selectedMaDuAn"
                      OnChange="OnDuAnChanged" />

            <UiSelect Icon="mdi mdi-view-grid-outline"
                      Placeholder="Chọn block"
                      Disabled="@(string.IsNullOrEmpty(selectedMaDuAn))"
                      Items="(ListBlock ?? new()).Select(x => new UiSelect.SelectItem(x.MaBlock!, x.TenBlock!))"
                      @bind-Value="selectedBlock"
                      OnChange="OnBlockChanged" />

            <UiSelect Icon="mdi mdi-floor-plan"
                      Placeholder="Chọn tầng"
                      Disabled="@(string.IsNullOrEmpty(selectedBlock))"
                      Items="(ListTang ?? new()).Select(x => new UiSelect.SelectItem(x.MaTang!, x.TenTang!))"
                      @bind-Value="selectedTang"
                      OnChange="OnTangChanged" />

            <div class="ml-auto flex items-center gap-2">
                <AddButton Text="Thêm sản phẩm" OnClick="Insert" />
                <button style="
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #EDAD0F;
        padding: 0 12px;
        border-radius: 8px;
        height: 40px;
        background-color: #FDF7E7;
        color: #EDAD0F;
        font-weight: 600;
        font-size: 16px;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
    "
                        title="Import"
                        @onclick="Import">
                    <i class="mdi mdi-cloud-upload"
                       style="
           color: #EDAD0F;
           font-size: 16px;
       ">
                    </i>
                    <span style="
           color: #EDAD0F;
           font-weight: 600;
           font-size: 16px;
           font-family: 'Inter', sans-serif;
       ">
                        Import
                    </span>
                </button>
            </div>
        </div>
    </div>

    <div class="flex items-center gap-3">
        <div class="w-[360px] md:w-[480px]">
            <InputSearch @bind-Value="search" OnSearch="Search" />
        </div>
        <div class="ml-auto h-11 flex items-center">
            <Pagination Page="@_page"
                        TotalPages="@totalPage"
                        TotalItems="@totalCount"
                        OnPageChanged="HandlePageChanged"
                        OnPageSizeChanged="HandlePageSizeChanged" />
        </div>
    </div>
    <SelectedDeleteList Count="@SelectedCount" OnRemoveList="RemoveSelectedAsync" OnDeleteList="@DeleteSelectedAsync" />
    <div class="container-table-detail">
        <div class="container-table-fixed has-paging">
            <table class="tbl table-form table-detail treeTable" id="table-data">
                <thead>
                    <tr>
                        <th style="width: 40px" class="text-center" rowspan="2">
                            <input type="checkbox" class="form-check-input" checked="@IsSelectAll"
                                   @onchange="(e) => OnCheckboxAllChanged(e)" />
                        </th>
                        <th style="width: 40px" rowspan="2" class="text-center">
                            STT
                        </th>
                        <th style="width: 130px" rowspan="2" class="text-center">Hệ thống</th>
                        <th style="width: 220px" rowspan="2" class="text-center">Dự án</th>
                        <th style="width: 120px" rowspan="2" class="text-center">Block</th>
                        <th style="width: 120px" rowspan="2" class="text-center">Tầng</th>
                        <th style="width: 120px" rowspan="2" class="text-center">Trục</th>
                        <th style="width: 120px" rowspan="2" class="text-center">Loại căn</th>
                        <th style="width: 120px" rowspan="2" class="text-center">Loại diện tích</th>
                        <th style="width: 120px" rowspan="2" class="text-center">Loại layout</th>
                        <th colspan="3" style="text-align:center">Diện tích</th>
                        <th style="width: 120px" rowspan="2" class="text-center">Hệ số view phụ</th>
                        <th style="width: 50px" rowspan="2">
                            &nbsp;
                        </th>
                    </tr>
                    <tr class="cls_custome_back">
                        <th style="width: 110px;text-align:center">Tim tường</th>
                        <th style="width: 110px;text-align:center">Thông thủy</th>
                        <th style="width: 110px;text-align:center">Sân vườn</th>
                    </tr>
                </thead>
                <tbody>
                    @if (sanPhams != null && sanPhams.Any())
                    {
                        foreach (var item in sanPhams)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="text-center">
                                    @if (item.KhongDuocXoa == false)
                                    {
                                        <input type="checkbox" class="form-check-input"
                                               checked="@item.IsSelected"
                                               @onchange="(e) => OnCheckboxChanged(item, e)" />
                                    }
                        </td>
                        <td class="text-center">@item.STT</td>
                        <td>
                            <div class="item-phieu" @onclick="() => OnEditRecord(item.MaSanPham.ToString())">@item.MaSanPham</div>
                            <span class="created-label">@item.HoVaTen</span>
                            <div class="created-date-label">
                                @(item.NgayLap == DateTime.MinValue
                                                                ? ""
                                                                : item.NgayLap.ToString("dd/MM/yyyy"))
                            </div>
                        </td>
                        <td>@item.TenDuAn</td>
                        <td>@item.TenBlock</td>
                        <td>
                            @item.TenTang
                        </td>
                        <td>
                            @item.TenTruc
                        </td>
                        <td>
                            @item.TenLoaiCanHo
                        </td>
                        <td>@item.TenLoaiDT</td>
                        <td>@item.TenLoaiThietKe</td>
                        <td style="text-align:right"> @string.Format("{0:N2}", item.DienTichTimTuong)</td>
                        <td style="text-align:right"> @string.Format("{0:N2}", item.DienTichThongThuy)</td>
                        <td style="text-align:right">@string.Format("{0:N2}", item.DienTichSanVuon)</td>
                        <td style="text-align:right">
                            @string.Format("{0:N4}", item.HeSoCanHo)
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center align-items-center flex-column">
                                <div class="icon-button" data-title="Cập nhật" data-position="left">
                                    <a href="javascript:void(0)" @onclick="() => OnEditRecord(item.MaSanPham!)">
                                        <span><i class="mdi mdi-pencil"></i></span>
                                    </a>
                                </div>
                                @if (item.KhongDuocXoa == false)
                                        {
                                            <div class="icon-button" data-title="Xóa" data-position="left">
                                                <a href="javascript:void(0)" @onclick="() => ShowConfirmDelete(item.MaSanPham!)">
                                                    <span><i class="mdi mdi-delete"></i></span>
                                                </a>
                                            </div>
                                        }

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            @if (sanPhams == null || !sanPhams.Any())
            {
                <div class="p-2">Không có dữ liệu</div>
            }
        </div>
    </div>
    <ConfirmDeleteModal ModalId="confirmDeleteModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa sản phẩm này <strong>@selectedMaCongViec</strong> không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDelete">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>

    <ConfirmDeleteModal ModalId="confirmDeleteListModal"
                        Title="Xác nhận xoá thông tin">
        <Description>
            <p class="delete-desc">
                Bạn có chắc muốn xóa danh sách sản phẩm này không?
            </p>
        </Description>

        <DeleteButton>
            <button type="button" class="btn-delete" @onclick="ConfirmDeleteList">
                Xoá vĩnh viễn
            </button>
        </DeleteButton>
    </ConfirmDeleteModal>

    <ImportFileModal DuAnOptions="@ListDA" LoaiSanPhamOptions="@ListLSP" OnUploaded="HandleFileUpload" />
</div>
@code {
    private DotNetObjectReference<Index>? _dotNetRef;
    private List<ViewMatKhoiModel> ChiTietView = new();
    private List<DaDanhMucDuAn> ListDA = new();
    private List<DaDanhMucLoaiSanPham> ListLSP = new();
    private List<DaDanhMucBlock> ListBlock = new();
    private List<DaDanhMucTang> ListTang = new();
    private string? selectedMaDuAn;
    private string? selectedBlock;
    private string? selectedTang;
    private string? selectedMaCongViec;
    private bool isLoading = false;
    int _page = 1;
    int _pageSize = 10;
    int totalPage = 1;
    int totalCount;
    string? search;
    List<SanPhamPagingDto> sanPhams = new();
    int SelectedCount => sanPhams?.Count(x => x.IsSelected) ?? 0;
    private bool IsSelectAll = false;
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        ListDA = await CanHoService.GetByDuAnAsync();
        ListLSP = await SanPhamService.GetByLoaiSanPhamAsync();
        await LoadCanHoData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BaseService.CheckPermissionAsync("SanPham", VuViec.Xem.GetDescription());
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaDuAn", "Chọn dự án", true);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaBlock", "Chọn block", true);
            await JS.InvokeVoidAsync("select2Helper.initSelectChange", "MaTang", "Chọn tầng", true);
        }
        // if (sanPhams.Any())
        // {
        //     var config = new List<FixColumnConfig>
        //     {
        //         new FixColumnConfig { left = 4 },
        //         new FixColumnConfig { right = 1 }
        //     };
        //     await JS.InvokeVoidAsync("applyStickyColumnsDynamic", "table-data", config);
        // }
    }

    private async Task ShowConfirmDelete(string maDuAn)
    {
        await BaseService.CheckPermissionAsync("SanPham", VuViec.Xoa.GetDescription());
        selectedMaCongViec = maDuAn;
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteModal");
    }

    private async Task ConfirmDelete()
    {
        if (selectedMaCongViec == null || string.IsNullOrEmpty(selectedMaCongViec))
        {
            return;
        }
        var result = await SanPhamService.DeleteViewAsync(selectedMaCongViec);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteModal");
        await LoadCanHoData();
        selectedMaCongViec = string.Empty;
        StateHasChanged();
    }

    private async Task OnDuAnChanged(string? maDuAn) { if (isLoading) return; selectedMaDuAn = string.IsNullOrWhiteSpace(maDuAn) ? null : maDuAn; ListBlock = await SanPhamService.GetByBlockTheoDuAnAsync(selectedMaDuAn); selectedBlock = null; ListTang = new(); selectedTang = null; _page = 1; await InvokeAsync(StateHasChanged); await LoadCanHoData(); }
    private async Task OnBlockChanged(string? maBlock) { if (isLoading) return; selectedBlock = string.IsNullOrWhiteSpace(maBlock) ? null : maBlock; ListTang = await SanPhamService.GetByTangTheoBlockAsync(selectedBlock, selectedMaDuAn); selectedTang = null; _page = 1; await InvokeAsync(StateHasChanged); await LoadCanHoData(); }
    private async Task OnTangChanged(string? maTang) { if (isLoading) return; selectedTang = string.IsNullOrWhiteSpace(maTang) ? null : maTang; _page = 1; await LoadCanHoData(); }

    private async Task LoadCanHoData()
    {
        isLoading = true;

        try
        {
            var (data, total) = await SanPhamService.GetPagingAsync(selectedMaDuAn, selectedBlock, selectedTang, _page, _pageSize, search);
            sanPhams = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandlePageChanged(int newPage)
    {
        _page = newPage;
        await LoadCanHoData();
    }

    private async Task HandlePageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        _page = 1;
        await LoadCanHoData();
    }

    private async Task OnEditRecord(string maMatKhoi)
    {
        Nav.NavigateTo($"/sanpham/edit/{maMatKhoi}");
    }
    private void Insert()
    {
        Nav.NavigateTo("/sanpham/create");
        return;
    }
    private async Task Import()
    {
        await JS.InvokeVoidAsync("bootstrapModal.show", "#ImportSanPhamModal");
    }
    private async Task HandleFileUpload()
    {
        await LoadCanHoData();
    }

    private async Task Search(string? keyword)
    {
        search = keyword;
        _page = 1;
        await LoadCanHoData();
    }

    private async Task RemoveSelectedAsync()
    {
        IsSelectAll = false;
        foreach (var item in sanPhams)
        {
            item.IsSelected = IsSelectAll;
        }
    }

    private async Task DeleteSelectedAsync()
    {
        await JS.InvokeVoidAsync("bootstrapModal.show", "#confirmDeleteListModal");
    }

    private async Task ConfirmDeleteList()
    {
        var selected = sanPhams.Where(d => d.IsSelected).ToList();
        if (selected.Count == 0) return;
        var result = await SanPhamService.DeleteListAsync(selected);
        await JS.InvokeVoidAsync("showToast", "Thông báo", result.Message, result.Status);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#confirmDeleteListModal");
        await LoadCanHoData();
        StateHasChanged();
    }

    private async Task OnCheckboxAllChanged(ChangeEventArgs e)
    {
        IsSelectAll = (bool)e.Value;
        foreach (var item in sanPhams)
        {
            if (item.KhongDuocXoa == false)
            {
                item.IsSelected = IsSelectAll;
            }
        }
    }

    private async Task OnCheckboxChanged(SanPhamPagingDto item, ChangeEventArgs e)
    {
        item.IsSelected = (bool)e.Value;
        IsSelectAll = sanPhams.All(x => x.IsSelected);
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
