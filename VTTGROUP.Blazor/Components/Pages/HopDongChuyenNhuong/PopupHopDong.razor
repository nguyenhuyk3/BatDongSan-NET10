@using VTTGROUP.Blazor.Components.CompChilds
@using VTTGROUP.Blazor.Components.Pages.Paging
@using VTTGROUP.Domain.Model
@using VTTGROUP.Domain.Model.HopDongChuyenNhuong
@using VTTGROUP.Domain.Model.KhachHang
@using VTTGROUP.Infrastructure.Database
@using VTTGROUP.Infrastructure.Services
@inject IBaseService BaseService
@inject HopDongChuyenNhuongService HopDongChuyenNhuongService
@inject IJSRuntime JS
<div class="modal fade" id="PopupChonHDModalTam" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Danh sách hợp đồng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body modal-wraper" id="modal-body">
                @* <div class="container-search-home">
                    <div class="search-row" style="margin-bottom: 15px;">                       
                        <div class="wapper-congtrinh container-form">
                            <div class="result-label-icon">
                                <InputSearch @bind-Value="search" OnSearch="Search" />
                            </div>
                        </div>
                    </div>
                </div> *@
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-[360px] md:w-[480px]">
                        <InputSearch @bind-Value="search" OnSearch="Search" />
                    </div>
                    <div class="ml-auto h-11 flex items-center">
                        <Pagination Page="@_page"
                                    TotalPages="@totalPage"
                                    TotalItems="@totalCount"
                                    OnPageChanged="HandlePageChanged"
                                    OnPageSizeChanged="HandlePageSizeChanged" />
                    </div>
                </div>
                <div class="container-table-detail">
                    <div class="container-table-fixed has-paging">
                        <table class="tbl table-form table-detail treeTable" id="table-data">
                            <thead>
                                <tr class="cls_custome_back">
                                    <th style="width: 50px" class="text-center">
                                        STT
                                    </th>
                                    <th style="width: 130px" class="text-center">
                                        Hợp đồng
                                    </th>
                                    <th style="width: 130px" class="text-center">
                                        Khách hàng
                                    </th>
                                    <th style="width: 130px" class="text-center">
                                        Sản phẩm
                                    </th>
                                    <th style="width: 150px" class="text-center">
                                        Giá trị hợp đồng
                                    </th>
                                    <th style="width: 150px" class="text-center">
                                        Giá trị đã thu
                                    </th>
                                    <th style="width: 90px">
                                        &nbsp;
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="content-table">
                                @if (listHopDong != null && listHopDong.Count > 0)
                                {
                                    @foreach (var item in listHopDong)
                                    {
                                        <tr class="initialized">
                                            <td style="text-align:center">
                                                <span>@item.STT</span>
                                            </td>
                                            <td>
                                                <div class="item-phieu" @onclick="() => OnHopDongRecord(item.MaHopDong.ToString())">@item.SoHopDong</div>
                                            </td>
                                            <td>
                                                <div class="item-phieu" @onclick="() => OnMaKHRecord(item.MaKhachHang.ToString())">@item.TenKhachHang</div>
                                            </td>
                                            <td>
                                                <div class="item-phieu"><span class="input-value" @onclick="() => OnViewCH(item.MaCanHo, item.MaDuAn)">@item.TenSanPham</span></div>
                                            </td>
                                            <td style="text-align:right">
                                                @string.Format("{0:N0}", item.GiaBanSauThue)
                                            </td>
                                            <td style="text-align:right">
                                                @string.Format("{0:N0}", item.GiaTriDaThu)
                                            </td>
                                            <td class="text-center">
                                                <div class="d-flex justify-content-center align-items-center">
                                                    <div class="icon-button" data-title="Chọn" data-position="left">
                                                        <a href="javascript:void(0)" @onclick="() => TriggerChoose(item)"><span><i class="bi bi-check-circle"></i></span></a>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                        @if (listHopDong == null || !listHopDong.Any())
                        {
                            <div class="p-2">Không có dữ liệu</div>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="button button-action button-huy" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
<CanHoDetails @ref="canHoModalRef" />
@code {
    [Parameter]
    public EventCallback<HopDongChuyenNhuongMuaBanPagingDto?> OnSelected { get; set; }
    private string? selectedDuAn;
    private bool isLoading = false;
    int _page = 1;
    int _pageSize = 10;
    int totalPage = 1;
    int totalCount;
    string? search;
    List<HopDongChuyenNhuongMuaBanPagingDto> listHopDong = new();
    private CanHoDetails? canHoModalRef;
    private DotNetObjectReference<PopupHopDong>? dotnetRef;
    // protected override async Task OnInitializedAsync()
    // {
    //     await LoadHopDong();
    // }

    private async Task TriggerChoose(HopDongChuyenNhuongMuaBanPagingDto? item)
    {
        await OnSelected.InvokeAsync(item);
        await JS.InvokeVoidAsync("bootstrapModal.hide", "#PopupChonHDModalTam");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotnetRef = DotNetObjectReference.Create(this);
        }
    }


    private async Task LoadHopDong()
    {
        isLoading = true;
        try
        {
            var (data, total) = await HopDongChuyenNhuongService.GetPagingHopDongPopupAsync(selectedDuAn, _page, _pageSize, search);
            listHopDong = data;
            totalCount = total;
            totalPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        }
        finally
        {
            isLoading = false;
        }
    }
    private async Task HandlePageChanged(int newPage)
    {
        _page = newPage;
        await LoadHopDong();
    }

    private async Task HandlePageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        await LoadHopDong(); // Gọi lại API với PageSize mới
    }

    private async Task Search(string? keyword)
    {
        search = keyword;
        _page = 1;
        await LoadHopDong();
    }

    private async Task OnMaKHRecord(string maKH)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/khachhang/edit/" + maKH);
    }

    private async Task OnHopDongRecord(string maHopDong)
    {
        await JS.InvokeVoidAsync("openInNewTab", "/hopdongmuaban/edit/" + maHopDong);
    }

    private async Task OnViewCH(string maCanHo, string maDuAn)
    {
        if (canHoModalRef != null)
        {
            var canHo = await BaseService.ThongTinChiTietSanPham(maDuAn, maCanHo);
            await canHoModalRef.Show(canHo);
        }
    }

    public async Task Show(string? maDuAn)
    {
        selectedDuAn = maDuAn;
        await LoadHopDong();
        await JS.InvokeVoidAsync("bootstrapModal.show", "#PopupChonHDModalTam");
        await JS.InvokeVoidAsync("modalHelper.makeAllDraggable");
        StateHasChanged();
    }
}
