	private bool IsSameList(List<CongViecDuyetModel> a, List<CongViecDuyetModel> b)
	{
		return a.Count == b.Count && !a.ExceptBy(b.Select(x => x.MaPhieu), x => x.MaPhieu).Any();
	}

	public class TokenResponse
	{
		public string? AccessToken { get; set; }
		public string? RefreshToken { get; set; }
	}

	private async Task ContinueSession()
	{
		try
		{
			var refreshToken = await JS.InvokeAsync<string>("blazorGetCookie", "refreshToken");

			if (!string.IsNullOrEmpty(refreshToken))
			{
				var response = await Http.PostAsJsonAsync("/api/auth/refresh", refreshToken);

				if (response.IsSuccessStatusCode)
				{
					var token = await response.Content.ReadFromJsonAsync<TokenResponse>();
					if (token != null && !string.IsNullOrEmpty(token.AccessToken))
					{

						await JS.InvokeVoidAsync("blazorSetCookie", "accessToken", token.AccessToken, 60 * 24 * 1);
						await JS.InvokeVoidAsync("blazorSetCookie", "refreshToken", token.RefreshToken, 60 * 24 * 7);

						Http.DefaultRequestHeaders.Authorization =
							new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token.AccessToken);

						var exp = GetTokenExpiry(token.AccessToken);
						if (exp.HasValue)
							ScheduleLogout(exp.Value);

						// đóng popup
						_showSessionPopup = false;
						_countdownTimer?.Dispose();
						StateHasChanged();
						return;
					}
				}
			}

			// Nếu fail -> logout
			await ForceLogoutUI();
		}
		catch (Exception ex)
		{
			await ForceLogoutUI();
		}
	}


	private DateTime? GetTokenExpiry(string accessToken)
	{
		try
		{
			var handler = new System.IdentityModel.Tokens.Jwt.JwtSecurityTokenHandler();
			var jwt = handler.ReadJwtToken(accessToken);
			var exp = jwt.Claims.FirstOrDefault(c => c.Type == "exp")?.Value;
			if (long.TryParse(exp, out var expUnix))
				return DateTimeOffset.FromUnixTimeSeconds(expUnix).UtcDateTime;
		}
		catch { }
		return null;
	}

	private void ScheduleLogout(DateTime exp)
	{
		var delay = exp - DateTime.UtcNow;
		if (delay.TotalMilliseconds <= 0)
		{
			_ = InvokeAsync(ForceLogoutUI);
			return;
		}


		var warnDelay = delay - TimeSpan.FromSeconds(10);
		if (warnDelay.TotalMilliseconds > 0)
		{
			_warnTimer?.Dispose();
			_warnTimer = new Timer(_ =>
			{
				_ = InvokeAsync(() =>
				{
					_countdown = 10;
					_showSessionPopup = true;
					StateHasChanged();
					_countdownTimer?.Dispose();
					_countdownTimer = new Timer(_ =>
					{
						_ = InvokeAsync(() =>
						{
							if (_countdown > 0)
							{
								_countdown--;
								StateHasChanged();
							}
						});
					}, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
				});
			}, null, warnDelay, Timeout.InfiniteTimeSpan);
		}

		_logoutTimer?.Dispose();
		_logoutTimer = new Timer(_ =>
		{
			_ = InvokeAsync(ForceLogoutUI);
		}, null, delay, Timeout.InfiniteTimeSpan);
	}

	private async Task ForceLogoutUI()
	{
		try
		{
			// xoá cookie dùng blazorSetCookie (chắc ăn hơn eval)
			await JS.InvokeVoidAsync("blazorSetCookie", "accessToken", "", 0);
			await JS.InvokeVoidAsync("blazorSetCookie", "refreshToken", "", 0);
		}
		catch { }

		Nav.NavigateTo("/login", forceLoad: true);
	}

	private async Task LogOut()
	{
		var refreshToken = await JS.InvokeAsync<string>("blazorGetCookie", "refreshToken");
		if (!string.IsNullOrEmpty(refreshToken))
		{
			var result = await Http.PostAsJsonAsync("/api/auth/logout", refreshToken);
			if (result.IsSuccessStatusCode)
			{
				await JS.InvokeVoidAsync("eval", @"
					document.cookie = 'accessToken=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC;';
					document.cookie = 'refreshToken=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC;';
				");
				Nav.NavigateTo("/login", forceLoad: true);
				return;
			}
		}
	}
