				@* <button class="w-9 h-9 rounded-lg border text-gray-500 hover:bg-gray-100 flex items-center justify-center">
					<i class="bi bi-arrows-fullscreen"></i>
				</button> *@
				<div class="relative">
					<button class="w-9 h-9 rounded-lg border text-gray-500 hover:bg-gray-100 flex items-center justify-center"
