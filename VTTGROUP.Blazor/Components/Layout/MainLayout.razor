	{
		var newList = await BaseService.GetDanhSachPhieuDuyet();
		if (!IsSameList(newList, oldList))
		{
			listCongViec = newList;
			oldList = newList;
			pendingCount = newList.Count;
			await JS.InvokeVoidAsync("showToast", "Thông báo", message, true);
			StateHasChanged();
