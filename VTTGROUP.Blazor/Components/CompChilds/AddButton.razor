@* <button type="button"
        class="addbtn addbtn--searchspec"
        @onclick="OnClick"
        aria-label="@Text"> *@
<button type="button"
        class="addbtn addbtn-searchspec @(Disabled ? "is-disabled" : "")"
        @onclick="OnClick"
        disabled="@Disabled"
        aria-label="@Text">
    <span class="addbtn__icon">
        <i class="mdi mdi-plus-circle-outline"></i>
    </span>
    <span class="addbtn__label">@Text</span>
</button>

@code {
    [Parameter] public string Text { get; set; } = "Thêm";
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public bool Disabled { get; set; }
}
