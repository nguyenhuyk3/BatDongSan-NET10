@page "/not-authorized"
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Không có quyền</PageTitle>

<div class="flex items-center justify-center min-h-[70vh] text-center">
    <div class="bg-white shadow-lg rounded-2xl p-8 max-w-md border border-red-200">
        <div class="text-red-500 text-5xl mb-4">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h2 class="text-2xl font-semibold text-gray-800 mb-2">Bạn không có quyền truy cập</h2>
        <p class="text-gray-600 mb-6">
            Bạn không được cấp quyền để thực hiện vụ việc này. Vui lòng liên hệ quản trị viên nếu đây là lỗi.
        </p>
        <button class="btn-backhome text-white font-medium px-5 py-2 rounded-xl shadow transition"
                @onclick="BackHome">
            <i class="bi bi-arrow-left me-2"></i>Quay lại trang chính
        </button>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {

        }
    }
    private void BackHome()
    {
        Navigation.NavigateTo("/dashboard");
    }
}